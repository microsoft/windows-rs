                ThickLongDash = 19,
            }
            #[repr(i32)]
            #[Windows::Foundation::Metadata::ContractVersion(super::super::Foundation::UniversalApiContract, 65536)]
            enum VerticalCharacterAlignment {
                Top = 0,
                Baseline = 1,
                Bottom = 2,
            }
        }
    }
}

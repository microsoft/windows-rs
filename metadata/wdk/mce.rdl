#[win32]
mod Windows {
    mod Win32 {
        type CMC_EXCEPTION = MCA_EXCEPTION;
        type CPE_EXCEPTION = MCA_EXCEPTION;
        type ERROR_SEVERITY = u8;
        #[repr(i32)]
        enum ERROR_SEVERITY_VALUE {
            ErrorRecoverable = 0,
            ErrorFatal = 1,
            ErrorCorrected = 2,
            ErrorOthers = 3,
        }
        struct MCA_EXCEPTION {
            VersionNumber: u32,
            ExceptionType: MCA_EXCEPTION_TYPE,
            TimeStamp: LARGE_INTEGER,
            ProcessorNumber: u32,
            Reserved1: u32,
            u: union {
                Mca: struct {
                    BankNumber: u8,
                    Reserved2: [u8; 7],
                    Status: MCI_STATS,
                    Address: MCI_ADDR,
                    Misc: u64,
                },
                Mce: struct {
                    Address: u64,
                    Type: u64,
                },
            },
            ExtCnt: u32,
            Reserved3: u32,
            ExtReg: [u64; 24],
        }
        #[repr(i32)]
        enum MCA_EXCEPTION_TYPE {
            HAL_MCE_RECORD = 0,
            HAL_MCA_RECORD = 1,
        }
        const MCA_EXCEPTION_V1_SIZE: u32 = 56;
        const MCA_EXTREG_V2MAX: u32 = 24;
        union MCI_ADDR {
            Anonymous: struct {
                Address: u32,
                Reserved: u32,
            },
            QuadPart: u64,
        }
        union MCI_STATS {
            MciStatus: struct {
                McaErrorCode: u16,
                ModelErrorCode: u16,
                _bitfield: u32,
            },
            QuadPart: u64,
        }
        type PCMC_EXCEPTION = *mut MCA_EXCEPTION;
        type PCPE_EXCEPTION = *mut MCA_EXCEPTION;
        type PERROR_SEVERITY = *mut u8;
        type PMCA_EXCEPTION = *mut MCA_EXCEPTION;
        type PMCI_ADDR = *mut MCI_ADDR;
        type PMCI_STATS = *mut MCI_STATS;
    }
}

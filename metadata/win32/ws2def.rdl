        const SO_USELOOPBACK: u32 = 64;
        const TCP_NODELAY: u32 = 1;
        struct WSABUF {
            len: u32,
            buf: *mut i8,
        }
        struct WSACMSGHDR {
            cmsg_len: usize,
            cmsg_level: i32,
            cmsg_type: i32,
        }
        struct WSAMSG {
            name: LPSOCKADDR,
            namelen: i32,
            lpBuffers: LPWSABUF,
            dwBufferCount: u32,
            Control: WSABUF,
            dwFlags: u32,
        }
        const WSK_SO_BASE: u32 = 16384;
    }
}

#[win32]
mod Windows {
    mod Win32 {
        extern fn EVT_VHF_ASYNC_OPERATION(VhfClientContext: *const void, VhfOperationHandle: VHFOPERATIONHANDLE, #[opt] VhfOperationContext: *const void, HidTransferPacket: *const HID_XFER_PACKET);
        extern fn EVT_VHF_CLEANUP(VhfClientContext: *const void);
        extern fn EVT_VHF_READY_FOR_NEXT_READ_REPORT(VhfClientContext: *const void);
        type PEVT_VHF_ASYNC_OPERATION = *mut EVT_VHF_ASYNC_OPERATION;
        type PEVT_VHF_CLEANUP = *mut EVT_VHF_CLEANUP;
        type PEVT_VHF_READY_FOR_NEXT_READ_REPORT = *mut EVT_VHF_READY_FOR_NEXT_READ_REPORT;
        type PVHF_CONFIG = *mut VHF_CONFIG;
        type VHFHANDLE = *mut void;
        type VHFOPERATIONHANDLE = *mut void;
        struct VHF_CONFIG {
            Size: u32,
            VhfClientContext: *mut void,
            OperationContextSize: u32,
            FileHandle: HANDLE,
            VendorID: u16,
            ProductID: u16,
            VersionNumber: u16,
            ContainerID: GUID,
            InstanceIDLength: u16,
            InstanceID: PWSTR,
            ReportDescriptorLength: u16,
            ReportDescriptor: PUCHAR,
            EvtVhfReadyForNextReadReport: PEVT_VHF_READY_FOR_NEXT_READ_REPORT,
            EvtVhfAsyncOperationGetFeature: PEVT_VHF_ASYNC_OPERATION,
            EvtVhfAsyncOperationSetFeature: PEVT_VHF_ASYNC_OPERATION,
            EvtVhfAsyncOperationWriteReport: PEVT_VHF_ASYNC_OPERATION,
            EvtVhfAsyncOperationGetInputReport: PEVT_VHF_ASYNC_OPERATION,
            EvtVhfCleanup: PEVT_VHF_CLEANUP,
            HardwareIDsLength: u16,
            HardwareIDs: PWSTR,
        }
    }
}

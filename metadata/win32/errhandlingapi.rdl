#[win32]
mod Windows {
    mod Win32 {
        #[library("KERNEL32.dll")]
        extern fn AddVectoredContinueHandler(First: u32, Handler: PVECTORED_EXCEPTION_HANDLER) -> *mut void;
        #[library("KERNEL32.dll")]
        extern fn AddVectoredExceptionHandler(First: u32, Handler: PVECTORED_EXCEPTION_HANDLER) -> *mut void;
        #[library("KERNEL32.dll")]
        extern fn FatalAppExitA(uAction: u32, lpMessageText: PCSTR);
        #[library("KERNEL32.dll")]
        extern fn FatalAppExitW(uAction: u32, lpMessageText: PCWSTR);
        #[library("KERNEL32.dll")]
        extern fn GetErrorMode() -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetLastError() -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetThreadErrorMode() -> u32;
        type LPTOP_LEVEL_EXCEPTION_FILTER = PTOP_LEVEL_EXCEPTION_FILTER;
        extern fn PTOP_LEVEL_EXCEPTION_FILTER(ExceptionInfo: *const EXCEPTION_POINTERS) -> i32;
        #[library("KERNEL32.dll")]
        extern fn RaiseException(dwExceptionCode: u32, dwExceptionFlags: u32, nNumberOfArguments: u32, #[len_param(2)] #[opt] lpArguments: *const usize);
        #[arch(Arm64)]
        #[library("KERNEL32.dll")]
        extern fn RaiseFailFastException(#[opt] pExceptionRecord: *const EXCEPTION_RECORD, #[opt] pContextRecord: *const ARM64_NT_CONTEXT, dwFlags: u32);
        #[arch(X86 | X64)]
        #[library("KERNEL32.dll")]
        extern fn RaiseFailFastException(#[opt] pExceptionRecord: *const EXCEPTION_RECORD, #[opt] pContextRecord: *const CONTEXT, dwFlags: u32);
        #[library("KERNEL32.dll")]
        extern fn RemoveVectoredContinueHandler(Handle: *const void) -> u32;
        #[library("KERNEL32.dll")]
        extern fn RemoveVectoredExceptionHandler(Handle: *const void) -> u32;
        #[library("KERNEL32.dll")]
        extern fn SetErrorMode(uMode: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern fn SetLastError(dwErrCode: u32);
        #[library("KERNEL32.dll")]
        extern fn SetThreadErrorMode(dwNewMode: u32, #[opt] lpOldMode: *const u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SetUnhandledExceptionFilter(#[opt] lpTopLevelExceptionFilter: LPTOP_LEVEL_EXCEPTION_FILTER) -> LPTOP_LEVEL_EXCEPTION_FILTER;
        #[library("api-ms-win-core-errorhandling-l1-1-3.dll")]
        extern fn TerminateProcessOnMemoryExhaustion(FailedAllocationSize: usize);
        #[library("KERNEL32.dll")]
        extern fn UnhandledExceptionFilter(ExceptionInfo: *const EXCEPTION_POINTERS) -> i32;
    }
}

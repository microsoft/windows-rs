#[win32]
mod Windows {
    mod Win32 {
        #[guid(0xd5fb0a7f_e74e_44f5_8e02_4806863a274f)]
        interface ILocationPermissions: IUnknown {
            fn GetGlobalLocationPermission(&self, pfEnabled: *mut BOOL) -> HRESULT;
            fn CheckLocationCapability(&self, dwClientThreadId: u32) -> HRESULT;
        }
        #[guid(0x5fa08f80_2657_458e_af75_46f73fa6ac5c)]
        interface ISensor: IUnknown {
            fn GetID(&self, pID: *mut SENSOR_ID) -> HRESULT;
            fn GetCategory(&self, pSensorCategory: *mut SENSOR_CATEGORY_ID) -> HRESULT;
            fn GetType(&self, pSensorType: *mut SENSOR_TYPE_ID) -> HRESULT;
            fn GetFriendlyName(&self, pFriendlyName: *mut BSTR) -> HRESULT;
            fn GetProperty(&self, key: *const PROPERTYKEY, pProperty: *mut PROPVARIANT) -> HRESULT;
            fn GetProperties(&self, pKeys: IPortableDeviceKeyCollection, ppProperties: *mut IPortableDeviceValues) -> HRESULT;
            fn GetSupportedDataFields(&self, ppDataFields: *mut IPortableDeviceKeyCollection) -> HRESULT;
            fn SetProperties(&self, pProperties: IPortableDeviceValues, ppResults: *mut IPortableDeviceValues) -> HRESULT;
            fn SupportsDataField(&self, key: *const PROPERTYKEY, pIsSupported: *mut VARIANT_BOOL) -> HRESULT;
            fn GetState(&self, pState: *mut SensorState) -> HRESULT;
            fn GetData(&self, ppDataReport: *mut ISensorDataReport) -> HRESULT;
            fn SupportsEvent(&self, eventGuid: *const GUID, pIsSupported: *mut VARIANT_BOOL) -> HRESULT;
            fn GetEventInterest(&self, ppValues: *mut *mut GUID, pCount: *mut u32) -> HRESULT;
            fn SetEventInterest(&self, pValues: *const GUID, count: u32) -> HRESULT;
            fn SetEventSink(&self, pEvents: ISensorEvents) -> HRESULT;
        }
        #[guid(0x23571e11_e545_4dd8_a337_b89bf44b10df)]
        interface ISensorCollection: IUnknown {
            fn GetAt(&self, ulIndex: u32, ppSensor: *mut ISensor) -> HRESULT;
            fn GetCount(&self, pCount: *mut u32) -> HRESULT;
            fn Add(&self, pSensor: ISensor) -> HRESULT;
            fn Remove(&self, pSensor: ISensor) -> HRESULT;
            fn RemoveByID(&self, sensorID: REFSENSOR_ID) -> HRESULT;
            fn Clear(&self) -> HRESULT;
        }
        #[guid(0x0ab9df9b_c4b5_4796_8898_0470706a2e1d)]
        interface ISensorDataReport: IUnknown {
            fn GetTimestamp(&self, pTimeStamp: *mut SYSTEMTIME) -> HRESULT;
            fn GetSensorValue(&self, pKey: *const PROPERTYKEY, pValue: *mut PROPVARIANT) -> HRESULT;
            fn GetSensorValues(&self, pKeys: IPortableDeviceKeyCollection, ppValues: *mut IPortableDeviceValues) -> HRESULT;
        }
        #[guid(0x5d8dcc91_4641_47e7_b7c3_b74f48a6c391)]
        interface ISensorEvents: IUnknown {
            fn OnStateChanged(&self, pSensor: ISensor, state: SensorState) -> HRESULT;
            fn OnDataUpdated(&self, pSensor: ISensor, pNewData: ISensorDataReport) -> HRESULT;
            fn OnEvent(&self, pSensor: ISensor, eventID: *const GUID, pEventData: IPortableDeviceValues) -> HRESULT;
            fn OnLeave(&self, ID: REFSENSOR_ID) -> HRESULT;
        }
        #[guid(0xbd77db67_45a8_42dc_8d00_6dcf15f8377a)]
        interface ISensorManager: IUnknown {
            fn GetSensorsByCategory(&self, sensorCategory: REFSENSOR_CATEGORY_ID, ppSensorsFound: *mut ISensorCollection) -> HRESULT;
            fn GetSensorsByType(&self, sensorType: REFSENSOR_TYPE_ID, ppSensorsFound: *mut ISensorCollection) -> HRESULT;
            fn GetSensorByID(&self, sensorID: REFSENSOR_ID, ppSensor: *mut ISensor) -> HRESULT;
            fn SetEventSink(&self, pEvents: ISensorManagerEvents) -> HRESULT;
            fn RequestPermissions(&self, hParent: HWND, pSensors: ISensorCollection, fModal: BOOL) -> HRESULT;
        }
        #[guid(0x9b3b0b86_266a_4aad_b21f_fde5501001b7)]
        interface ISensorManagerEvents: IUnknown {
            fn OnSensorEnter(&self, pSensor: ISensor, state: SensorState) -> HRESULT;
        }
        #[repr(i32)]
        enum LOCATION_DESIRED_ACCURACY {
            LOCATION_DESIRED_ACCURACY_DEFAULT = 0,
            LOCATION_DESIRED_ACCURACY_HIGH = 1,
        }
        #[repr(i32)]
        enum LOCATION_POSITION_SOURCE {
            LOCATION_POSITION_SOURCE_CELLULAR = 0,
            LOCATION_POSITION_SOURCE_SATELLITE = 1,
            LOCATION_POSITION_SOURCE_WIFI = 2,
            LOCATION_POSITION_SOURCE_IPADDRESS = 3,
            LOCATION_POSITION_SOURCE_UNKNOWN = 4,
        }
        #[repr(i32)]
        enum MagnetometerAccuracy {
            MAGNETOMETER_ACCURACY_UNKNOWN = 0,
            MAGNETOMETER_ACCURACY_UNRELIABLE = 1,
            MAGNETOMETER_ACCURACY_APPROXIMATE = 2,
            MAGNETOMETER_ACCURACY_HIGH = 3,
        }
        type REFSENSOR_CATEGORY_ID = *const GUID;
        type REFSENSOR_ID = *const GUID;
        type REFSENSOR_TYPE_ID = *const GUID;
        type SENSOR_CATEGORY_ID = GUID;
        type SENSOR_ID = GUID;
        type SENSOR_TYPE_ID = GUID;
        const Sensor: GUID = 0xe97ced00_523a_4133_bf6f_d3a2dae7f6ba;
        const SensorCollection: GUID = 0x79c43adb_a429_469f_aa39_2f2b74b75937;
        #[repr(i32)]
        enum SensorConnectionType {
            SENSOR_CONNECTION_TYPE_PC_INTEGRATED = 0,
            SENSOR_CONNECTION_TYPE_PC_ATTACHED = 1,
            SENSOR_CONNECTION_TYPE_PC_EXTERNAL = 2,
        }
        const SensorDataReport: GUID = 0x4ea9d6ef_694b_4218_8816_ccda8da74bba;
        const SensorManager: GUID = 0x77a1c827_fcd2_4689_8915_9d613cc5fa3e;
        #[repr(i32)]
        enum SensorState {
            SENSOR_STATE_MIN = 0,
            SENSOR_STATE_READY = 0,
            SENSOR_STATE_NOT_AVAILABLE = 1,
            SENSOR_STATE_NO_DATA = 2,
            SENSOR_STATE_INITIALIZING = 3,
            SENSOR_STATE_ACCESS_DENIED = 4,
            SENSOR_STATE_ERROR = 5,
            SENSOR_STATE_MAX = 5,
        }
        #[repr(i32)]
        enum SimpleDeviceOrientation {
            SIMPLE_DEVICE_ORIENTATION_NOT_ROTATED = 0,
            SIMPLE_DEVICE_ORIENTATION_ROTATED_90 = 1,
            SIMPLE_DEVICE_ORIENTATION_ROTATED_180 = 2,
            SIMPLE_DEVICE_ORIENTATION_ROTATED_270 = 3,
            SIMPLE_DEVICE_ORIENTATION_ROTATED_FACE_UP = 4,
            SIMPLE_DEVICE_ORIENTATION_ROTATED_FACE_DOWN = 5,
        }
    }
}

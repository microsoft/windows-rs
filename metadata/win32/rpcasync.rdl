            rcclRemote = 2,
            rcclClientUnknownLocality = 3,
        }
        #[repr(i32)]
        enum RpcCallType {
            rctInvalid = 0,
            rctNormal = 1,
            rctTraining = 2,
            rctGuaranteed = 3,
        }

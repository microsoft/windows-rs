            CallLocalAddress: *mut RPC_CALL_LOCAL_ADDRESS_V1,
            OpNum: u16,
            InterfaceUuid: GUID,
            ClientIdentifierBufferLength: u32,
            ClientIdentifier: *mut u8,
        }
        struct RPC_CALL_ATTRIBUTES_V3_W {
            Version: u32,
            Flags: u32,
            ServerPrincipalNameBufferLength: u32,
            ServerPrincipalName: *mut u16,
            ClientPrincipalNameBufferLength: u32,
            ClientPrincipalName: *mut u16,
            AuthenticationLevel: u32,
            AuthenticationService: u32,
            NullSession: BOOL,
            KernelModeCaller: BOOL,
            ProtocolSequence: u32,
            IsClientLocal: RpcCallClientLocality,
            ClientPID: HANDLE,
            CallStatus: u32,
            CallType: RpcCallType,
            CallLocalAddress: *mut RPC_CALL_LOCAL_ADDRESS_V1,
            OpNum: u16,
            InterfaceUuid: GUID,
            ClientIdentifierBufferLength: u32,
            ClientIdentifier: *mut u8,
        }
        const RPC_CALL_ATTRIBUTES_VERSION: u32 = 3;
        struct RPC_CALL_LOCAL_ADDRESS_V1 {
            Version: u32,
            Buffer: *mut void,
            BufferSize: u32,
            AddressFormat: RpcLocalAddressFormat,
        }
        const RPC_CALL_STATUS_CANCELLED: u32 = 1;
        const RPC_CALL_STATUS_DISCONNECTED: u32 = 2;
        const RPC_C_INFINITE_TIMEOUT: i32 = -1;
        const RPC_C_NOTIFY_ON_SEND_COMPLETE: u32 = 1;
        const RPC_EEINFO_VERSION: u32 = 1;
        struct RPC_EE_INFO_PARAM {
            ParameterType: ExtendedErrorParamTypes,
            u: union {
                AnsiString: PSTR,
                UnicodeString: PWSTR,
                LVal: i32,
                SVal: i16,
                PVal: u64,
                BVal: BinaryParam,
            },
        }
        struct RPC_ERROR_ENUM_HANDLE {
            Signature: u32,
            CurrentPos: *mut void,
            Head: *mut void,
        }
        struct RPC_EXTENDED_ERROR_INFO {
            Version: u32,
            ComputerName: PWSTR,
            ProcessID: u32,
            u: union {
                SystemTime: SYSTEMTIME,
                FileTime: FILETIME,
            },
            GeneratingComponent: u32,
            Status: u32,
            DetectionLocation: u16,
            Flags: u16,
            NumberOfParameters: i32,
            Parameters: [RPC_EE_INFO_PARAM; 4],
        }
        #[repr(i32)]
        enum RPC_NOTIFICATIONS {
            RpcNotificationCallNone = 0,
            RpcNotificationClientDisconnect = 1,
            RpcNotificationCallCancel = 2,
        }
        #[repr(i32)]
        enum RPC_NOTIFICATION_TYPES {
            RpcNotificationTypeNone = 0,
            RpcNotificationTypeEvent = 1,
            RpcNotificationTypeApc = 2,
            RpcNotificationTypeIoc = 3,
            RpcNotificationTypeHwnd = 4,
            RpcNotificationTypeCallback = 5,
        }
        const RPC_QUERY_CALL_LOCAL_ADDRESS: u32 = 8;
        const RPC_QUERY_CLIENT_ID: u32 = 128;
        const RPC_QUERY_CLIENT_PID: u32 = 16;
        const RPC_QUERY_CLIENT_PRINCIPAL_NAME: u32 = 4;
        const RPC_QUERY_IS_CLIENT_LOCAL: u32 = 32;
        const RPC_QUERY_NO_AUTH_REQUIRED: u32 = 64;
        const RPC_QUERY_SERVER_PRINCIPAL_NAME: u32 = 2;

        #[library("RPCRT4.dll")]
        extern fn I_RpcExceptionFilter(ExceptionCode: u32) -> i32;
        const MaxNumberOfEEInfoParams: u32 = 4;
        extern fn PFN_RPCNOTIFICATION_ROUTINE(pAsync: *mut RPC_ASYNC_STATE, Context: *mut void, Event: RPC_ASYNC_EVENT);
        type PRPC_ASYNC_NOTIFICATION_INFO = *mut RPC_ASYNC_NOTIFICATION_INFO;
        type PRPC_ASYNC_STATE = *mut RPC_ASYNC_STATE;
        type PRPC_CALL_LOCAL_ADDRESS_V1 = *mut RPC_CALL_LOCAL_ADDRESS_V1;
        extern fn RPCNOTIFICATION_ROUTINE(pAsync: *mut RPC_ASYNC_STATE, Context: *mut void, Event: RPC_ASYNC_EVENT);
        #[repr(i32)]
        enum RPC_ASYNC_EVENT {
            RpcCallComplete = 0,
            RpcSendComplete = 1,
            RpcReceiveComplete = 2,
            RpcClientDisconnect = 3,
            RpcClientCancel = 4,
        }
        union RPC_ASYNC_NOTIFICATION_INFO {
            APC: struct {
                NotificationRoutine: PFN_RPCNOTIFICATION_ROUTINE,
                hThread: HANDLE,
            },
            IOC: struct {
                hIOPort: HANDLE,
                dwNumberOfBytesTransferred: u32,
                dwCompletionKey: usize,
                lpOverlapped: LPOVERLAPPED,
            },
            HWND: struct {
                hWnd: HWND,
                Msg: u32,
            },
            hEvent: HANDLE,
            NotificationRoutine: PFN_RPCNOTIFICATION_ROUTINE,
        }
        struct RPC_ASYNC_STATE {
            Size: u32,
            Signature: u32,
            Lock: i32,
            Flags: u32,
            StubInfo: *mut void,
            UserInfo: *mut void,
            RuntimeInfo: *mut void,
            Event: RPC_ASYNC_EVENT,
            NotificationType: RPC_NOTIFICATION_TYPES,
            u: RPC_ASYNC_NOTIFICATION_INFO,
            Reserved: [isize; 4],
        }
        type RPC_CALL_ATTRIBUTES = RPC_CALL_ATTRIBUTES_V3_A;
        struct RPC_CALL_ATTRIBUTES_V1_A {
            Version: u32,
            Flags: u32,
            ServerPrincipalNameBufferLength: u32,
            ServerPrincipalName: *mut u8,
            ClientPrincipalNameBufferLength: u32,
            ClientPrincipalName: *mut u8,
            AuthenticationLevel: u32,
            AuthenticationService: u32,
            NullSession: BOOL,
        }
        struct RPC_CALL_ATTRIBUTES_V1_W {
            Version: u32,
            Flags: u32,
            ServerPrincipalNameBufferLength: u32,
            ServerPrincipalName: *mut u16,
            ClientPrincipalNameBufferLength: u32,
            ClientPrincipalName: *mut u16,
            AuthenticationLevel: u32,
            AuthenticationService: u32,
            NullSession: BOOL,
        }
        struct RPC_CALL_ATTRIBUTES_V2_A {
            Version: u32,
            Flags: u32,
            ServerPrincipalNameBufferLength: u32,
            ServerPrincipalName: *mut u8,
            ClientPrincipalNameBufferLength: u32,
            ClientPrincipalName: *mut u8,
            AuthenticationLevel: u32,
            AuthenticationService: u32,
            NullSession: BOOL,
            KernelModeCaller: BOOL,
            ProtocolSequence: u32,
            IsClientLocal: u32,
            ClientPID: HANDLE,
            CallStatus: u32,
            CallType: RpcCallType,
            CallLocalAddress: *mut RPC_CALL_LOCAL_ADDRESS_V1,
            OpNum: u16,
            InterfaceUuid: GUID,
        }
        struct RPC_CALL_ATTRIBUTES_V2_W {
            Version: u32,
            Flags: u32,
            ServerPrincipalNameBufferLength: u32,
            ServerPrincipalName: *mut u16,
            ClientPrincipalNameBufferLength: u32,

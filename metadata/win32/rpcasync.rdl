        #[library("RPCRT4.dll")]
        extern fn RpcErrorClearInformation();
        #[library("RPCRT4.dll")]
        extern fn RpcErrorEndEnumeration(#[in] #[out] EnumHandle: *mut RPC_ERROR_ENUM_HANDLE) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorGetNextRecord(EnumHandle: *const RPC_ERROR_ENUM_HANDLE, CopyStrings: BOOL, ErrorInfo: *mut RPC_EXTENDED_ERROR_INFO) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorGetNumberOfRecords(EnumHandle: *const RPC_ERROR_ENUM_HANDLE, Records: *mut i32) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorLoadErrorInfo(#[size_param(1)] ErrorBlob: *const void, BlobSize: usize, EnumHandle: *mut RPC_ERROR_ENUM_HANDLE) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorResetEnumeration(#[in] #[out] EnumHandle: *mut RPC_ERROR_ENUM_HANDLE) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorSaveErrorInfo(EnumHandle: *const RPC_ERROR_ENUM_HANDLE, ErrorBlob: *mut *mut void, BlobSize: *mut usize) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcErrorStartEnumeration(EnumHandle: *mut RPC_ERROR_ENUM_HANDLE) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcFreeAuthorizationContext(#[in] #[out] pAuthzClientContext: *mut *mut void) -> RPC_STATUS;
        #[library("RPCRT4.dll")]
        extern fn RpcGetAuthorizationContextForClient(#[opt] ClientBinding: RPC_BINDING_HANDLE, ImpersonateOnReturn: BOOL, #[opt] Reserved1: *const void, #[opt] pExpirationTime: *const LARGE_INTEGER, Reserved2: LUID, Reserved3: u32, #[opt] Reserved4: *const void, pAuthzClientContext: *mut *mut void) -> RPC_STATUS;
        #[repr(i32)]
        enum RpcLocalAddressFormat {
            rlafInvalid = 0,
            rlafIPv4 = 1,
            rlafIPv6 = 2,

#[win32]
mod Windows {
    mod Win32 {
        #[library("KERNEL32.dll")]
        extern fn AddDllDirectory(NewDirectory: PCWSTR) -> DLL_DIRECTORY_COOKIE;
        const CURRENT_IMPORT_REDIRECTION_VERSION: u32 = 1;
        type DLL_DIRECTORY_COOKIE = *mut void;
        const DONT_RESOLVE_DLL_REFERENCES: u32 = 1;
        #[library("KERNEL32.dll")]
        extern fn DisableThreadLibraryCalls(hLibModule: HMODULE) -> BOOL;
        extern fn ENUMRESLANGPROCA(#[opt] hModule: HMODULE, lpType: PCSTR, lpName: PCSTR, wLanguage: u16, lParam: isize) -> BOOL;
        extern fn ENUMRESLANGPROCW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpName: PCWSTR, wLanguage: u16, lParam: isize) -> BOOL;
        extern fn ENUMRESNAMEPROCA(#[opt] hModule: HMODULE, lpType: PCSTR, lpName: PCSTR, lParam: isize) -> BOOL;
        extern fn ENUMRESNAMEPROCW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpName: PCWSTR, lParam: isize) -> BOOL;
        extern fn ENUMRESTYPEPROCA(#[opt] hModule: HMODULE, lpType: PCSTR, lParam: isize) -> BOOL;
        extern fn ENUMRESTYPEPROCW(#[opt] hModule: HMODULE, lpType: PCWSTR, lParam: isize) -> BOOL;
        struct ENUMUILANG {
            NumOfEnumUILang: u32,
            SizeOfEnumUIBuffer: u32,
            pEnumUIBuffer: *mut LANGID,
        }
        #[library("KERNEL32.dll")]
        extern fn EnumResourceLanguagesExA(#[opt] hModule: HMODULE, lpType: PCSTR, lpName: PCSTR, lpEnumFunc: ENUMRESLANGPROCA, #[opt] lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceLanguagesExW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpName: PCWSTR, lpEnumFunc: ENUMRESLANGPROCW, #[opt] lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceNamesA(#[opt] hModule: HMODULE, lpType: PCSTR, lpEnumFunc: ENUMRESNAMEPROCA, lParam: isize) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceNamesExA(#[opt] hModule: HMODULE, lpType: PCSTR, lpEnumFunc: ENUMRESNAMEPROCA, lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceNamesExW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpEnumFunc: ENUMRESNAMEPROCW, lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceNamesW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpEnumFunc: ENUMRESNAMEPROCW, lParam: isize) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceTypesExA(#[opt] hModule: HMODULE, lpEnumFunc: ENUMRESTYPEPROCA, lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn EnumResourceTypesExW(#[opt] hModule: HMODULE, lpEnumFunc: ENUMRESTYPEPROCW, lParam: isize, dwFlags: u32, LangId: LANGID) -> BOOL;
        const FIND_RESOURCE_DIRECTORY_LANGUAGES: u32 = 1024;
        const FIND_RESOURCE_DIRECTORY_NAMES: u32 = 512;
        const FIND_RESOURCE_DIRECTORY_TYPES: u32 = 256;
        #[library("KERNEL32.dll")]
        extern fn FindResourceExW(#[opt] hModule: HMODULE, lpType: PCWSTR, lpName: PCWSTR, wLanguage: u16) -> HRSRC;
        #[library("KERNEL32.dll")]
        extern fn FindResourceW(#[opt] hModule: HMODULE, lpName: PCWSTR, lpType: PCWSTR) -> HRSRC;
        #[library("KERNEL32.dll")]
        extern fn FindStringOrdinal(dwFindStringOrdinalFlags: u32, #[len_param(2)] lpStringSource: PCWSTR, cchSource: i32, #[len_param(4)] lpStringValue: PCWSTR, cchValue: i32, bIgnoreCase: BOOL) -> i32;
        #[library("KERNEL32.dll")]
        extern fn FreeLibrary(hLibModule: HMODULE) -> BOOL;
        #[noreturn]
        #[library("KERNEL32.dll")]
        extern fn FreeLibraryAndExitThread(hLibModule: HMODULE, dwExitCode: u32);
        #[library("KERNEL32.dll")]
        extern fn FreeResource(hResData: HGLOBAL) -> BOOL;
        const GET_MODULE_HANDLE_EX_FLAG_FROM_ADDRESS: u32 = 4;
        const GET_MODULE_HANDLE_EX_FLAG_PIN: u32 = 1;
        const GET_MODULE_HANDLE_EX_FLAG_UNCHANGED_REFCOUNT: u32 = 2;
        #[library("KERNEL32.dll")]
        extern fn GetModuleFileNameA(#[opt] hModule: HMODULE, #[len_param(2)] #[out] lpFilename: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetModuleFileNameW(#[opt] hModule: HMODULE, #[len_param(2)] #[out] lpFilename: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetModuleHandleA(#[opt] lpModuleName: PCSTR) -> HMODULE;
        #[library("KERNEL32.dll")]

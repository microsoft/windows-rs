        #[library("KERNEL32.dll")]
        extern fn GetModuleHandleExW(dwFlags: u32, #[opt] lpModuleName: PCWSTR, phModule: *mut HMODULE) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn GetModuleHandleW(#[opt] lpModuleName: PCWSTR) -> HMODULE;
        #[library("KERNEL32.dll")]
        extern fn GetProcAddress(hModule: HMODULE, lpProcName: PCSTR) -> FARPROC;
        const LOAD_IGNORE_CODE_AUTHZ_LEVEL: u32 = 16;
        const LOAD_LIBRARY_AS_DATAFILE: u32 = 2;
        const LOAD_LIBRARY_AS_DATAFILE_EXCLUSIVE: u32 = 64;
        const LOAD_LIBRARY_AS_IMAGE_RESOURCE: u32 = 32;
        const LOAD_LIBRARY_OS_INTEGRITY_CONTINUITY: u32 = 32768;
        const LOAD_LIBRARY_REQUIRE_SIGNED_TARGET: u32 = 128;
        const LOAD_LIBRARY_SAFE_CURRENT_DIRS: u32 = 8192;
        const LOAD_LIBRARY_SEARCH_APPLICATION_DIR: u32 = 512;
        const LOAD_LIBRARY_SEARCH_DEFAULT_DIRS: u32 = 4096;
        const LOAD_LIBRARY_SEARCH_DLL_LOAD_DIR: u32 = 256;
        const LOAD_LIBRARY_SEARCH_SYSTEM32: u32 = 2048;
        const LOAD_LIBRARY_SEARCH_SYSTEM32_NO_FORWARDER: u32 = 16384;
        const LOAD_LIBRARY_SEARCH_USER_DIRS: u32 = 1024;
        const LOAD_WITH_ALTERED_SEARCH_PATH: u32 = 8;
        #[library("KERNEL32.dll")]
        extern fn LoadLibraryA(lpLibFileName: PCSTR) -> HMODULE;
        #[library("KERNEL32.dll")]
        extern fn LoadLibraryExA(lpLibFileName: PCSTR, #[reserved] hFile: HANDLE, dwFlags: u32) -> HMODULE;
        #[library("KERNEL32.dll")]
        extern fn LoadLibraryExW(lpLibFileName: PCWSTR, #[reserved] hFile: HANDLE, dwFlags: u32) -> HMODULE;
        #[library("KERNEL32.dll")]
        extern fn LoadLibraryW(lpLibFileName: PCWSTR) -> HMODULE;
        #[library("KERNEL32.dll")]
        extern fn LoadResource(#[opt] hModule: HMODULE, hResInfo: HRSRC) -> HGLOBAL;
        #[library("USER32.dll")]
        extern fn LoadStringA(#[opt] hInstance: HINSTANCE, uID: u32, #[len_param(3)] #[out] lpBuffer: PSTR, cchBufferMax: i32) -> i32;
        #[library("USER32.dll")]
        extern fn LoadStringW(#[opt] hInstance: HINSTANCE, uID: u32, #[len_param(3)] #[out] lpBuffer: PWSTR, cchBufferMax: i32) -> i32;
        #[library("KERNEL32.dll")]
        extern fn LockResource(hResData: HGLOBAL) -> *mut void;
        type PCREDIRECTION_DESCRIPTOR = *const REDIRECTION_DESCRIPTOR;
        type PCREDIRECTION_FUNCTION_DESCRIPTOR = *const REDIRECTION_FUNCTION_DESCRIPTOR;
        type PDLL_DIRECTORY_COOKIE = *mut *mut void;
        type PENUMUILANG = *mut ENUMUILANG;
        extern fn PGET_MODULE_HANDLE_EXA(dwFlags: u32, #[opt] lpModuleName: PCSTR, phModule: *mut HMODULE) -> BOOL;
        extern fn PGET_MODULE_HANDLE_EXW(dwFlags: u32, #[opt] lpModuleName: PCWSTR, phModule: *mut HMODULE) -> BOOL;
        type PREDIRECTION_DESCRIPTOR = *mut REDIRECTION_DESCRIPTOR;
        type PREDIRECTION_FUNCTION_DESCRIPTOR = *mut REDIRECTION_FUNCTION_DESCRIPTOR;
        struct REDIRECTION_DESCRIPTOR {
            Version: u32,
            FunctionCount: u32,
            Redirections: PCREDIRECTION_FUNCTION_DESCRIPTOR,
        }
        struct REDIRECTION_FUNCTION_DESCRIPTOR {
            DllName: PCSTR,
            FunctionName: PCSTR,
            RedirectionTarget: *mut void,
        }
        const RESOURCE_ENUM_LN: u32 = 1;
        const RESOURCE_ENUM_MODULE_EXACT: u32 = 16;
        const RESOURCE_ENUM_MUI: u32 = 2;
        const RESOURCE_ENUM_MUI_SYSTEM: u32 = 4;
        const RESOURCE_ENUM_VALIDATE: u32 = 8;
        #[library("KERNEL32.dll")]
        extern fn RemoveDllDirectory(Cookie: DLL_DIRECTORY_COOKIE) -> BOOL;
        const SUPPORT_LANG_NUMBER: u32 = 32;
        #[library("KERNEL32.dll")]
        extern fn SetDefaultDllDirectories(DirectoryFlags: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SizeofResource(#[opt] hModule: HMODULE, hResInfo: HRSRC) -> u32;
    }
}

            Anonymous: #[packed(1)] struct {
                #[bitfield("PortIsUserConnectable", 0, 1)]
                #[bitfield("PortIsDebugCapable", 1, 1)]
                #[bitfield("PortHasMultipleCompanions", 2, 1)]
                #[bitfield("PortConnectorIsTypeC", 3, 1)]
                #[bitfield("ReservedMBZ", 4, 28)]
                _bitfield: u32,
            },
        }
        #[packed(1)]
        union USB_PROTOCOLS {
            ul: u32,
            Anonymous: #[packed(1)] struct {
                #[bitfield("Usb110", 0, 1)]
                #[bitfield("Usb200", 1, 1)]
                #[bitfield("Usb300", 2, 1)]
                #[bitfield("ReservedMBZ", 3, 29)]
                _bitfield: u32,
            },
        }
        const USB_REGISTER_FOR_TRANSPORT_BANDWIDTH_CHANGE: u32 = 2;
        const USB_REGISTER_FOR_TRANSPORT_LATENCY_CHANGE: u32 = 1;
        #[packed(1)]
        struct USB_ROOT_HUB_NAME {
            ActualLength: u32,
            RootHubName: [u16; 1],
        }
        #[packed(1)]
        struct USB_START_TRACKING_FOR_TIME_SYNC_INFORMATION {
            TimeTrackingHandle: HANDLE,
            IsStartupDelayTolerable: BOOLEAN,
        }
        #[packed(1)]
        struct USB_STOP_TRACKING_FOR_TIME_SYNC_INFORMATION {
            TimeTrackingHandle: HANDLE,
        }
        struct USB_TOPOLOGY_ADDRESS {
            PciBusNumber: u32,
            PciDeviceNumber: u32,
            PciFunctionNumber: u32,
            Reserved: u32,
            RootHubPortNumber: u16,
            HubPortNumber: [u16; 5],
            Reserved2: u16,
        }
        #[packed(1)]
        struct USB_TRANSPORT_CHARACTERISTICS {
            Version: u32,
            TransportCharacteristicsFlags: u32,
            CurrentRoundtripLatencyInMilliSeconds: u64,
            MaxPotentialBandwidth: u64,
        }
        const USB_TRANSPORT_CHARACTERISTICS_BANDWIDTH_AVAILABLE: u32 = 2;
        #[packed(1)]
        struct USB_TRANSPORT_CHARACTERISTICS_CHANGE_NOTIFICATION {
            Handle: USB_CHANGE_REGISTRATION_HANDLE,
            UsbTransportCharacteristics: USB_TRANSPORT_CHARACTERISTICS,
        }
        #[packed(1)]
        struct USB_TRANSPORT_CHARACTERISTICS_CHANGE_REGISTRATION {
            ChangeNotificationInputFlags: u32,
            Handle: USB_CHANGE_REGISTRATION_HANDLE,
            UsbTransportCharacteristics: USB_TRANSPORT_CHARACTERISTICS,
        }
        #[packed(1)]
        struct USB_TRANSPORT_CHARACTERISTICS_CHANGE_UNREGISTRATION {
            Handle: USB_CHANGE_REGISTRATION_HANDLE,
        }
        const USB_TRANSPORT_CHARACTERISTICS_LATENCY_AVAILABLE: u32 = 1;
        const USB_TRANSPORT_CHARACTERISTICS_VERSION_1: u32 = 1;
        #[repr(i32)]
        enum USB_WMI_DEVICE_NODE_TYPE {
            UsbDevice = 0,
            HubDevice = 1,
            CompositeDevice = 2,
            UsbController = 3,
        }
        const WMI_USB_DEVICE_NODE_INFORMATION: u32 = 2;
        const WMI_USB_DRIVER_INFORMATION: u32 = 0;
        const WMI_USB_DRIVER_NOTIFICATION: u32 = 1;
        const WMI_USB_HUB_NODE_INFORMATION: u32 = 4;
        const WMI_USB_PERFORMANCE_INFORMATION: u32 = 1;
        const WMI_USB_POWER_DEVICE_ENABLE: u32 = 2;
    }
}

            fn GetWriterMetadata(&self, iWriter: u32, pidInstance: *mut VSS_ID, ppMetadata: *mut IVssExamineWriterMetadata) -> HRESULT;
            fn FreeWriterMetadata(&self) -> HRESULT;
            fn AddComponent(&self, instanceId: VSS_ID, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR) -> HRESULT;
            fn PrepareForBackup(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn AbortBackup(&self) -> HRESULT;
            fn GatherWriterStatus(&self, pAsync: *mut IVssAsync) -> HRESULT;
            fn GetWriterStatusCount(&self, pcWriters: *mut u32) -> HRESULT;
            fn FreeWriterStatus(&self) -> HRESULT;
            fn GetWriterStatus(&self, iWriter: u32, pidInstance: *mut VSS_ID, pidWriter: *mut VSS_ID, pbstrWriter: *mut BSTR, pnStatus: *mut VSS_WRITER_STATE, phResultFailure: *mut HRESULT) -> HRESULT;
            fn SetBackupSucceeded(&self, instanceId: VSS_ID, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, bSucceded: bool) -> HRESULT;
            fn SetBackupOptions(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszBackupOptions: PCWSTR) -> HRESULT;
            fn SetSelectedForRestore(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, bSelectedForRestore: bool) -> HRESULT;
            fn SetRestoreOptions(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszRestoreOptions: PCWSTR) -> HRESULT;
            fn SetAdditionalRestores(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, bAdditionalRestores: bool) -> HRESULT;
            fn SetPreviousBackupStamp(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszPreviousBackupStamp: PCWSTR) -> HRESULT;
            fn SaveAsXML(&self, pbstrXML: *const BSTR) -> HRESULT;
            fn BackupComplete(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn AddAlternativeLocationMapping(&self, writerId: VSS_ID, componentType: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszPath: PCWSTR, wszFilespec: PCWSTR, bRecursive: bool, wszDestination: PCWSTR) -> HRESULT;
            fn AddRestoreSubcomponent(&self, writerId: VSS_ID, componentType: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszSubComponentLogicalPath: PCWSTR, wszSubComponentName: PCWSTR, bRepair: bool) -> HRESULT;
            fn SetFileRestoreStatus(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, status: VSS_FILE_RESTORE_STATUS) -> HRESULT;
            fn AddNewTarget(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszPath: PCWSTR, wszFileName: PCWSTR, bRecursive: bool, wszAlternatePath: PCWSTR) -> HRESULT;
            fn SetRangesFilePath(&self, writerId: VSS_ID, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, iPartialFile: u32, wszRangesFile: PCWSTR) -> HRESULT;
            fn PreRestore(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn PostRestore(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn SetContext(&self, lContext: i32) -> HRESULT;
            fn StartSnapshotSet(&self, pSnapshotSetId: *mut VSS_ID) -> HRESULT;
            fn AddToSnapshotSet(&self, pwszVolumeName: PCWSTR, ProviderId: VSS_ID, pidSnapshot: *mut VSS_ID) -> HRESULT;
            fn DoSnapshotSet(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn DeleteSnapshots(&self, SourceObjectId: VSS_ID, eSourceObjectType: VSS_OBJECT_TYPE, bForceDelete: BOOL, plDeletedSnapshots: *const i32, pNondeletedSnapshotID: *const VSS_ID) -> HRESULT;
            fn ImportSnapshots(&self, ppAsync: *mut IVssAsync) -> HRESULT;
            fn BreakSnapshotSet(&self, SnapshotSetId: VSS_ID) -> HRESULT;
            fn GetSnapshotProperties(&self, SnapshotId: VSS_ID, pProp: *mut VSS_SNAPSHOT_PROP) -> HRESULT;
            fn Query(&self, QueriedObjectId: VSS_ID, eQueriedObjectType: VSS_OBJECT_TYPE, eReturnedObjectsType: VSS_OBJECT_TYPE, ppEnum: *const IVssEnumObject) -> HRESULT;
            fn IsVolumeSupported(&self, ProviderId: VSS_ID, pwszVolumeName: PCWSTR, pbSupportedByThisProvider: *const BOOL) -> HRESULT;
            fn DisableWriterClasses(&self, rgWriterClassId: *const VSS_ID, cClassId: u32) -> HRESULT;
            fn EnableWriterClasses(&self, rgWriterClassId: *const VSS_ID, cClassId: u32) -> HRESULT;
            fn DisableWriterInstances(&self, rgWriterInstanceId: *const VSS_ID, cInstanceId: u32) -> HRESULT;
            fn ExposeSnapshot(&self, SnapshotId: VSS_ID, wszPathFromRoot: PCWSTR, lAttributes: i32, wszExpose: PCWSTR, pwszExposed: *mut VSS_PWSZ) -> HRESULT;
            fn RevertToSnapshot(&self, SnapshotId: VSS_ID, bForceDismount: BOOL) -> HRESULT;
            fn QueryRevertStatus(&self, pwszVolume: PCWSTR, ppAsync: *mut IVssAsync) -> HRESULT;
        }

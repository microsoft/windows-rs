        extern fn RemoveLogContainerSet(hLog: HANDLE, cContainer: u16, #[len_param(1)] rgwszContainerPath: *const PWSTR, fForce: BOOL, #[in] #[out] #[opt] pReserved: *mut void) -> BOOL;
        #[library("clfsw32.dll")]
        extern fn ReserveAndAppendLog(pvMarshal: *mut void, rgWriteEntries: *mut CLFS_WRITE_ENTRY, cWriteEntries: u32, plsnUndoNext: *mut CLFS_LSN, plsnPrevious: *mut CLFS_LSN, cReserveRecords: u32, rgcbReservation: [i64; 0], fFlags: u32, plsn: *mut CLFS_LSN, pOverlapped: *mut OVERLAPPED) -> BOOL;
        #[library("clfsw32.dll")]
        extern fn ReserveAndAppendLogAligned(pvMarshal: *mut void, rgWriteEntries: *mut CLFS_WRITE_ENTRY, cWriteEntries: u32, cbEntryAlignment: u32, plsnUndoNext: *mut CLFS_LSN, plsnPrevious: *mut CLFS_LSN, cReserveRecords: u32, rgcbReservation: [i64; 0], fFlags: u32, plsn: *mut CLFS_LSN, pOverlapped: *mut OVERLAPPED) -> BOOL;
        #[library("clfsw32.dll")]

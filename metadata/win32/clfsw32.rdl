#[win32]
mod Windows {
    mod Win32 {
        #[library("clfsw32.dll")]
        extern fn AddLogContainer(hLog: HANDLE, #[opt] pcbContainer: *const u64, pwszContainerPath: PCWSTR, #[in] #[out] #[opt] pReserved: *mut void) -> BOOL;

        extern fn WriteLogRestartArea(pvMarshal: *mut void, pvRestartBuffer: *mut void, cbRestartBuffer: u32, plsnBase: *mut CLFS_LSN, fFlags: u32, pcbWritten: *mut u32, plsnNext: *mut CLFS_LSN, pOverlapped: *mut OVERLAPPED) -> BOOL;

        #[repr(i32)]
        enum TRUSTEE_TYPE {
            TRUSTEE_IS_UNKNOWN = 0,
            TRUSTEE_IS_USER = 1,
            TRUSTEE_IS_GROUP = 2,
            TRUSTEE_IS_DOMAIN = 3,
            TRUSTEE_IS_ALIAS = 4,

#[win32]
mod Windows {
    mod Win32 {
        #[encoding("ansi")]
        const ACCCTRL_DEFAULT_PROVIDERA: String = "Windows NT Access Provider";
        #[encoding("utf-16")]
        const ACCCTRL_DEFAULT_PROVIDERW: String = "Windows NT Access Provider";
        #[repr(i32)]
        enum ACCESS_MODE {
            NOT_USED_ACCESS = 0,
            GRANT_ACCESS = 1,
            SET_ACCESS = 2,
            DENY_ACCESS = 3,
            REVOKE_ACCESS = 4,
            SET_AUDIT_SUCCESS = 5,
            SET_AUDIT_FAILURE = 6,
        }
        type ACCESS_RIGHTS = u32;
        type ACTRL_ACCESS = ACTRL_ACCESSA;
        struct ACTRL_ACCESSA {
            cEntries: u32,
            pPropertyAccessList: PACTRL_PROPERTY_ENTRYA,
        }
        struct ACTRL_ACCESSW {
            cEntries: u32,
            pPropertyAccessList: PACTRL_PROPERTY_ENTRYW,
        }
        const ACTRL_ACCESS_ALLOWED: u32 = 1;
        const ACTRL_ACCESS_DENIED: u32 = 2;
        type ACTRL_ACCESS_ENTRY = ACTRL_ACCESS_ENTRYA;
        struct ACTRL_ACCESS_ENTRYA {
            Trustee: TRUSTEE_A,
            fAccessFlags: u32,
            Access: ACCESS_RIGHTS,
            ProvSpecificAccess: ACCESS_RIGHTS,
            Inheritance: INHERIT_FLAGS,
            lpInheritProperty: PSTR,
        }
        struct ACTRL_ACCESS_ENTRYW {
            Trustee: TRUSTEE_W,
            fAccessFlags: u32,
            Access: ACCESS_RIGHTS,
            ProvSpecificAccess: ACCESS_RIGHTS,
            Inheritance: INHERIT_FLAGS,
            lpInheritProperty: PWSTR,
        }
        type ACTRL_ACCESS_ENTRY_LIST = ACTRL_ACCESS_ENTRY_LISTA;
        struct ACTRL_ACCESS_ENTRY_LISTA {
            cEntries: u32,
            pAccessList: *mut ACTRL_ACCESS_ENTRYA,
        }
        struct ACTRL_ACCESS_ENTRY_LISTW {
            cEntries: u32,
            pAccessList: *mut ACTRL_ACCESS_ENTRYW,
        }
        type ACTRL_ACCESS_INFO = ACTRL_ACCESS_INFOA;
        struct ACTRL_ACCESS_INFOA {
            fAccessPermission: u32,
            lpAccessPermissionName: PSTR,
        }
        struct ACTRL_ACCESS_INFOW {
            fAccessPermission: u32,
            lpAccessPermissionName: PWSTR,
        }
        const ACTRL_ACCESS_NO_OPTIONS: u32 = 0;
        const ACTRL_ACCESS_PROTECTED: u32 = 1;
        const ACTRL_ACCESS_SUPPORTS_OBJECT_ENTRIES: u32 = 1;
        type ACTRL_AUDIT = ACTRL_AUDITA;
        type ACTRL_AUDITA = ACTRL_ACCESSA;
        type ACTRL_AUDITW = ACTRL_ACCESSW;
        const ACTRL_AUDIT_FAILURE: u32 = 8;
        const ACTRL_AUDIT_SUCCESS: u32 = 4;
        const ACTRL_CHANGE_ACCESS: u32 = 536870912;
        const ACTRL_CHANGE_OWNER: u32 = 1073741824;
        type ACTRL_CONTROL_INFO = ACTRL_CONTROL_INFOA;
        struct ACTRL_CONTROL_INFOA {
            lpControlId: PSTR,

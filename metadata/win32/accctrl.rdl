        const ACTRL_KERNEL_VM_READ: u32 = 8;
        const ACTRL_KERNEL_VM_WRITE: u32 = 16;
        struct ACTRL_OVERLAPPED {
            Anonymous: union {
                Provider: *mut void,
                Reserved1: u32,
            },
            Reserved2: u32,
            hEvent: HANDLE,
        }
        const ACTRL_PERM_1: u32 = 1;
        const ACTRL_PERM_10: u32 = 512;
        const ACTRL_PERM_11: u32 = 1024;
        const ACTRL_PERM_12: u32 = 2048;
        const ACTRL_PERM_13: u32 = 4096;
        const ACTRL_PERM_14: u32 = 8192;
        const ACTRL_PERM_15: u32 = 16384;
        const ACTRL_PERM_16: u32 = 32768;
        const ACTRL_PERM_17: u32 = 65536;
        const ACTRL_PERM_18: u32 = 131072;
        const ACTRL_PERM_19: u32 = 262144;
        const ACTRL_PERM_2: u32 = 2;
        const ACTRL_PERM_20: u32 = 524288;
        const ACTRL_PERM_3: u32 = 4;
        const ACTRL_PERM_4: u32 = 8;
        const ACTRL_PERM_5: u32 = 16;
        const ACTRL_PERM_6: u32 = 32;
        const ACTRL_PERM_7: u32 = 64;
        const ACTRL_PERM_8: u32 = 128;
        const ACTRL_PERM_9: u32 = 256;
        const ACTRL_PRINT_JADMIN: u32 = 16;
        const ACTRL_PRINT_PADMIN: u32 = 4;
        const ACTRL_PRINT_PUSE: u32 = 8;
        const ACTRL_PRINT_SADMIN: u32 = 1;
        const ACTRL_PRINT_SLIST: u32 = 2;
        type ACTRL_PROPERTY_ENTRY = ACTRL_PROPERTY_ENTRYA;
        struct ACTRL_PROPERTY_ENTRYA {
            lpProperty: PSTR,
            pAccessEntryList: PACTRL_ACCESS_ENTRY_LISTA,
            fListFlags: u32,
        }
        struct ACTRL_PROPERTY_ENTRYW {
            lpProperty: PWSTR,
            pAccessEntryList: PACTRL_ACCESS_ENTRY_LISTW,
            fListFlags: u32,
        }
        const ACTRL_READ_CONTROL: u32 = 268435456;
        const ACTRL_REG_CREATE_CHILD: u32 = 4;
        const ACTRL_REG_LINK: u32 = 32;
        const ACTRL_REG_LIST: u32 = 8;
        const ACTRL_REG_NOTIFY: u32 = 16;
        const ACTRL_REG_QUERY: u32 = 1;

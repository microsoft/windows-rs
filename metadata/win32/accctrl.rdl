        const ACTRL_FILE_READ_PROP: u32 = 8;
        const ACTRL_FILE_WRITE: u32 = 2;
        const ACTRL_FILE_WRITE_ATTRIB: u32 = 256;
        const ACTRL_FILE_WRITE_PROP: u32 = 16;
        const ACTRL_KERNEL_ALERT: u32 = 1024;
        const ACTRL_KERNEL_CONTROL: u32 = 512;
        const ACTRL_KERNEL_DIMPERSONATE: u32 = 32768;
        const ACTRL_KERNEL_DUP_HANDLE: u32 = 32;
        const ACTRL_KERNEL_GET_CONTEXT: u32 = 2048;

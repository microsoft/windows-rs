#[win32]
mod Windows {
    mod Win32 {
        #[repr(i32)]
        enum DECODING_SOURCE {
            DecodingSourceXMLFile = 0,
            DecodingSourceWbem = 1,
            DecodingSourceWPP = 2,
            DecodingSourceTlg = 3,
            DecodingSourceMax = 4,
        }
        #[repr(i32)]
        enum EVENT_FIELD_TYPE {
            EventKeywordInformation = 0,
            EventLevelInformation = 1,
            EventChannelInformation = 2,
            EventTaskInformation = 3,
            EventOpcodeInformation = 4,
            EventInformationMax = 5,
        }
        struct EVENT_MAP_ENTRY {
            OutputOffset: u32,
            Anonymous: union {
                Value: u32,
                InputOffset: u32,
            },
        }
        struct EVENT_MAP_INFO {
            NameOffset: u32,
            Flag: MAP_FLAGS,
            EntryCount: u32,
            Anonymous: union {
                MapEntryValueType: MAP_VALUETYPE,
                FormatStringOffset: u32,
            },
            MapEntryArray: [EVENT_MAP_ENTRY; 1],
        }
        struct EVENT_PROPERTY_INFO {
            Flags: PROPERTY_FLAGS,
            NameOffset: u32,
            Anonymous: union {
                nonStructType: EVENT_PROPERTY_INFO_0_0,
                structType: EVENT_PROPERTY_INFO_0_1,
                customSchemaType: EVENT_PROPERTY_INFO_0_2,
            },
            Anonymous2: union {
                count: u16,
                countPropertyIndex: u16,
            },
            Anonymous3: union {
                length: u16,
                lengthPropertyIndex: u16,
            },
            Anonymous4: union {
                Reserved: u32,
                Anonymous: struct {
                    _bitfield: u32 {
                        Tags: 28,
                    },
                },
            },
        }
        struct EVENT_PROPERTY_INFO_0_0 {
            InType: u16,
            OutType: u16,
            MapNameOffset: u32,
        }
        struct EVENT_PROPERTY_INFO_0_1 {
            StructStartIndex: u16,
            NumOfStructMembers: u16,
            padding: u32,
        }
        struct EVENT_PROPERTY_INFO_0_2 {
            InType: u16,
            OutType: u16,
            CustomSchemaOffset: u32,
        }
        #[repr(i32)]
        enum MAP_FLAGS {
            EVENTMAP_INFO_FLAG_MANIFEST_VALUEMAP = 1,

        #[repr(i32)]
        enum MAP_VALUETYPE {
            EVENTMAP_ENTRY_VALUETYPE_ULONG = 0,
            EVENTMAP_ENTRY_VALUETYPE_STRING = 1,
        }
        const MAX_PAYLOAD_PREDICATES: u32 = 8;
        struct PAYLOAD_FILTER_PREDICATE {

            PAYLOADFIELD_DOESNTCONTAIN = 21,
            PAYLOADFIELD_IS = 30,
            PAYLOADFIELD_ISNOT = 31,
            PAYLOADFIELD_INVALID = 32,
        }
        type PEVENT_MAP_ENTRY = *mut EVENT_MAP_ENTRY;
        type PEVENT_MAP_INFO = *mut EVENT_MAP_INFO;
        type PEVENT_PROPERTY_INFO = *mut EVENT_PROPERTY_INFO;
        type PPAYLOAD_FILTER_PREDICATE = *mut PAYLOAD_FILTER_PREDICATE;
        type PPROPERTY_DATA_DESCRIPTOR = *mut PROPERTY_DATA_DESCRIPTOR;
        type PPROVIDER_ENUMERATION_INFO = *mut PROVIDER_ENUMERATION_INFO;
        type PPROVIDER_EVENT_INFO = *mut PROVIDER_EVENT_INFO;
        type PPROVIDER_FIELD_INFO = *mut PROVIDER_FIELD_INFO;
        type PPROVIDER_FIELD_INFOARRAY = *mut PROVIDER_FIELD_INFOARRAY;
        type PPROVIDER_FILTER_INFO = *mut PROVIDER_FILTER_INFO;
        struct PROPERTY_DATA_DESCRIPTOR {
            PropertyName: u64,
            ArrayIndex: u32,
            Reserved: u32,
        }
        #[repr(i32)]
        enum PROPERTY_FLAGS {
            PropertyStruct = 1,
            PropertyParamLength = 2,
            PropertyParamCount = 4,
            PropertyWBEMXmlFragment = 8,
            PropertyParamFixedLength = 16,
            PropertyParamFixedCount = 32,
            PropertyHasTags = 64,
            PropertyHasCustomSchema = 128,
        }
        struct PROVIDER_ENUMERATION_INFO {
            NumberOfProviders: u32,

        extern fn TdhFormatProperty(EventInfo: *const TRACE_EVENT_INFO, #[opt] MapInfo: *const EVENT_MAP_INFO, PointerSize: u32, PropertyInType: u16, PropertyOutType: u16, PropertyLength: u16, UserDataLength: u16, #[size_param(6)] UserData: *const u8, #[in] #[out] BufferSize: *mut u32, #[size_param(8)] #[opt] Buffer: *mut u16, UserDataConsumed: *mut u16) -> TDHSTATUS;

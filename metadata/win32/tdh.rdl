        }
        struct PROVIDER_FIELD_INFO {
            NameOffset: u32,
            DescriptionOffset: u32,
            Value: u64,
        }
        struct PROVIDER_FIELD_INFOARRAY {
            NumberOfElements: u32,
            FieldType: EVENT_FIELD_TYPE,
            FieldInfoArray: [PROVIDER_FIELD_INFO; 1],
        }
        struct PROVIDER_FILTER_INFO {
            Id: u8,
            Version: u8,
            MessageOffset: u32,
            Reserved: u32,
            PropertyCount: u32,
            EventPropertyInfoArray: [EVENT_PROPERTY_INFO; 1],
        }
        type PTDH_CONTEXT = *mut TDH_CONTEXT;
        type PTDH_HANDLE = *mut HANDLE;
        type PTRACE_EVENT_INFO = *mut TRACE_EVENT_INFO;
        type PTRACE_PROVIDER_INFO = *mut TRACE_PROVIDER_INFO;
        type TDHSTATUS = u32;
        struct TDH_CONTEXT {
            ParameterValue: u64,
            ParameterType: TDH_CONTEXT_TYPE,
            ParameterSize: u32,
        }
        #[repr(i32)]
        enum TDH_CONTEXT_TYPE {
            TDH_CONTEXT_WPP_TMFFILE = 0,
            TDH_CONTEXT_WPP_TMFSEARCHPATH = 1,
            TDH_CONTEXT_WPP_GMT = 2,
            TDH_CONTEXT_POINTERSIZE = 3,
            TDH_CONTEXT_PDB_PATH = 4,
            TDH_CONTEXT_MAXIMUM = 5,
        }
        type TDH_HANDLE = HANDLE;
        const TDH_OUTYTPE_ERRORCODE: u32 = 29;
        #[repr(i32)]
        enum TEMPLATE_FLAGS {
            TEMPLATE_EVENT_DATA = 1,
            TEMPLATE_USER_DATA = 2,
            TEMPLATE_CONTROL_GUID = 4,
        }
        struct TRACE_EVENT_INFO {
            ProviderGuid: GUID,
            EventGuid: GUID,
            EventDescriptor: EVENT_DESCRIPTOR,
            DecodingSource: DECODING_SOURCE,
            ProviderNameOffset: u32,
            LevelNameOffset: u32,
            ChannelNameOffset: u32,
            KeywordsNameOffset: u32,
            TaskNameOffset: u32,
            OpcodeNameOffset: u32,
            EventMessageOffset: u32,
            ProviderMessageOffset: u32,
            BinaryXMLOffset: u32,
            BinaryXMLSize: u32,
            Anonymous: union {
                EventNameOffset: u32,
                ActivityIDNameOffset: u32,
            },
            Anonymous2: union {
                EventAttributesOffset: u32,
                RelatedActivityIDNameOffset: u32,
            },
            PropertyCount: u32,
            TopLevelPropertyCount: u32,
            Anonymous3: union {
                Flags: TEMPLATE_FLAGS,
                Anonymous: struct {
                    _bitfield: u32 {
                        Reserved: 4,
                        Tags: 28,
                    },
                },
            },
            EventPropertyInfoArray: [EVENT_PROPERTY_INFO; 1],
        }
        struct TRACE_PROVIDER_INFO {
            ProviderGuid: GUID,
            SchemaSource: u32,
            ProviderNameOffset: u32,
        }

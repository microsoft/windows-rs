        extern fn TdhAggregatePayloadFilters(PayloadFilterCount: u32, #[len_param(0)] PayloadFilterPtrs: *const *const void, #[len_param(0)] #[opt] EventMatchALLFlags: *const BOOLEAN, EventFilterDescriptor: *mut EVENT_FILTER_DESCRIPTOR) -> TDHSTATUS;

        #[library("ADVAPI32.dll")]
        extern fn RegSetValueW(hKey: HKEY, #[opt] lpSubKey: PCWSTR, dwType: u32, #[size_param(4)] #[opt] lpData: PCWSTR, cbData: u32) -> WIN32_ERROR;
        #[library("ADVAPI32.dll")]
        extern fn RegUnLoadKeyA(hKey: HKEY, #[opt] lpSubKey: PCSTR) -> WIN32_ERROR;
        #[library("ADVAPI32.dll")]
        extern fn RegUnLoadKeyW(hKey: HKEY, #[opt] lpSubKey: PCWSTR) -> WIN32_ERROR;

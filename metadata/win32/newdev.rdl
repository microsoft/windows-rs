#[win32]
mod Windows {
    mod Win32 {
        const DIIDFLAG_BITS: u32 = 15;
        const DIIDFLAG_INSTALLCOPYINFDRIVERS: u32 = 8;
        const DIIDFLAG_INSTALLNULLDRIVER: u32 = 4;
        const DIIDFLAG_NOFINISHINSTALLUI: u32 = 2;
        const DIIDFLAG_SHOWSEARCHUI: u32 = 1;
        const DIIRFLAG_BITS: u32 = 106;
        const DIIRFLAG_FORCE_INF: u32 = 2;
        const DIIRFLAG_HOTPATCH: u32 = 8;
        const DIIRFLAG_HW_USING_THE_INF: u32 = 4;
        const DIIRFLAG_INF_ALREADY_COPIED: u32 = 1;
        const DIIRFLAG_INSTALL_AS_SET: u32 = 64;
        const DIIRFLAG_NOBACKUP: u32 = 16;
        const DIIRFLAG_PRE_CONFIGURE_INF: u32 = 32;
        const DIIRFLAG_SYSTEM_BITS: u32 = 127;
        const DIURFLAG_NO_REMOVE_INF: u32 = 1;
        const DIURFLAG_RESERVED: u32 = 2;
        const DIURFLAG_VALID: u32 = 3;
        #[library("newdev.dll")]
        extern fn DiInstallDevice(#[opt] hwndParent: HWND, DeviceInfoSet: HDEVINFO, DeviceInfoData: *const SP_DEVINFO_DATA, #[opt] DriverInfoData: PSP_DRVINFO_DATA, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiInstallDriverA(#[opt] hwndParent: HWND, InfPath: PCSTR, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiInstallDriverW(#[opt] hwndParent: HWND, InfPath: PCWSTR, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiRollbackDriver(DeviceInfoSet: HDEVINFO, DeviceInfoData: *const SP_DEVINFO_DATA, #[opt] hwndParent: HWND, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiShowUpdateDevice(#[opt] hwndParent: HWND, DeviceInfoSet: HDEVINFO, DeviceInfoData: *const SP_DEVINFO_DATA, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiShowUpdateDriver(hwndParent: HWND, FilePath: PCWSTR, Flags: u32, NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiUninstallDevice(hwndParent: HWND, DeviceInfoSet: HDEVINFO, DeviceInfoData: *const SP_DEVINFO_DATA, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiUninstallDriverA(#[opt] hwndParent: HWND, InfPath: PCSTR, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn DiUninstallDriverW(#[opt] hwndParent: HWND, InfPath: PCWSTR, Flags: u32, #[opt] NeedReboot: *mut BOOL) -> BOOL;
        const INSTALLFLAG_BITS: u32 = 7;
        const INSTALLFLAG_FORCE: u32 = 1;
        const INSTALLFLAG_NONINTERACTIVE: u32 = 4;
        const INSTALLFLAG_READONLY: u32 = 2;
        const ROLLBACK_BITS: u32 = 1;
        const ROLLBACK_FLAG_NO_UI: u32 = 1;
        #[library("newdev.dll")]
        extern fn UpdateDriverForPlugAndPlayDevicesA(#[opt] hwndParent: HWND, HardwareId: PCSTR, FullInfPath: PCSTR, InstallFlags: u32, #[opt] bRebootRequired: *mut BOOL) -> BOOL;
        #[library("newdev.dll")]
        extern fn UpdateDriverForPlugAndPlayDevicesW(#[opt] hwndParent: HWND, HardwareId: PCWSTR, FullInfPath: PCWSTR, InstallFlags: u32, #[opt] bRebootRequired: *mut BOOL) -> BOOL;
    }
}

#[win32]
mod Windows {
    mod Win32 {
        struct MIB_UDP6ROW {
            dwLocalAddr: IN6_ADDR,
            dwLocalScopeId: u32,
            dwLocalPort: u32,
        }
        struct MIB_UDP6ROW2 {
            ucLocalAddr: [u8; 16],
            dwLocalScopeId: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
            liCreateTimestamp: LARGE_INTEGER,
            Anonymous: union {
                Anonymous: struct {
                    #[bitfield("SpecificPortBind", 0, 1)]
                    _bitfield: i32,
                },
                dwFlags: i32,
            },
            OwningModuleInfo: [u64; 16],
            ucRemoteAddr: [u8; 16],
            dwRemoteScopeId: u32,
            dwRemotePort: u32,
        }
        struct MIB_UDP6ROW_OWNER_MODULE {
            ucLocalAddr: [u8; 16],
            dwLocalScopeId: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
            liCreateTimestamp: LARGE_INTEGER,
            Anonymous: union {
                Anonymous: struct {
                    #[bitfield("SpecificPortBind", 0, 1)]
                    _bitfield: i32,
                },
                dwFlags: i32,
            },
            OwningModuleInfo: [u64; 16],
        }
        struct MIB_UDP6ROW_OWNER_PID {
            ucLocalAddr: [u8; 16],
            dwLocalScopeId: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
        }
        struct MIB_UDP6TABLE {
            dwNumEntries: u32,
            table: [MIB_UDP6ROW; 1],
        }
        struct MIB_UDP6TABLE2 {
            dwNumEntries: u32,
            table: [MIB_UDP6ROW2; 1],
        }
        struct MIB_UDP6TABLE_OWNER_MODULE {
            dwNumEntries: u32,
            table: [MIB_UDP6ROW_OWNER_MODULE; 1],
        }
        struct MIB_UDP6TABLE_OWNER_PID {
            dwNumEntries: u32,
            table: [MIB_UDP6ROW_OWNER_PID; 1],
        }
        struct MIB_UDPROW {
            dwLocalAddr: u32,
            dwLocalPort: u32,
        }
        struct MIB_UDPROW2 {
            dwLocalAddr: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
            liCreateTimestamp: LARGE_INTEGER,
            Anonymous: union {
                Anonymous: struct {
                    #[bitfield("SpecificPortBind", 0, 1)]
                    _bitfield: i32,
                },
                dwFlags: i32,
            },
            OwningModuleInfo: [u64; 16],
            dwRemoteAddr: u32,
            dwRemotePort: u32,
        }
        struct MIB_UDPROW_OWNER_MODULE {
            dwLocalAddr: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
            liCreateTimestamp: LARGE_INTEGER,
            Anonymous: union {
                Anonymous: struct {
                    #[bitfield("SpecificPortBind", 0, 1)]
                    _bitfield: i32,
                },
                dwFlags: i32,
            },
            OwningModuleInfo: [u64; 16],
        }
        struct MIB_UDPROW_OWNER_PID {
            dwLocalAddr: u32,
            dwLocalPort: u32,
            dwOwningPid: u32,
        }
        struct MIB_UDPSTATS {
            dwInDatagrams: u32,
            dwNoPorts: u32,
            dwInErrors: u32,
            dwOutDatagrams: u32,
            dwNumAddrs: u32,
        }
        struct MIB_UDPSTATS2 {
            dw64InDatagrams: u64,
            dwNoPorts: u32,
            dwInErrors: u32,
            dw64OutDatagrams: u64,
            dwNumAddrs: u32,
        }
        struct MIB_UDPTABLE {
            dwNumEntries: u32,
            table: [MIB_UDPROW; 1],
        }
        struct MIB_UDPTABLE2 {
            dwNumEntries: u32,
            table: [MIB_UDPROW2; 1],
        }
        struct MIB_UDPTABLE_OWNER_MODULE {
            dwNumEntries: u32,
            table: [MIB_UDPROW_OWNER_MODULE; 1],
        }
        struct MIB_UDPTABLE_OWNER_PID {
            dwNumEntries: u32,
            table: [MIB_UDPROW_OWNER_PID; 1],
        }
        type PMIB_UDP6ROW = *mut MIB_UDP6ROW;
        type PMIB_UDP6ROW2 = *mut MIB_UDP6ROW2;
        type PMIB_UDP6ROW_OWNER_MODULE = *mut MIB_UDP6ROW_OWNER_MODULE;
        type PMIB_UDP6ROW_OWNER_PID = *mut MIB_UDP6ROW_OWNER_PID;
        type PMIB_UDP6TABLE = *mut MIB_UDP6TABLE;
        type PMIB_UDP6TABLE2 = *mut MIB_UDP6TABLE2;
        type PMIB_UDP6TABLE_OWNER_MODULE = *mut MIB_UDP6TABLE_OWNER_MODULE;
        type PMIB_UDP6TABLE_OWNER_PID = *mut MIB_UDP6TABLE_OWNER_PID;
        type PMIB_UDPROW = *mut MIB_UDPROW;
        type PMIB_UDPROW2 = *mut MIB_UDPROW2;
        type PMIB_UDPROW_OWNER_MODULE = *mut MIB_UDPROW_OWNER_MODULE;
        type PMIB_UDPROW_OWNER_PID = *mut MIB_UDPROW_OWNER_PID;
        type PMIB_UDPSTATS = *mut MIB_UDPSTATS;
        type PMIB_UDPSTATS2 = *mut MIB_UDPSTATS2;
        type PMIB_UDPTABLE = *mut MIB_UDPTABLE;
        type PMIB_UDPTABLE2 = *mut MIB_UDPTABLE2;
        type PMIB_UDPTABLE_OWNER_MODULE = *mut MIB_UDPTABLE_OWNER_MODULE;
        type PMIB_UDPTABLE_OWNER_PID = *mut MIB_UDPTABLE_OWNER_PID;
    }
}

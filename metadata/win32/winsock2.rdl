        #[library("WS2_32.dll")]
        extern fn send(s: SOCKET, #[size_param(2)] buf: *const i8, len: i32, flags: i32) -> i32;
        #[library("WS2_32.dll")]
        extern fn sendto(s: SOCKET, #[size_param(2)] buf: *const i8, len: i32, flags: i32, #[size_param(5)] to: *const SOCKADDR, tolen: i32) -> i32;
        #[arch(X64 | Arm64)]
        struct servent {
            s_name: *mut i8,
            s_aliases: *mut *mut i8,
            s_proto: *mut i8,
            s_port: i16,
        }
        #[arch(X86)]
        struct servent {
            s_name: *mut i8,
            s_aliases: *mut *mut i8,
            s_port: i16,
            s_proto: *mut i8,
        }
        #[library("WS2_32.dll")]
        extern fn setsockopt(s: SOCKET, level: i32, optname: i32, #[size_param(4)] #[opt] optval: *const i8, optlen: i32) -> i32;
        #[library("WS2_32.dll")]
        extern fn shutdown(s: SOCKET, how: i32) -> i32;
        #[library("WS2_32.dll")]
        extern fn socket(af: i32, r#type: i32, protocol: i32) -> SOCKET;
        struct sockproto {
            sp_family: u_short,
            sp_protocol: u_short,
        }
        struct timeval {
            tv_sec: i32,
            tv_usec: i32,
        }
        type u_char = u8;
        type u_int = u32;
        type u_int64 = u64;
        type u_long = u32;
        type u_short = u16;
    }
}

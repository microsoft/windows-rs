        const WMPCOREEVENT_PLAYLIST_BASE: u32 = 5800;
        const WMPCOREEVENT_SEEK_BASE: u32 = 5200;
        const WMPCOREEVENT_WARNING_BASE: u32 = 5600;
        const WMPOCXEVENT_BASE: u32 = 6500;
    }
}

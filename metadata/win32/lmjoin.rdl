#[win32]
mod Windows {
    mod Win32 {
        struct DSREG_JOIN_INFO {
            joinType: DSREG_JOIN_TYPE,
            pJoinCertificate: PCCERT_CONTEXT,
            pszDeviceId: PWSTR,
            pszIdpDomain: PWSTR,
            pszTenantId: PWSTR,
            pszJoinUserEmail: PWSTR,
            pszTenantDisplayName: PWSTR,
            pszMdmEnrollmentUrl: PWSTR,
            pszMdmTermsOfUseUrl: PWSTR,
            pszMdmComplianceUrl: PWSTR,
            pszUserSettingSyncUrl: PWSTR,
            pUserInfo: *mut DSREG_USER_INFO,
        }
        #[repr(i32)]
        enum DSREG_JOIN_TYPE {
            DSREG_UNKNOWN_JOIN = 0,
            DSREG_DEVICE_JOIN = 1,
            DSREG_WORKPLACE_JOIN = 2,
        }
        struct DSREG_USER_INFO {
            pszUserEmail: PWSTR,
            pszUserKeyId: PWSTR,
            pszUserKeyName: PWSTR,
        }
        const NETSETUP_ACCT_CREATE: u32 = 2;
        const NETSETUP_ACCT_DELETE: u32 = 4;
        const NETSETUP_ALT_SAMACCOUNTNAME: u32 = 131072;
        const NETSETUP_AMBIGUOUS_DC: u32 = 4096;
        const NETSETUP_DEFER_SPN_SET: u32 = 256;
        const NETSETUP_DNS_NAME_CHANGES_ONLY: u32 = 4096;
        const NETSETUP_DOMAIN_JOIN_IF_JOINED: u32 = 32;
        const NETSETUP_DONT_CONTROL_SERVICES: u32 = 16384;
        const NETSETUP_FORCE_SPN_SET: u32 = 65536;
        const NETSETUP_IGNORE_UNSUPPORTED_FLAGS: u32 = 268435456;
        const NETSETUP_INSTALL_INVOCATION: u32 = 262144;
        const NETSETUP_JOIN_DC_ACCOUNT: u32 = 512;
        const NETSETUP_JOIN_DOMAIN: u32 = 1;
        const NETSETUP_JOIN_READONLY: u32 = 2048;
        #[repr(i32)]
        enum NETSETUP_JOIN_STATUS {
            NetSetupUnknownStatus = 0,
            NetSetupUnjoined = 1,
            NetSetupWorkgroupName = 2,
            NetSetupDomainName = 3,
        }
        const NETSETUP_JOIN_UNSECURE: u32 = 64;
        const NETSETUP_JOIN_WITH_NEW_NAME: u32 = 1024;
        const NETSETUP_MACHINE_PWD_PASSED: u32 = 128;
        #[repr(i32)]
        enum NETSETUP_NAME_TYPE {
            NetSetupUnknown = 0,
            NetSetupMachine = 1,
            NetSetupWorkgroup = 2,
            NetSetupDomain = 3,
            NetSetupNonExistentDomain = 4,
            NetSetupDnsMachine = 5,
        }
        const NETSETUP_NO_ACCT_REUSE: u32 = 131072;
        const NETSETUP_NO_NETLOGON_CACHE: u32 = 8192;
        const NETSETUP_PROCESS_OFFLINE_FLAGS: u32 = 17569;
        struct NETSETUP_PROVISIONING_PARAMS {
            dwVersion: u32,
            lpDomain: PCWSTR,
            lpHostName: PCWSTR,
            lpMachineAccountOU: PCWSTR,
            lpDcName: PCWSTR,
            dwProvisionOptions: u32,
            aCertTemplateNames: *mut PCWSTR,
            cCertTemplateNames: u32,
            aMachinePolicyNames: *mut PCWSTR,
            cMachinePolicyNames: u32,
            aMachinePolicyPaths: *mut PCWSTR,
            cMachinePolicyPaths: u32,
            lpNetbiosName: PWSTR,
            lpSiteName: PWSTR,
            lpPrimaryDNSDomain: PWSTR,
        }
        const NETSETUP_PROVISIONING_PARAMS_CURRENT_VERSION: u32 = 2;
        const NETSETUP_PROVISIONING_PARAMS_WIN8_VERSION: u32 = 1;
        const NETSETUP_PROVISION_CHECK_PWD_ONLY: u32 = 2147483648;
        const NETSETUP_PROVISION_DOWNLEVEL_PRIV_SUPPORT: u32 = 1;
        const NETSETUP_PROVISION_ONLINE_CALLER: u32 = 1073741824;
        const NETSETUP_PROVISION_PERSISTENTSITE: u32 = 32;
        const NETSETUP_PROVISION_REUSE_ACCOUNT: u32 = 2;
        const NETSETUP_PROVISION_ROOT_CA_CERTS: u32 = 16;
        const NETSETUP_PROVISION_SKIP_ACCOUNT_SEARCH: u32 = 8;
        const NETSETUP_PROVISION_USE_DEFAULT_PASSWORD: u32 = 4;
        const NETSETUP_SET_MACHINE_NAME: u32 = 32768;
        const NETSETUP_VALID_UNJOIN_FLAGS: u32 = 268435972;
        const NETSETUP_WIN9X_UPGRADE: u32 = 16;
        #[repr(i32)]
        enum NET_COMPUTER_NAME_TYPE {
            NetPrimaryComputerName = 0,
            NetAlternateComputerNames = 1,
            NetAllComputerNames = 2,
            NetComputerNameTypeMax = 3,
        }
        const NET_IGNORE_UNSUPPORTED_FLAGS: u32 = 1;
        #[library("NETAPI32.dll")]
        extern fn NetAddAlternateComputerName(#[opt] Server: PCWSTR, AlternateName: PCWSTR, #[opt] DomainAccount: PCWSTR, #[opt] DomainAccountPassword: PCWSTR, Reserved: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetCreateProvisioningPackage(pProvisioningParams: *const NETSETUP_PROVISIONING_PARAMS, ppPackageBinData: *mut PBYTE, #[opt] pdwPackageBinDataSize: *mut u32, ppPackageTextData: *mut PWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetEnumerateComputerNames(#[opt] Server: PCWSTR, NameType: NET_COMPUTER_NAME_TYPE, Reserved: u32, EntryCount: *mut u32, ComputerNames: *mut *mut PWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetFreeAadJoinInformation(#[opt] pJoinInfo: *const DSREG_JOIN_INFO);
        #[library("NETAPI32.dll")]
        extern fn NetGetAadJoinInformation(#[opt] pcszTenantId: PCWSTR, ppJoinInfo: *mut PDSREG_JOIN_INFO) -> HRESULT;
        #[library("NETAPI32.dll")]
        extern fn NetGetJoinInformation(#[opt] lpServer: PCWSTR, lpNameBuffer: *mut PWSTR, BufferType: *mut NETSETUP_JOIN_STATUS) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetGetJoinableOUs(lpServer: PCWSTR, lpDomain: PCWSTR, #[opt] lpAccount: PCWSTR, #[opt] lpPassword: PCWSTR, OUCount: *mut u32, OUs: *mut *mut PWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetJoinDomain(#[opt] lpServer: PCWSTR, lpDomain: PCWSTR, #[opt] lpMachineAccountOU: PCWSTR, #[opt] lpAccount: PCWSTR, #[opt] lpPassword: PCWSTR, fJoinOptions: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetProvisionComputerAccount(lpDomain: PCWSTR, lpMachineName: PCWSTR, #[opt] lpMachineAccountOU: PCWSTR, #[opt] lpDcName: PCWSTR, dwOptions: u32, pProvisionBinData: *mut PBYTE, #[opt] pdwProvisionBinDataSize: *mut u32, pProvisionTextData: *mut PWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetRemoveAlternateComputerName(#[opt] Server: PCWSTR, AlternateName: PCWSTR, #[opt] DomainAccount: PCWSTR, #[opt] DomainAccountPassword: PCWSTR, Reserved: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetRenameMachineInDomain(#[opt] lpServer: PCWSTR, #[opt] lpNewMachineName: PCWSTR, #[opt] lpAccount: PCWSTR, #[opt] lpPassword: PCWSTR, fRenameOptions: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetRequestOfflineDomainJoin(#[size_param(1)] pProvisionBinData: *const u8, cbProvisionBinDataSize: u32, dwOptions: u32, lpWindowsPath: PCWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetRequestProvisioningPackageInstall(#[size_param(1)] pPackageBinData: *const u8, dwPackageBinDataSize: u32, dwProvisionOptions: u32, lpWindowsPath: PCWSTR, #[reserved] pvReserved: *const void) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetSetPrimaryComputerName(#[opt] Server: PCWSTR, PrimaryName: PCWSTR, #[opt] DomainAccount: PCWSTR, #[opt] DomainAccountPassword: PCWSTR, Reserved: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetUnjoinDomain(#[opt] lpServer: PCWSTR, #[opt] lpAccount: PCWSTR, #[opt] lpPassword: PCWSTR, fUnjoinOptions: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetValidateName(#[opt] lpServer: PCWSTR, lpName: PCWSTR, #[opt] lpAccount: PCWSTR, #[opt] lpPassword: PCWSTR, NameType: NETSETUP_NAME_TYPE) -> u32;
        type PDSREG_JOIN_INFO = *mut DSREG_JOIN_INFO;
        type PDSREG_JOIN_TYPE = *mut DSREG_JOIN_TYPE;
        type PDSREG_USER_INFO = *mut DSREG_USER_INFO;
        type PNETSETUP_JOIN_STATUS = *mut NETSETUP_JOIN_STATUS;
        type PNETSETUP_NAME_TYPE = *mut NETSETUP_NAME_TYPE;
        type PNETSETUP_PROVISIONING_PARAMS = *mut NETSETUP_PROVISIONING_PARAMS;
        type PNET_COMPUTER_NAME_TYPE = *mut NET_COMPUTER_NAME_TYPE;
    }
}

        }
        const USE_OPTION_SMB_COMPRESSION_PARAMS: u32 = 1349349187;
        struct USE_OPTION_TRANSPORT_PARAMETERS {
            Tag: u32,
            Length: u16,
            Reserved: u16,
        }
        const USE_OPTION_TRANSPORT_PARAMS: u32 = 1348563540;
        const USE_PASSWORD_PARMNUM: u32 = 3;
        const USE_PAUSED: u32 = 1;
        const USE_RECONN: u32 = 5;
        const USE_REMOTE_PARMNUM: u32 = 2;
        const USE_SD_PARMNUM: u32 = 9;
        const USE_SESSLOST: u32 = 2;
        const USE_SPOOLDEV: u32 = 1;
        const USE_USERNAME_PARMNUM: u32 = 5;
        const USE_WILDCARD: i32 = -1;
    }

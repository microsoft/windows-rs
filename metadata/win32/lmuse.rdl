#[win32]
mod Windows {
    mod Win32 {
        struct BLOCK_NTLM_INFO {
            BlockNTLM: BOOLEAN,
            Reserved1: u8,
            Reserved2: u16,
            Reserved3: u32,
        }
        const CREATE_BYPASS_CSC: u32 = 2;
        const CREATE_CRED_RESET: u32 = 4;
        const CREATE_GLOBAL_MAPPING: u32 = 256;
        const CREATE_NO_CONNECT: u32 = 1;
        const CREATE_PERSIST_MAPPING: u32 = 32;
        const CREATE_REQUIRE_CONNECTION_INTEGRITY: u32 = 8;
        const CREATE_REQUIRE_CONNECTION_PRIVACY: u32 = 16;
        const CREATE_WRITE_THROUGH_SEMANTICS: u32 = 64;
        type LPUSE_INFO_0 = *mut USE_INFO_0;
        type LPUSE_INFO_1 = *mut USE_INFO_1;
        type LPUSE_INFO_2 = *mut USE_INFO_2;
        type LPUSE_INFO_3 = *mut USE_INFO_3;
        type LPUSE_INFO_4 = *mut USE_INFO_4;
        type LPUSE_INFO_5 = *mut USE_INFO_5;
        #[library("NETAPI32.dll")]
        extern fn NetUseAdd(#[opt] servername: LPTSTR, LevelFlags: u32, buf: *mut u8, #[opt] parm_err: *mut u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetUseDel(#[opt] UncServerName: PCWSTR, UseName: PCWSTR, ForceLevelFlags: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetUseEnum(#[opt] UncServerName: PCWSTR, LevelFlags: u32, BufPtr: *mut LPBYTE, PreferedMaximumSize: u32, #[opt] EntriesRead: *mut u32, TotalEntries: *mut u32, #[in] #[out] #[opt] ResumeHandle: *mut u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetUseGetInfo(#[opt] UncServerName: PCWSTR, UseName: PCWSTR, LevelFlags: u32, bufptr: *mut LPBYTE) -> u32;
        type PBLOCK_NTLM_INFO = *mut BLOCK_NTLM_INFO;
        type PSMB_COMPRESSION_INFO = *mut SMB_COMPRESSION_INFO;
        type PSMB_TREE_CONNECT_PARAMETERS = *mut SMB_TREE_CONNECT_PARAMETERS;
        type PSMB_USE_OPTION_COMPRESSION_PARAMETERS = *mut SMB_USE_OPTION_COMPRESSION_PARAMETERS;
        type PTRANSPORT_INFO = *mut TRANSPORT_INFO;
        type PTRANSPORT_INFO_FLAG = *mut TRANSPORT_INFO_FLAG;
        type PTRANSPORT_TYPE = *mut TRANSPORT_TYPE;
        type PUSE_INFO_0 = *mut USE_INFO_0;
        type PUSE_INFO_1 = *mut USE_INFO_1;
        type PUSE_INFO_2 = *mut USE_INFO_2;
        type PUSE_INFO_3 = *mut USE_INFO_3;
        type PUSE_INFO_4 = *mut USE_INFO_4;
        type PUSE_INFO_5 = *mut USE_INFO_5;
        type PUSE_OPTION_BLOCK_NTLM_PARAMETERS = *mut USE_OPTION_BLOCK_NTLM_PARAMETERS;
        type PUSE_OPTION_DEFERRED_CONNECTION_PARAMETERS = *mut USE_OPTION_DEFERRED_CONNECTION_PARAMETERS;
        type PUSE_OPTION_GENERIC = *mut USE_OPTION_GENERIC;
        type PUSE_OPTION_PROPERTIES = *mut USE_OPTION_PROPERTIES;
        type PUSE_OPTION_TRANSPORT_PARAMETERS = *mut USE_OPTION_TRANSPORT_PARAMETERS;
        struct SMB_COMPRESSION_INFO {
            Switch: BOOLEAN,
            Reserved1: u8,
            Reserved2: u16,
            Reserved3: u32,
        }
        struct SMB_TREE_CONNECT_PARAMETERS {
            EABufferOffset: u32,
            EABufferLen: u32,
            CreateOptions: u32,
            TreeConnectAttributes: u32,
        }
        struct SMB_USE_OPTION_COMPRESSION_PARAMETERS {
            Tag: u32,
            Length: u16,
            Reserved: u16,
        }
        struct TRANSPORT_INFO {
            Type: TRANSPORT_TYPE,
            SkipCertificateCheck: BOOLEAN,
            TcpPort: u16,
            QuicPort: u16,
            RdmaPort: u16,
            Flags: u32,
        }
        #[repr(i32)]
        enum TRANSPORT_INFO_FLAG {
            NoneFlag = 0,
            TcpPortSetFlag = 1,
            QuicPortSetFlag = 2,
            RdmaPortSetFlag = 4,
        }
        #[repr(i32)]
        enum TRANSPORT_TYPE {
            UseTransportType_None = 0,
            UseTransportType_Wsk = 1,
            UseTransportType_Quic = 2,
        }
        const USE_ASGTYPE_PARMNUM: u32 = 4;
        const USE_AUTHIDENTITY_PARMNUM: u32 = 8;
        const USE_CHARDEV: u32 = 2;
        const USE_CONN: u32 = 4;
        const USE_DEFAULT_CREDENTIALS: u32 = 4;
        const USE_DISCONN: u32 = 2;
        const USE_DISKDEV: u32 = 0;
        const USE_DOMAINNAME_PARMNUM: u32 = 6;

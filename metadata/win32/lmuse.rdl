            ui2_domainname: PWSTR,
        }
        struct USE_INFO_3 {
            ui3_ui2: USE_INFO_2,
            ui3_flags: u32,
        }
        struct USE_INFO_4 {
            ui4_ui3: USE_INFO_3,
            ui4_auth_identity_length: u32,
            ui4_auth_identity: PBYTE,
        }
        struct USE_INFO_5 {
            ui4_ui3: USE_INFO_3,
            ui4_auth_identity_length: u32,
            ui4_auth_identity: PBYTE,
            ui5_security_descriptor_length: u32,
            ui5_security_descriptor: PBYTE,
            ui5_use_options_length: u32,
            ui5_use_options: PBYTE,
        }
        const USE_IPC: u32 = 3;
        const USE_LOCAL_PARMNUM: u32 = 1;
        const USE_NETERR: u32 = 3;
        const USE_OK: u32 = 0;
        const USE_OPTIONS_PARMNUM: u32 = 10;
        struct USE_OPTION_BLOCK_NTLM_PARAMETERS {
            Tag: u32,
            Length: u16,
            Reserved: u16,
        }
        const USE_OPTION_BLOCK_NTLM_PARAMS: u32 = 1315925058;
        struct USE_OPTION_DEFERRED_CONNECTION_PARAMETERS {
            Tag: u32,
            Length: u16,
            Reserved: u16,
        }
        const USE_OPTION_DEFERRED_CONNECTION_PARAMS: u32 = 1130784068;
        struct USE_OPTION_GENERIC {
            Tag: u32,
            Length: u16,
            Reserved: u16,
        }
        struct USE_OPTION_PROPERTIES {
            Tag: u32,
            pInfo: *mut void,

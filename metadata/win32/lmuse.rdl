            ui1_refcount: u32,
            ui1_usecount: u32,
        }
        struct USE_INFO_2 {
            ui2_local: PWSTR,
            ui2_remote: PWSTR,
            ui2_password: PWSTR,
            ui2_status: u32,
            ui2_asg_type: u32,
            ui2_refcount: u32,
            ui2_usecount: u32,

        type PSOCKADDR_UN = *mut SOCKADDR_UN;
        const SIO_AF_UNIX_GETPEERPID: u32 = 1476395264;
        const SIO_AF_UNIX_SETBINDPARENTPATH: i32 = -1744830207;
        const SIO_AF_UNIX_SETCONNPARENTPATH: i32 = -1744830206;

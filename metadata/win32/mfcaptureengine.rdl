#[win32]
mod Windows {
    mod Win32 {
        #[guid(0xa6bba433_176b_48b2_b375_53aa03473207)]
        interface IMFCaptureEngine: IUnknown {
            fn Initialize(&self, pEventCallback: IMFCaptureEngineOnEventCallback, #[opt] pAttributes: IMFAttributes, #[opt] pAudioSource: IUnknown, #[opt] pVideoSource: IUnknown) -> HRESULT;
            fn StartPreview(&self) -> HRESULT;
            fn StopPreview(&self) -> HRESULT;
            fn StartRecord(&self) -> HRESULT;
            fn StopRecord(&self, bFinalize: BOOL, bFlushUnprocessedSamples: BOOL) -> HRESULT;
            fn TakePhoto(&self) -> HRESULT;
            fn GetSink(&self, mfCaptureEngineSinkType: MF_CAPTURE_ENGINE_SINK_TYPE, ppSink: *mut IMFCaptureSink) -> HRESULT;
            fn GetSource(&self, ppSource: *mut IMFCaptureSource) -> HRESULT;
        }
        #[guid(0x8f02d140_56fc_4302_a705_3a97c78be779)]
        interface IMFCaptureEngineClassFactory: IUnknown {
            fn CreateInstance(&self, clsid: *const GUID, riid: *const GUID, ppvObject: *mut *mut void) -> HRESULT;
        }
        #[guid(0xaeda51c0_9025_4983_9012_de597b88b089)]
        interface IMFCaptureEngineOnEventCallback: IUnknown {
            fn OnEvent(&self, pEvent: IMFMediaEvent) -> HRESULT;
        }
        #[guid(0x52150b82_ab39_4467_980f_e48bf0822ecd)]
        interface IMFCaptureEngineOnSampleCallback: IUnknown {
            fn OnSample(&self, #[opt] pSample: IMFSample) -> HRESULT;
        }

        interface IMFCaptureEngineOnSampleCallback2: IMFCaptureEngineOnSampleCallback {
            fn OnSynchronizedEvent(&self, pEvent: IMFMediaEvent) -> HRESULT;
        }
        #[guid(0xd2d43cc8_48bb_4aa7_95db_10c06977e777)]
        interface IMFCapturePhotoSink: IMFCaptureSink {
            fn SetOutputFileName(&self, fileName: PCWSTR) -> HRESULT;
            fn SetSampleCallback(&self, pCallback: IMFCaptureEngineOnSampleCallback) -> HRESULT;
            fn SetOutputByteStream(&self, pByteStream: IMFByteStream) -> HRESULT;
        }
        #[guid(0x77346cfd_5b49_4d73_ace0_5b52a859f2e0)]
        interface IMFCapturePreviewSink: IMFCaptureSink {
            fn SetRenderHandle(&self, handle: HANDLE) -> HRESULT;

            fn UpdateVideo(&self, #[opt] pSrc: *const MFVideoNormalizedRect, #[opt] pDst: *const RECT, #[opt] pBorderClr: *const COLORREF) -> HRESULT;
            fn SetSampleCallback(&self, dwStreamSinkIndex: u32, pCallback: IMFCaptureEngineOnSampleCallback) -> HRESULT;
            fn GetMirrorState(&self, pfMirrorState: *mut BOOL) -> HRESULT;
            fn SetMirrorState(&self, fMirrorState: BOOL) -> HRESULT;
            fn GetRotation(&self, dwStreamIndex: u32, pdwRotationValue: *mut u32) -> HRESULT;
            fn SetRotation(&self, dwStreamIndex: u32, dwRotationValue: u32) -> HRESULT;
            fn SetCustomSink(&self, pMediaSink: IMFMediaSink) -> HRESULT;
        }
        #[guid(0x3323b55a_f92a_4fe2_8edc_e9bfc0634d77)]
        interface IMFCaptureRecordSink: IMFCaptureSink {
            fn SetOutputByteStream(&self, pByteStream: IMFByteStream, guidContainerType: *const GUID) -> HRESULT;
            fn SetOutputFileName(&self, fileName: PCWSTR) -> HRESULT;
            fn SetSampleCallback(&self, dwStreamSinkIndex: u32, pCallback: IMFCaptureEngineOnSampleCallback) -> HRESULT;
            fn SetCustomSink(&self, pMediaSink: IMFMediaSink) -> HRESULT;
            fn GetRotation(&self, dwStreamIndex: u32, pdwRotationValue: *mut u32) -> HRESULT;
            fn SetRotation(&self, dwStreamIndex: u32, dwRotationValue: u32) -> HRESULT;
        }
        #[guid(0x72d6135b_35e9_412c_b926_fd5265f2a885)]
        interface IMFCaptureSink: IUnknown {
            fn GetOutputMediaType(&self, dwSinkStreamIndex: u32, #[opt] ppMediaType: *mut IMFMediaType) -> HRESULT;
            fn GetService(&self, dwSinkStreamIndex: u32, rguidService: *const GUID, riid: *const GUID, #[opt] ppUnknown: *mut IUnknown) -> HRESULT;
            fn AddStream(&self, dwSourceStreamIndex: u32, pMediaType: IMFMediaType, #[opt] pAttributes: IMFAttributes, #[opt] pdwSinkStreamIndex: *mut u32) -> HRESULT;
            fn Prepare(&self) -> HRESULT;
            fn RemoveAllStreams(&self) -> HRESULT;
        }
        #[guid(0xf9e4219e_6197_4b5e_b888_bee310ab2c59)]
        interface IMFCaptureSink2: IMFCaptureSink {
            fn SetOutputMediaType(&self, dwStreamIndex: u32, pMediaType: IMFMediaType, #[opt] pEncodingAttributes: IMFAttributes) -> HRESULT;
        }
        #[guid(0x439a42a8_0d2c_4505_be83_f79b2a05d5c4)]
        interface IMFCaptureSource: IUnknown {
            fn GetCaptureDeviceSource(&self, mfCaptureEngineDeviceType: MF_CAPTURE_ENGINE_DEVICE_TYPE, #[opt] ppMediaSource: *mut IMFMediaSource) -> HRESULT;
            fn GetCaptureDeviceActivate(&self, mfCaptureEngineDeviceType: MF_CAPTURE_ENGINE_DEVICE_TYPE, #[opt] ppActivate: *mut IMFActivate) -> HRESULT;
            fn GetService(&self, rguidService: *const GUID, riid: *const GUID, #[opt] ppUnknown: *mut IUnknown) -> HRESULT;
            fn AddEffect(&self, dwSourceStreamIndex: u32, pUnknown: IUnknown) -> HRESULT;
            fn RemoveEffect(&self, dwSourceStreamIndex: u32, pUnknown: IUnknown) -> HRESULT;
            fn RemoveAllEffects(&self, dwSourceStreamIndex: u32) -> HRESULT;
            fn GetAvailableDeviceMediaType(&self, dwSourceStreamIndex: u32, dwMediaTypeIndex: u32, #[opt] ppMediaType: *mut IMFMediaType) -> HRESULT;
            fn SetCurrentDeviceMediaType(&self, dwSourceStreamIndex: u32, pMediaType: IMFMediaType) -> HRESULT;
            fn GetCurrentDeviceMediaType(&self, dwSourceStreamIndex: u32, ppMediaType: *mut IMFMediaType) -> HRESULT;
            fn GetDeviceStreamCount(&self, pdwStreamCount: *mut u32) -> HRESULT;
            fn GetDeviceStreamCategory(&self, dwSourceStreamIndex: u32, pStreamCategory: *mut MF_CAPTURE_ENGINE_STREAM_CATEGORY) -> HRESULT;
            fn GetMirrorState(&self, dwStreamIndex: u32, pfMirrorState: *mut BOOL) -> HRESULT;
            fn SetMirrorState(&self, dwStreamIndex: u32, fMirrorState: BOOL) -> HRESULT;
            fn GetStreamIndexFromFriendlyName(&self, uifriendlyName: u32, pdwActualStreamIndex: *mut u32) -> HRESULT;
        }

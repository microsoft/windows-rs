            empvDword: EAP_METHOD_PROPERTY_VALUE_DWORD,
            empvString: EAP_METHOD_PROPERTY_VALUE_STRING,
        }
        struct EAP_METHOD_PROPERTY_VALUE_BOOL {
            length: u32,

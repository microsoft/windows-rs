        const EAP_UI_INPUT_FIELD_PROPS_NON_PERSIST: u32 = 2;
        const EAP_UI_INPUT_FIELD_PROPS_READ_ONLY: u32 = 4;
        #[encoding("utf-16")]
        const EAP_VALUENAME_PROPERTIES: String = "Properties";

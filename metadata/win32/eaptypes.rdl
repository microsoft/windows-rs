            EAP_EMPTY_CREDENTIAL = 0,
            EAP_USERNAME_PASSWORD_CREDENTIAL = 1,
            EAP_WINLOGON_CREDENTIAL = 2,
            EAP_CERTIFICATE_CREDENTIAL = 3,
            EAP_SIM_CREDENTIAL = 4,
        }

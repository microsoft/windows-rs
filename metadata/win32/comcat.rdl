#[win32]
mod Windows {
    mod Win32 {
        struct CATEGORYINFO {
            catid: CATID,
            lcid: LCID,
            szDescription: [OLECHAR; 128],
        }
        type CATID = GUID;
        #[guid(0x0002e013_0000_0000_c000_000000000046)]
        interface ICatInformation: IUnknown {
            fn EnumCategories(&self, lcid: LCID, ppenumCategoryInfo: *mut IEnumCATEGORYINFO) -> HRESULT;
            fn GetCategoryDesc(&self, rcatid: REFCATID, lcid: LCID, pszDesc: *mut PWSTR) -> HRESULT;
            fn EnumClassesOfCategories(&self, cImplemented: u32, rgcatidImpl: [CATID; 0], cRequired: u32, rgcatidReq: [CATID; 0], ppenumClsid: *mut IEnumGUID) -> HRESULT;
            fn IsClassOfCategories(&self, rclsid: *const GUID, cImplemented: u32, rgcatidImpl: [CATID; 0], cRequired: u32, rgcatidReq: [CATID; 0]) -> HRESULT;

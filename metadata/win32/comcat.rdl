            fn UnRegisterCategories(&self, cCategories: u32, rgcatid: [CATID; 0]) -> HRESULT;
            fn RegisterClassImplCategories(&self, rclsid: *const GUID, cCategories: u32, rgcatid: [CATID; 0]) -> HRESULT;
            fn UnRegisterClassImplCategories(&self, rclsid: *const GUID, cCategories: u32, rgcatid: [CATID; 0]) -> HRESULT;
            fn RegisterClassReqCategories(&self, rclsid: *const GUID, cCategories: u32, rgcatid: [CATID; 0]) -> HRESULT;
            fn UnRegisterClassReqCategories(&self, rclsid: *const GUID, cCategories: u32, rgcatid: [CATID; 0]) -> HRESULT;
        }
        #[guid(0x0002e011_0000_0000_c000_000000000046)]
        interface IEnumCATEGORYINFO: IUnknown {
            fn Next(&self, celt: u32, rgelt: *mut CATEGORYINFO, pceltFetched: *mut u32) -> HRESULT;
            fn Skip(&self, celt: u32) -> HRESULT;
            fn Reset(&self) -> HRESULT;

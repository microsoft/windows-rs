        #[guid(0x0002e000_0000_0000_c000_000000000046)]
        interface IEnumGUID: IUnknown {
            fn Next(&self, celt: u32, #[len_param(0)] rgelt: *mut GUID, #[opt] pceltFetched: *mut u32) -> HRESULT;
            fn Skip(&self, celt: u32) -> HRESULT;
            fn Reset(&self) -> HRESULT;
            fn Clone(&self, ppenum: *mut IEnumGUID) -> HRESULT;

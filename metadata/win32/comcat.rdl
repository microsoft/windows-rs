            fn EnumReqCategoriesOfClass(&self, rclsid: *const GUID, ppenumCatid: *mut IEnumGUID) -> HRESULT;
        }
        #[guid(0x0002e012_0000_0000_c000_000000000046)]
        interface ICatRegister: IUnknown {

            Descriptors: [CDROM_TOC_ATIP_DATA_BLOCK; 0],
        }
        struct CDROM_TOC_ATIP_DATA_BLOCK {
            _bitfield1: u8 {
                CdrwReferenceSpeed: 3,
                Reserved3: 1,
                WritePower: 3,
                True1: 1,
            },
            _bitfield2: u8 {
                Reserved4: 6,
                UnrestrictedUse: 1,
                Reserved5: 1,
            },
            _bitfield3: u8 {
                A3Valid: 1,
                A2Valid: 1,
                A1Valid: 1,
                DiscSubType: 3,
                IsCdrw: 1,
                True2: 1,
            },
            Reserved7: u8,
            LeadInMsf: [u8; 3],
            Reserved8: u8,
            LeadOutMsf: [u8; 3],
            Reserved9: u8,
            A1Values: [u8; 3],
            Reserved10: u8,
            A2Values: [u8; 3],
            Reserved11: u8,
            A3Values: [u8; 3],
            Reserved12: u8,
        }
        struct CDROM_TOC_CD_TEXT_DATA {
            Length: [u8; 2],
            Reserved1: u8,
            Reserved2: u8,
            Descriptors: [CDROM_TOC_CD_TEXT_DATA_BLOCK; 0],
        }
        struct CDROM_TOC_CD_TEXT_DATA_BLOCK {
            PackType: u8,
            _bitfield1: u8 {
                TrackNumber: 7,
                ExtensionFlag: 1,
            },
            SequenceNumber: u8,
            _bitfield2: u8 {
                CharacterPosition: 4,
                BlockNumber: 3,
                Unicode: 1,
            },

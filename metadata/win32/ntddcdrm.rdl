                Text: [u8; 12],
                WText: [u16; 6],
            },
            CRC: [u8; 2],
        }
        struct CDROM_TOC_FULL_TOC_DATA {
            Length: [u8; 2],
            FirstCompleteSession: u8,
            LastCompleteSession: u8,
            Descriptors: [CDROM_TOC_FULL_TOC_DATA_BLOCK; 0],
        }
        struct CDROM_TOC_FULL_TOC_DATA_BLOCK {
            SessionNumber: u8,
            _bitfield: u8 {
                Control: 4,
                Adr: 4,
            },
            Reserved1: u8,
            Point: u8,
            MsfExtra: [u8; 3],
            Zero: u8,
            Msf: [u8; 3],

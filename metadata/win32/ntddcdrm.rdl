        type PTRACK_MODE_TYPE = *mut TRACK_MODE_TYPE;
        type PVOLUME_CONTROL = *mut VOLUME_CONTROL;
        type PWRITE_ROTATION = *mut WRITE_ROTATION;
        struct RAW_READ_INFO {
            DiskOffset: LARGE_INTEGER,

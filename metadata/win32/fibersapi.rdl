#[win32]
mod Windows {
    mod Win32 {
        const FLS_OUT_OF_INDEXES: u32 = 4294967295;
        #[library("KERNEL32.dll")]
        extern fn FlsAlloc(#[opt] lpCallback: PFLS_CALLBACK_FUNCTION) -> u32;
        #[library("KERNEL32.dll")]
        extern fn FlsFree(dwFlsIndex: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn FlsGetValue(dwFlsIndex: u32) -> *mut void;
        #[library("KERNEL32.dll")]
        extern fn FlsGetValue2(dwTlsIndex: u32) -> *mut void;
        #[library("KERNEL32.dll")]
        extern fn FlsSetValue(dwFlsIndex: u32, #[opt] lpFlsData: *const void) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn IsThreadAFiber() -> BOOL;
    }
}

        #[library("KERNEL32.dll")]
        extern fn SetWaitableTimerEx(hTimer: HANDLE, lpDueTime: *const LARGE_INTEGER, lPeriod: i32, #[opt] pfnCompletionRoutine: PTIMERAPCROUTINE, #[opt] lpArgToCompletionRoutine: *const void, #[opt] WakeContext: *const REASON_CONTEXT, TolerableDelay: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SignalObjectAndWait(hObjectToSignal: HANDLE, hObjectToWaitOn: HANDLE, dwMilliseconds: u32, bAlertable: BOOL) -> u32;

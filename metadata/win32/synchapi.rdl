        #[library("KERNEL32.dll")]
        extern fn ResetEvent(hEvent: HANDLE) -> BOOL;
        type SRWLOCK = RTL_SRWLOCK;
        type SYNCHRONIZATION_BARRIER = RTL_BARRIER;
        const SYNCHRONIZATION_BARRIER_FLAGS_BLOCK_ONLY: u32 = 2;
        const SYNCHRONIZATION_BARRIER_FLAGS_NO_DELETE: u32 = 4;
        const SYNCHRONIZATION_BARRIER_FLAGS_SPIN_ONLY: u32 = 1;

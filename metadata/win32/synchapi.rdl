        #[library("KERNEL32.dll")]
        extern fn CreateSemaphoreW(#[opt] lpSemaphoreAttributes: *const SECURITY_ATTRIBUTES, lInitialCount: i32, lMaximumCount: i32, #[opt] lpName: PCWSTR) -> HANDLE;

#[win32]
mod Windows {
    mod Win32 {
        #[repr(i32)]
        enum DVD_ERROR {
            DVD_ERROR_Unexpected = 1,
            DVD_ERROR_CopyProtectFail = 2,
            DVD_ERROR_InvalidDVD1_0Disc = 3,
            DVD_ERROR_InvalidDiscRegion = 4,
            DVD_ERROR_LowParentalLevel = 5,

        }
        #[repr(i32)]
        enum DVD_WARNING {
            DVD_WARNING_InvalidDVD1_0Disc = 1,
            DVD_WARNING_FormatNotSupported = 2,
            DVD_WARNING_IllegalNavCommand = 3,
            DVD_WARNING_Open = 4,
            DVD_WARNING_Seek = 5,
            DVD_WARNING_Read = 6,
        }
        const EC_DVDBASE: u32 = 256;
        const EC_DVD_ANGLES_AVAILABLE: u32 = 275;
        const EC_DVD_ANGLE_CHANGE: u32 = 262;
        const EC_DVD_AUDIO_STREAM_CHANGE: u32 = 260;
        const EC_DVD_BUTTON_AUTO_ACTIVATED: u32 = 277;

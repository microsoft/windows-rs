        const EC_DVD_DISC_EJECTED: u32 = 280;
        const EC_DVD_DISC_INSERTED: u32 = 281;
        const EC_DVD_DOMAIN_CHANGE: u32 = 257;
        const EC_DVD_ERROR: u32 = 268;

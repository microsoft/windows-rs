#[win32]
mod Windows {
    mod Win32 {
        struct OFFSETINSTANCEDATAANDLENGTH {
            OffsetInstanceData: u32,
            LengthInstanceData: u32,
        }
        type POFFSETINSTANCEDATAANDLENGTH = *mut OFFSETINSTANCEDATAANDLENGTH;
        type PWMIREGGUID = PWMIREGGUIDW;
        type PWMIREGGUIDW = *mut WMIREGGUIDW;
        type PWMIREGINFO = PWMIREGINFOW;
        type PWMIREGINFOW = *mut WMIREGINFOW;
        type PWNODE_ALL_DATA = *mut WNODE_ALL_DATA;
        type PWNODE_EVENT_ITEM = *mut WNODE_EVENT_ITEM;
        type PWNODE_EVENT_REFERENCE = *mut WNODE_EVENT_REFERENCE;
        type PWNODE_HEADER = *mut WNODE_HEADER;
        type PWNODE_METHOD_ITEM = *mut WNODE_METHOD_ITEM;
        type PWNODE_SINGLE_INSTANCE = *mut WNODE_SINGLE_INSTANCE;
        type PWNODE_SINGLE_ITEM = *mut WNODE_SINGLE_ITEM;
        type PWNODE_TOO_SMALL = *mut WNODE_TOO_SMALL;
        const TRACELOG_ACCESS_KERNEL_LOGGER: u32 = 256;
        const TRACELOG_ACCESS_REALTIME: u32 = 1024;
        const TRACELOG_CREATE_INPROC: u32 = 512;
        const TRACELOG_CREATE_ONDISK: u32 = 64;
        const TRACELOG_CREATE_REALTIME: u32 = 32;
        const TRACELOG_GUID_ENABLE: u32 = 128;
        const TRACELOG_JOIN_GROUP: u32 = 4096;
        const TRACELOG_LOG_EVENT: u32 = 512;
        const TRACELOG_REGISTER_GUIDS: u32 = 2048;
        #[repr(i32)]
        enum WMIDPREQUESTCODE {
            WMI_GET_ALL_DATA = 0,
            WMI_GET_SINGLE_INSTANCE = 1,
            WMI_SET_SINGLE_INSTANCE = 2,
            WMI_SET_SINGLE_ITEM = 3,
            WMI_ENABLE_EVENTS = 4,
            WMI_DISABLE_EVENTS = 5,
            WMI_ENABLE_COLLECTION = 6,
            WMI_DISABLE_COLLECTION = 7,
            WMI_REGINFO = 8,
            WMI_EXECUTE_METHOD = 9,
            WMI_CAPTURE_STATE = 10,
        }
        const WMIGUID_ALL_ACCESS: u32 = 1187839;
        const WMIGUID_ALL_ACCESS_RS1: u32 = 1187839;
        const WMIGUID_ALL_ACCESS_WIN2K: u32 = 133119;
        const WMIGUID_ALL_ACCESS_WINXP: u32 = 1183743;
        const WMIGUID_EXECUTE: u32 = 16;
        const WMIGUID_NOTIFICATION: u32 = 4;
        const WMIGUID_QUERY: u32 = 1;
        const WMIGUID_READ_DESCRIPTION: u32 = 8;
        const WMIGUID_SET: u32 = 2;
        type WMIREGGUID = WMIREGGUIDW;
        struct WMIREGGUIDW {
            Guid: GUID,
            Flags: u32,
            InstanceCount: u32,
            Anonymous: union {
                InstanceNameList: u32,
                BaseNameOffset: u32,
                Pdo: usize,
                InstanceInfo: usize,
            },
        }
        type WMIREGINFO = WMIREGINFOW;
        struct WMIREGINFOW {
            BufferSize: u32,
            NextWmiRegInfo: u32,
            RegistryPath: u32,
            MofResourceName: u32,
            GuidCount: u32,
            WmiRegGuid: [WMIREGGUIDW; 0],
        }
        const WMIREG_FLAG_EVENT_ONLY_GUID: u32 = 64;
        const WMIREG_FLAG_EXPENSIVE: u32 = 1;
        const WMIREG_FLAG_INSTANCE_BASENAME: u32 = 8;
        const WMIREG_FLAG_INSTANCE_LIST: u32 = 4;
        const WMIREG_FLAG_INSTANCE_PDO: u32 = 32;
        const WMIREG_FLAG_REMOVE_GUID: u32 = 65536;
        const WMIREG_FLAG_RESERVED1: u32 = 131072;
        const WMIREG_FLAG_RESERVED2: u32 = 262144;
        const WMIREG_FLAG_TRACED_GUID: u32 = 524288;
        const WMIREG_FLAG_TRACE_CONTROL_GUID: u32 = 4096;
        const WMI_GLOBAL_LOGGER_ID: u32 = 1;
        const WMI_GUIDTYPE_DATA: u32 = 2;
        const WMI_GUIDTYPE_EVENT: u32 = 3;
        const WMI_GUIDTYPE_TRACE: u32 = 1;
        const WMI_GUIDTYPE_TRACECONTROL: u32 = 0;
        struct WNODE_ALL_DATA {
            WnodeHeader: WNODE_HEADER,
            DataBlockOffset: u32,
            InstanceCount: u32,
            OffsetInstanceNameOffsets: u32,
            Anonymous: union {
                FixedInstanceSize: u32,
                OffsetInstanceDataAndLength: [OFFSETINSTANCEDATAANDLENGTH; 0],
            },
        }
        struct WNODE_EVENT_ITEM {
            WnodeHeader: WNODE_HEADER,
        }
        struct WNODE_EVENT_REFERENCE {
            WnodeHeader: WNODE_HEADER,
            TargetGuid: GUID,
            TargetDataBlockSize: u32,
            Anonymous: union {
                TargetInstanceIndex: u32,
                TargetInstanceName: [u16; 0],
            },
        }
        const WNODE_FLAG_ALL_DATA: u32 = 1;
        const WNODE_FLAG_ANSI_INSTANCENAMES: u32 = 16384;
        const WNODE_FLAG_EVENT_ITEM: u32 = 8;
        const WNODE_FLAG_EVENT_REFERENCE: u32 = 8192;
        const WNODE_FLAG_FIXED_INSTANCE_SIZE: u32 = 16;
        const WNODE_FLAG_INSTANCES_SAME: u32 = 64;
        const WNODE_FLAG_INTERNAL: u32 = 256;
        const WNODE_FLAG_LOG_WNODE: u32 = 262144;
        const WNODE_FLAG_METHOD_ITEM: u32 = 32768;
        const WNODE_FLAG_NO_HEADER: u32 = 2097152;
        const WNODE_FLAG_PDO_INSTANCE_NAMES: u32 = 65536;
        const WNODE_FLAG_PERSIST_EVENT: u32 = 1024;
        const WNODE_FLAG_SEND_DATA_BLOCK: u32 = 4194304;
        const WNODE_FLAG_SEVERITY_MASK: u32 = 4278190080;
        const WNODE_FLAG_SINGLE_INSTANCE: u32 = 2;
        const WNODE_FLAG_SINGLE_ITEM: u32 = 4;
        const WNODE_FLAG_STATIC_INSTANCE_NAMES: u32 = 128;
        const WNODE_FLAG_TOO_SMALL: u32 = 32;
        const WNODE_FLAG_TRACED_GUID: u32 = 131072;
        const WNODE_FLAG_USE_GUID_PTR: u32 = 524288;
        const WNODE_FLAG_USE_MOF_PTR: u32 = 1048576;
        const WNODE_FLAG_USE_TIMESTAMP: u32 = 512;
        const WNODE_FLAG_VERSIONED_PROPERTIES: u32 = 8388608;
        struct WNODE_HEADER {
            BufferSize: u32,
            ProviderId: u32,
            Anonymous: union {
                HistoricalContext: u64,
                Anonymous: struct {
                    Version: u32,
                    Linkage: u32,
                },
            },
            Anonymous2: union {
                CountLost: u32,
                KernelHandle: HANDLE,
                TimeStamp: LARGE_INTEGER,
            },
            Guid: GUID,
            ClientContext: u32,
            Flags: u32,
        }
        struct WNODE_METHOD_ITEM {
            WnodeHeader: WNODE_HEADER,
            OffsetInstanceName: u32,
            InstanceIndex: u32,
            MethodId: u32,
            DataBlockOffset: u32,
            SizeDataBlock: u32,
            VariableData: [u8; 0],
        }
        struct WNODE_SINGLE_INSTANCE {
            WnodeHeader: WNODE_HEADER,
            OffsetInstanceName: u32,
            InstanceIndex: u32,
            DataBlockOffset: u32,
            SizeDataBlock: u32,
            VariableData: [u8; 0],
        }
        struct WNODE_SINGLE_ITEM {
            WnodeHeader: WNODE_HEADER,
            OffsetInstanceName: u32,
            InstanceIndex: u32,
            ItemId: u32,
            DataBlockOffset: u32,
            SizeDataItem: u32,
            VariableData: [u8; 0],
        }
        struct WNODE_TOO_SMALL {
            WnodeHeader: WNODE_HEADER,
            SizeNeeded: u32,
        }
    }
}

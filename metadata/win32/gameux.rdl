#[win32]
mod Windows {
    mod Win32 {
        #[repr(i32)]
        enum GAMESTATS_OPEN_RESULT {
            GAMESTATS_OPEN_CREATED = 0,
            GAMESTATS_OPEN_OPENED = 1,
        }
        #[repr(i32)]
        enum GAMESTATS_OPEN_TYPE {
            GAMESTATS_OPEN_OPENORCREATE = 0,
            GAMESTATS_OPEN_OPENONLY = 1,
        }
        #[repr(i32)]
        enum GAME_INSTALL_SCOPE {
            GIS_NOT_INSTALLED = 1,
            GIS_CURRENT_USER = 2,
            GIS_ALL_USERS = 3,
        }
        const GameExplorer: GUID = 0x9a5ea990_3034_4d6f_9128_01f3c61022bc;
        const GameStatistics: GUID = 0xdbc85a2c_c0dc_4961_b6e2_d28b62c11ad4;
        #[encoding("utf-16")]
        const ID_GDF_THUMBNAIL_STR: String = "__GDF_THUMBNAIL";
        #[encoding("utf-16")]
        const ID_GDF_XML_STR: String = "__GDF_XML";
        #[guid(0xe7b2fb72_d728_49b3_a5f2_18ebf5f1349e)]
        interface IGameExplorer: IUnknown {
            fn AddGame(&self, bstrGDFBinaryPath: BSTR, bstrGameInstallDirectory: BSTR, installScope: GAME_INSTALL_SCOPE, #[in] #[out] pguidInstanceID: *mut GUID) -> HRESULT;
            fn RemoveGame(&self, guidInstanceID: GUID) -> HRESULT;
            fn UpdateGame(&self, guidInstanceID: GUID) -> HRESULT;
            fn VerifyAccess(&self, bstrGDFBinaryPath: BSTR, pfHasAccess: *mut BOOL) -> HRESULT;
        }
        #[guid(0x86874aa7_a1ed_450d_a7eb_b89e20b2fff3)]
        interface IGameExplorer2: IUnknown {
            fn InstallGame(&self, binaryGDFPath: PCWSTR, installDirectory: PCWSTR, installScope: GAME_INSTALL_SCOPE) -> HRESULT;
            fn UninstallGame(&self, binaryGDFPath: PCWSTR) -> HRESULT;
            fn CheckAccess(&self, binaryGDFPath: PCWSTR, #[retval] pHasAccess: *mut BOOL) -> HRESULT;
        }
        #[guid(0x3887c9ca_04a0_42ae_bc4c_5fa6c7721145)]
        interface IGameStatistics: IUnknown {
            fn GetMaxCategoryLength(&self, #[retval] cch: *mut u32) -> HRESULT;
            fn GetMaxNameLength(&self, #[retval] cch: *mut u32) -> HRESULT;
            fn GetMaxValueLength(&self, #[retval] cch: *mut u32) -> HRESULT;
            fn GetMaxCategories(&self, #[retval] pMax: *mut u16) -> HRESULT;
            fn GetMaxStatsPerCategory(&self, #[retval] pMax: *mut u16) -> HRESULT;
            fn SetCategoryTitle(&self, categoryIndex: u16, title: PCWSTR) -> HRESULT;
            fn GetCategoryTitle(&self, categoryIndex: u16, #[retval] pTitle: *mut PWSTR) -> HRESULT;
            fn GetStatistic(&self, categoryIndex: u16, statIndex: u16, #[in] #[out] pName: *mut PWSTR, #[in] #[out] pValue: *mut PWSTR) -> HRESULT;
            fn SetStatistic(&self, categoryIndex: u16, statIndex: u16, name: PCWSTR, value: PCWSTR) -> HRESULT;
            fn Save(&self, trackChanges: BOOL) -> HRESULT;
            fn SetLastPlayedCategory(&self, categoryIndex: u32) -> HRESULT;
            fn GetLastPlayedCategory(&self, #[retval] pCategoryIndex: *mut u32) -> HRESULT;
        }
        #[guid(0xaff3ea11_e70e_407d_95dd_35e612c41ce2)]
        interface IGameStatisticsMgr: IUnknown {
            fn GetGameStatistics(&self, GDFBinaryPath: PCWSTR, openType: GAMESTATS_OPEN_TYPE, pOpenResult: *mut GAMESTATS_OPEN_RESULT, #[retval] ppiStats: *mut IGameStatistics) -> HRESULT;
            fn RemoveGameStatistics(&self, GDFBinaryPath: PCWSTR) -> HRESULT;
        }
    }
}

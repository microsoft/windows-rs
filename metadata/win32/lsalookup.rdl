#[win32]
mod Windows {
    mod Win32 {
        const LOOKUP_TRANSLATE_NAMES: u32 = 2048;
        const LOOKUP_VIEW_LOCAL_INFORMATION: u32 = 1;
        #[repr(i32)]
        enum LSA_LOOKUP_DOMAIN_INFO_CLASS {
            AccountDomainInformation = 5,
            DnsDomainInformation = 12,
        }
        type LSA_LOOKUP_HANDLE = *mut void;
        struct LSA_OBJECT_ATTRIBUTES {
            Length: u32,
            RootDirectory: HANDLE,
            ObjectName: PLSA_UNICODE_STRING,
            Attributes: u32,
            SecurityDescriptor: *mut void,
            SecurityQualityOfService: *mut void,
        }
        struct LSA_REFERENCED_DOMAIN_LIST {
            Entries: u32,
            Domains: PLSA_TRUST_INFORMATION,
        }
        struct LSA_STRING {
            Length: u16,
            MaximumLength: u16,
            Buffer: PCHAR,
        }
        struct LSA_TRANSLATED_NAME {
            Use: SID_NAME_USE,
            Name: LSA_UNICODE_STRING,
            DomainIndex: i32,
        }
        struct LSA_TRANSLATED_SID2 {
            Use: SID_NAME_USE,
            Sid: PSID,
            DomainIndex: i32,
            Flags: u32,
        }
        struct LSA_TRUST_INFORMATION {
            Name: LSA_UNICODE_STRING,
            Sid: PSID,
        }
        struct LSA_UNICODE_STRING {
            Length: u16,
            MaximumLength: u16,
            Buffer: PWSTR,
        }
        type PLSA_LOOKUP_DOMAIN_INFO_CLASS = *mut LSA_LOOKUP_DOMAIN_INFO_CLASS;
        type PLSA_LOOKUP_HANDLE = *mut *mut void;
        type PLSA_OBJECT_ATTRIBUTES = *mut LSA_OBJECT_ATTRIBUTES;
        type PLSA_REFERENCED_DOMAIN_LIST = *mut LSA_REFERENCED_DOMAIN_LIST;
        type PLSA_STRING = *mut LSA_STRING;
        type PLSA_TRANSLATED_NAME = *mut LSA_TRANSLATED_NAME;
        type PLSA_TRANSLATED_SID2 = *mut LSA_TRANSLATED_SID2;
        type PLSA_TRUST_INFORMATION = *mut LSA_TRUST_INFORMATION;
        type PLSA_UNICODE_STRING = *mut LSA_UNICODE_STRING;
        struct POLICY_ACCOUNT_DOMAIN_INFO {
            DomainName: LSA_UNICODE_STRING,
            DomainSid: PSID,
        }
        struct POLICY_DNS_DOMAIN_INFO {
            Name: LSA_UNICODE_STRING,
            DnsDomainName: LSA_UNICODE_STRING,
            DnsForestName: LSA_UNICODE_STRING,
            DomainGuid: GUID,
            Sid: PSID,
        }
        type PPOLICY_ACCOUNT_DOMAIN_INFO = *mut POLICY_ACCOUNT_DOMAIN_INFO;
        type PPOLICY_DNS_DOMAIN_INFO = *mut POLICY_DNS_DOMAIN_INFO;
    }
}

        extern fn DsMakeSpnA(ServiceClass: PCSTR, ServiceName: PCSTR, #[opt] InstanceName: PCSTR, InstancePort: u16, #[opt] Referrer: PCSTR, #[in] #[out] pcSpnLength: *mut u32, #[len_param(5)] #[out] #[opt] pszSpn: PSTR) -> u32;

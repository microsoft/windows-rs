        extern fn DsMakeSpnW(ServiceClass: PCWSTR, ServiceName: PCWSTR, #[opt] InstanceName: PCWSTR, InstancePort: u16, #[opt] Referrer: PCWSTR, #[in] #[out] pcSpnLength: *mut u32, #[len_param(5)] #[out] #[opt] pszSpn: PWSTR) -> u32;
        #[library("NTDSAPI.dll")]
        extern fn DsQuoteRdnValueA(cUnquotedRdnValueLength: u32, #[len_param(0)] psUnquotedRdnValue: *const i8, #[in] #[out] pcQuotedRdnValueLength: *mut u32, #[len_param(2)] psQuotedRdnValue: *mut i8) -> u32;
        #[library("NTDSAPI.dll")]
        extern fn DsQuoteRdnValueW(cUnquotedRdnValueLength: u32, #[len_param(0)] psUnquotedRdnValue: *const u16, #[in] #[out] pcQuotedRdnValueLength: *mut u32, #[len_param(2)] psQuotedRdnValue: *mut u16) -> u32;
        #[library("NTDSAPI.dll")]
        extern fn DsUnquoteRdnValueA(cQuotedRdnValueLength: u32, #[len_param(0)] psQuotedRdnValue: *const i8, #[in] #[out] pcUnquotedRdnValueLength: *mut u32, #[len_param(2)] psUnquotedRdnValue: *mut i8) -> u32;
        #[library("NTDSAPI.dll")]

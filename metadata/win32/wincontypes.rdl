#[win32]
mod Windows {
    mod Win32 {
        const ALTNUMPAD_BIT: u32 = 67108864;
        const CAPSLOCK_ON: u32 = 128;
        struct CHAR_INFO {
            Char: union {
                UnicodeChar: u16,
                AsciiChar: i8,
            },
            Attributes: u16,
        }
        struct CONSOLE_FONT_INFO {
            nFont: u32,
            dwFontSize: COORD,
        }
        struct COORD {
            X: i16,
            Y: i16,
        }
        const DOUBLE_CLICK: u32 = 2;
        const ENHANCED_KEY: u32 = 256;
        const FOCUS_EVENT: u32 = 16;
        struct FOCUS_EVENT_RECORD {
            bSetFocus: BOOL,
        }
        const FROM_LEFT_1ST_BUTTON_PRESSED: u32 = 1;
        const FROM_LEFT_2ND_BUTTON_PRESSED: u32 = 4;
        const FROM_LEFT_3RD_BUTTON_PRESSED: u32 = 8;
        const FROM_LEFT_4TH_BUTTON_PRESSED: u32 = 16;
        type HPCON = *mut void;
        struct INPUT_RECORD {
            EventType: u16,
            Event: union {
                KeyEvent: KEY_EVENT_RECORD,
                MouseEvent: MOUSE_EVENT_RECORD,
                WindowBufferSizeEvent: WINDOW_BUFFER_SIZE_RECORD,
                MenuEvent: MENU_EVENT_RECORD,
                FocusEvent: FOCUS_EVENT_RECORD,
            },
        }
        const KEY_EVENT: u32 = 1;
        struct KEY_EVENT_RECORD {
            bKeyDown: BOOL,
            wRepeatCount: u16,
            wVirtualKeyCode: u16,
            wVirtualScanCode: u16,
            uChar: union {
                UnicodeChar: u16,
                AsciiChar: i8,
            },
            dwControlKeyState: u32,
        }
        const LEFT_ALT_PRESSED: u32 = 2;
        const LEFT_CTRL_PRESSED: u32 = 8;
        const MENU_EVENT: u32 = 8;
        struct MENU_EVENT_RECORD {
            dwCommandId: u32,
        }
        const MOUSE_EVENT: u32 = 2;
        struct MOUSE_EVENT_RECORD {
            dwMousePosition: COORD,
            dwButtonState: u32,
            dwControlKeyState: u32,
            dwEventFlags: u32,
        }
        const MOUSE_HWHEELED: u32 = 8;
        const MOUSE_MOVED: u32 = 1;
        const MOUSE_WHEELED: u32 = 4;
        const NLS_ALPHANUMERIC: u32 = 0;
        const NLS_DBCSCHAR: u32 = 65536;
        const NLS_HIRAGANA: u32 = 262144;
        const NLS_IME_CONVERSION: u32 = 8388608;
        const NLS_IME_DISABLE: u32 = 536870912;
        const NLS_KATAKANA: u32 = 131072;
        const NLS_ROMAN: u32 = 4194304;
        const NUMLOCK_ON: u32 = 32;
        type PCHAR_INFO = *mut CHAR_INFO;
        type PCONSOLE_FONT_INFO = *mut CONSOLE_FONT_INFO;
        type PCOORD = *mut COORD;
        type PFOCUS_EVENT_RECORD = *mut FOCUS_EVENT_RECORD;
        type PINPUT_RECORD = *mut INPUT_RECORD;
        type PKEY_EVENT_RECORD = *mut KEY_EVENT_RECORD;
        type PMENU_EVENT_RECORD = *mut MENU_EVENT_RECORD;
        type PMOUSE_EVENT_RECORD = *mut MOUSE_EVENT_RECORD;
        type PSMALL_RECT = *mut SMALL_RECT;
        type PWINDOW_BUFFER_SIZE_RECORD = *mut WINDOW_BUFFER_SIZE_RECORD;
        const RIGHTMOST_BUTTON_PRESSED: u32 = 2;
        const RIGHT_ALT_PRESSED: u32 = 1;
        const RIGHT_CTRL_PRESSED: u32 = 4;
        const SCROLLLOCK_ON: u32 = 64;
        const SHIFT_PRESSED: u32 = 16;
        struct SMALL_RECT {
            Left: i16,
            Top: i16,
            Right: i16,
            Bottom: i16,
        }
        const WINDOW_BUFFER_SIZE_EVENT: u32 = 4;
        struct WINDOW_BUFFER_SIZE_RECORD {
            dwSize: COORD,
        }
    }
}

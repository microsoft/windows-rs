        #[guid(0xe33affdc_59c7_47b1_97d5_4266598f6235)]
        interface IVssExpressWriter: IUnknown {
            fn CreateMetadata(&self, writerId: VSS_ID, writerName: PCWSTR, usageType: VSS_USAGE_TYPE, versionMajor: u32, versionMinor: u32, reserved: u32, ppMetadata: *mut IVssCreateExpressWriterMetadata) -> HRESULT;

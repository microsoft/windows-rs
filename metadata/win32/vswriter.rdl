        }
        #[no_guid]
        interface IVssWriterImpl: IUnknown {
            fn Initialize(&self, writerId: VSS_ID, wszWriterName: PCWSTR, #[opt] wszWriterInstanceName: PCWSTR, dwMajorVersion: u32, dwMinorVersion: u32, ut: VSS_USAGE_TYPE, st: VSS_SOURCE_TYPE, nLevel: VSS_APPLICATION_LEVEL, dwTimeout: u32, aws: VSS_ALTERNATE_WRITER_STATE, bIOThrottlingOnly: bool) -> HRESULT;
            fn Subscribe(&self, dwSubscribeTimeout: u32, dwEventFlags: u32) -> HRESULT;
            fn Unsubscribe(&self) -> HRESULT;
            fn Uninitialize(&self);
            fn GetCurrentVolumeArray(&self) -> *mut PCWSTR;
            fn GetCurrentVolumeCount(&self) -> u32;
            fn GetSnapshotDeviceName(&self, wszOriginalVolume: PCWSTR, ppwszSnapshotDevice: *mut PCWSTR) -> HRESULT;
            fn GetCurrentSnapshotSetId(&self) -> VSS_ID;
            fn GetContext(&self) -> i32;
            fn GetCurrentLevel(&self) -> VSS_APPLICATION_LEVEL;
            fn IsPathAffected(&self, wszPath: PCWSTR) -> bool;
            fn IsBootableSystemStateBackedUp(&self) -> bool;
            fn AreComponentsSelected(&self) -> bool;
            fn GetBackupType(&self) -> VSS_BACKUP_TYPE;
            fn GetRestoreType(&self) -> VSS_RESTORE_TYPE;
            fn SetWriterFailure(&self, hr: HRESULT) -> HRESULT;
            fn IsPartialFileSupportEnabled(&self) -> bool;
            fn InstallAlternateWriter(&self, idWriter: VSS_ID, clsid: GUID) -> HRESULT;
            fn GetIdentityInformation(&self) -> IVssExamineWriterMetadata;
            fn SetWriterFailureEx(&self, hr: HRESULT, hrApplication: HRESULT, wszApplicationMessage: PCWSTR) -> HRESULT;
            fn GetSessionId(&self, idSession: *mut VSS_ID) -> HRESULT;
            fn IsWriterShuttingDown(&self) -> bool;
        }

            fn AddComponentDependency(&self, wszForLogicalPath: PCWSTR, wszForComponentName: PCWSTR, onWriterId: VSS_ID, wszOnLogicalPath: PCWSTR, wszOnComponentName: PCWSTR) -> HRESULT;

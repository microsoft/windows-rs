#[win32]
mod Windows {
    mod Win32 {
        #[no_guid]
        interface CVssWriter {
            fn OnPrepareSnapshot(&self) -> bool;
            fn OnFreeze(&self) -> bool;
            fn OnThaw(&self) -> bool;
            fn OnAbort(&self) -> bool;
        }
        #[no_guid]
        interface CVssWriterEx: CVssWriter {}
        #[no_guid]
        interface CVssWriterEx2: CVssWriterEx {}
        #[library("VSSAPI.DLL")]
        extern fn CreateVssExpressWriterInternal(ppWriter: *mut IVssExpressWriter) -> HRESULT;

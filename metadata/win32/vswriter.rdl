            fn AddComponent(&self, ct: VSS_COMPONENT_TYPE, wszLogicalPath: PCWSTR, wszComponentName: PCWSTR, wszCaption: PCWSTR, pbIcon: *const u8, cbIcon: u32, bRestoreMetadata: bool, bNotifyOnBackupComplete: bool, bSelectable: bool, bSelectableForRestore: bool, dwComponentFlags: u32) -> HRESULT;

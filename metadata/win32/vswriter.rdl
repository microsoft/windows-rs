            fn AddDatabaseLogFiles(&self, wszLogicalPath: PCWSTR, wszDatabaseName: PCWSTR, wszPath: PCWSTR, wszFilespec: PCWSTR, dwBackupTypeMask: u32) -> HRESULT;

            fn SetRestoreMethod(&self, method: VSS_RESTOREMETHOD_ENUM, wszService: PCWSTR, wszUserProcedure: PCWSTR, writerRestore: VSS_WRITERRESTORE_ENUM, bRebootRequired: bool) -> HRESULT;
            fn AddComponentDependency(&self, wszForLogicalPath: PCWSTR, wszForComponentName: PCWSTR, onWriterId: VSS_ID, wszOnLogicalPath: PCWSTR, wszOnComponentName: PCWSTR) -> HRESULT;
            fn SetBackupSchema(&self, dwSchemaMask: u32) -> HRESULT;

        }
        struct REPL_INFO_1002 {
            rp1002_guardtime: u32,
        }
        struct REPL_INFO_1003 {
            rp1003_random: u32,
        }
        const REPL_INTEGRITY_FILE: u32 = 1;
        const REPL_INTEGRITY_TREE: u32 = 2;
        const REPL_INTERVAL_INFOLEVEL: u32 = 1000;
        const REPL_PULSE_INFOLEVEL: u32 = 1001;
        const REPL_RANDOM_INFOLEVEL: u32 = 1003;
        const REPL_ROLE_BOTH: u32 = 3;

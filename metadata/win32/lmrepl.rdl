        const REPL_EXPORT_EXTENT_INFOLEVEL: u32 = 1001;
        const REPL_EXPORT_INTEGRITY_INFOLEVEL: u32 = 1000;
        const REPL_EXTENT_FILE: u32 = 1;
        const REPL_EXTENT_TREE: u32 = 2;
        const REPL_GUARDTIME_INFOLEVEL: u32 = 1002;
        struct REPL_IDIR_INFO_0 {
            rpid0_dirname: PWSTR,
        }
        struct REPL_IDIR_INFO_1 {

        #[library("NETAPI32.dll")]
        extern fn NetReplImportDirGetInfo(servername: PCWSTR, dirname: PCWSTR, level: u32, bufptr: *mut LPBYTE) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplImportDirLock(servername: PCWSTR, dirname: PCWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplImportDirUnlock(servername: PCWSTR, dirname: PCWSTR, unlockforce: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplSetInfo(servername: PCWSTR, level: u32, buf: *mut u8, parm_err: *mut u32) -> u32;
        type PREPL_EDIR_INFO_0 = *mut REPL_EDIR_INFO_0;
        type PREPL_EDIR_INFO_1 = *mut REPL_EDIR_INFO_1;
        type PREPL_EDIR_INFO_1000 = *mut REPL_EDIR_INFO_1000;
        type PREPL_EDIR_INFO_1001 = *mut REPL_EDIR_INFO_1001;
        type PREPL_EDIR_INFO_2 = *mut REPL_EDIR_INFO_2;
        type PREPL_IDIR_INFO_0 = *mut REPL_IDIR_INFO_0;
        type PREPL_IDIR_INFO_1 = *mut REPL_IDIR_INFO_1;
        type PREPL_INFO_0 = *mut REPL_INFO_0;
        type PREPL_INFO_1000 = *mut REPL_INFO_1000;
        type PREPL_INFO_1001 = *mut REPL_INFO_1001;
        type PREPL_INFO_1002 = *mut REPL_INFO_1002;
        type PREPL_INFO_1003 = *mut REPL_INFO_1003;
        struct REPL_EDIR_INFO_0 {
            rped0_dirname: PWSTR,

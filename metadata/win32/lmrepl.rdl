        type LPREPL_EDIR_INFO_2 = *mut REPL_EDIR_INFO_2;
        type LPREPL_IDIR_INFO_0 = *mut REPL_IDIR_INFO_0;
        type LPREPL_IDIR_INFO_1 = *mut REPL_IDIR_INFO_1;

#[win32]
mod Windows {
    mod Win32 {
        type LPREPL_EDIR_INFO_0 = *mut REPL_EDIR_INFO_0;
        type LPREPL_EDIR_INFO_1 = *mut REPL_EDIR_INFO_1;
        type LPREPL_EDIR_INFO_1000 = *mut REPL_EDIR_INFO_1000;

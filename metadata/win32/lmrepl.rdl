        type LPREPL_INFO_1002 = *mut REPL_INFO_1002;
        type LPREPL_INFO_1003 = *mut REPL_INFO_1003;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirAdd(servername: PCWSTR, level: u32, buf: *mut u8, parm_err: *mut u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirDel(servername: PCWSTR, dirname: PCWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirEnum(servername: PCWSTR, level: u32, bufptr: *mut LPBYTE, prefmaxlen: u32, entriesread: *mut u32, totalentries: *mut u32, resumehandle: *mut u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirGetInfo(servername: PCWSTR, dirname: PCWSTR, level: u32, bufptr: *mut LPBYTE) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirLock(servername: PCWSTR, dirname: PCWSTR) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirSetInfo(servername: PCWSTR, dirname: PCWSTR, level: u32, buf: *mut u8, parm_err: *mut u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplExportDirUnlock(servername: PCWSTR, dirname: PCWSTR, unlockforce: u32) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplGetInfo(servername: PCWSTR, level: u32, bufptr: *mut LPBYTE) -> u32;
        #[library("NETAPI32.dll")]
        extern fn NetReplImportDirAdd(servername: PCWSTR, level: u32, buf: *mut u8, parm_err: *mut u32) -> u32;

#[win32]
mod Windows {
    mod Win32 {
        const BALLPOINT_I8042_HARDWARE: u32 = 8;
        const BALLPOINT_SERIAL_HARDWARE: u32 = 16;
        #[encoding("ansi")]
        const DD_MOUSE_DEVICE_NAME: String = "\\Device\\PointerClass";
        #[encoding("utf-16")]
        const DD_MOUSE_DEVICE_NAME_U: String = "\\Device\\PointerClass";
        const GUID_DEVINTERFACE_MOUSE: GUID = 0x378de44c_56ef_11d1_bc8c_00a0c91405dd;
        const HORIZONTAL_WHEEL_PRESENT: u32 = 32768;
        const IOCTL_MOUSE_INSERT_DATA: u32 = 983044;
        const IOCTL_MOUSE_QUERY_ATTRIBUTES: u32 = 983040;
        struct MOUSE_ATTRIBUTES {
            MouseIdentifier: u16,
            NumberOfButtons: u16,
            SampleRate: u16,
            InputDataQueueLength: u32,
        }
        const MOUSE_BUTTON_1_DOWN: u32 = 1;
        const MOUSE_BUTTON_1_UP: u32 = 2;
        const MOUSE_BUTTON_2_DOWN: u32 = 4;
        const MOUSE_BUTTON_2_UP: u32 = 8;
        const MOUSE_BUTTON_3_DOWN: u32 = 16;
        const MOUSE_BUTTON_3_UP: u32 = 32;
        const MOUSE_BUTTON_4_DOWN: u32 = 64;
        const MOUSE_BUTTON_4_UP: u32 = 128;
        const MOUSE_BUTTON_5_DOWN: u32 = 256;
        const MOUSE_BUTTON_5_UP: u32 = 512;
        const MOUSE_ERROR_VALUE_BASE: u32 = 20000;
        const MOUSE_HID_HARDWARE: u32 = 128;
        const MOUSE_HWHEEL: u32 = 2048;
        const MOUSE_I8042_HARDWARE: u32 = 2;
        const MOUSE_INPORT_HARDWARE: u32 = 1;
        struct MOUSE_INPUT_DATA {
            UnitId: u16,
            Flags: u16,
            Anonymous: union {
                Buttons: u32,
                Anonymous: struct {
                    ButtonFlags: u16,
                    ButtonData: u16,
                },
            },
            RawButtons: u32,
            LastX: i32,
            LastY: i32,
            ExtraInformation: u32,
        }
        const MOUSE_LEFT_BUTTON_DOWN: u32 = 1;
        const MOUSE_LEFT_BUTTON_UP: u32 = 2;
        const MOUSE_MIDDLE_BUTTON_DOWN: u32 = 16;
        const MOUSE_MIDDLE_BUTTON_UP: u32 = 32;
        const MOUSE_RIGHT_BUTTON_DOWN: u32 = 4;
        const MOUSE_RIGHT_BUTTON_UP: u32 = 8;
        const MOUSE_SERIAL_HARDWARE: u32 = 4;
        const MOUSE_TERMSRV_SRC_SHADOW: u32 = 256;
        struct MOUSE_UNIT_ID_PARAMETER {
            UnitId: u16,
        }
        const MOUSE_WHEEL: u32 = 1024;
        type PMOUSE_ATTRIBUTES = *mut MOUSE_ATTRIBUTES;
        type PMOUSE_INPUT_DATA = *mut MOUSE_INPUT_DATA;
        type PMOUSE_UNIT_ID_PARAMETER = *mut MOUSE_UNIT_ID_PARAMETER;
        const WHEELMOUSE_HID_HARDWARE: u32 = 256;
        const WHEELMOUSE_I8042_HARDWARE: u32 = 32;
        const WHEELMOUSE_SERIAL_HARDWARE: u32 = 64;
    }
}

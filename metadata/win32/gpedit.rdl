            fn GetMachineName(&self, #[len_param(1)] #[out] pszName: PWSTR, cchMaxLength: i32) -> HRESULT;
            fn GetPropertySheetPages(&self, hPages: *mut *mut HPROPSHEETPAGE, uPageCount: *mut u32) -> HRESULT;
        }

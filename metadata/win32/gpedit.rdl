        #[guid(0x8fc0b735_a0e1_11d1_a7d3_0000f87571e3)]
        interface IGPEInformation: IUnknown {
            fn QueryInterface(&self, riid: *const GUID, ppvObj: *mut *mut void) -> HRESULT;
            fn AddRef(&self) -> u32;

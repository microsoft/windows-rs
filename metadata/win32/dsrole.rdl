#[win32]
mod Windows {
    mod Win32 {
        #[repr(i32)]
        enum DSROLE_MACHINE_ROLE {
            DsRole_RoleStandaloneWorkstation = 0,
            DsRole_RoleMemberWorkstation = 1,
            DsRole_RoleStandaloneServer = 2,
            DsRole_RoleMemberServer = 3,
            DsRole_RoleBackupDomainController = 4,
            DsRole_RolePrimaryDomainController = 5,
        }
        #[repr(i32)]
        enum DSROLE_OPERATION_STATE {
            DsRoleOperationIdle = 0,
            DsRoleOperationActive = 1,
            DsRoleOperationNeedReboot = 2,
        }
        struct DSROLE_OPERATION_STATE_INFO {
            OperationState: DSROLE_OPERATION_STATE,
        }
        const DSROLE_PRIMARY_DOMAIN_GUID_PRESENT: u32 = 16777216;
        struct DSROLE_PRIMARY_DOMAIN_INFO_BASIC {
            MachineRole: DSROLE_MACHINE_ROLE,
            Flags: u32,
            DomainNameFlat: PWSTR,
            DomainNameDns: PWSTR,
            DomainForestName: PWSTR,
            DomainGuid: GUID,
        }
        #[repr(i32)]
        enum DSROLE_PRIMARY_DOMAIN_INFO_LEVEL {
            DsRolePrimaryDomainInfoBasic = 1,
            DsRoleUpgradeStatus = 2,
            DsRoleOperationState = 3,
        }
        const DSROLE_PRIMARY_DS_MIXED_MODE: u32 = 2;
        const DSROLE_PRIMARY_DS_READONLY: u32 = 8;
        const DSROLE_PRIMARY_DS_RUNNING: u32 = 1;
        #[repr(i32)]
        enum DSROLE_SERVER_STATE {
            DsRoleServerUnknown = 0,
            DsRoleServerPrimary = 1,
            DsRoleServerBackup = 2,
        }
        const DSROLE_UPGRADE_IN_PROGRESS: u32 = 4;
        struct DSROLE_UPGRADE_STATUS_INFO {
            OperationState: u32,
            PreviousServerState: DSROLE_SERVER_STATE,
        }
        #[library("NETAPI32.dll")]
        extern fn DsRoleFreeMemory(Buffer: *mut void);
        #[library("NETAPI32.dll")]
        extern fn DsRoleGetPrimaryDomainInformation(lpServer: PCWSTR, InfoLevel: DSROLE_PRIMARY_DOMAIN_INFO_LEVEL, Buffer: *mut PBYTE) -> u32;
        type PDSROLE_OPERATION_STATE_INFO = *mut DSROLE_OPERATION_STATE_INFO;
        type PDSROLE_PRIMARY_DOMAIN_INFO_BASIC = *mut DSROLE_PRIMARY_DOMAIN_INFO_BASIC;
        type PDSROLE_SERVER_STATE = *mut DSROLE_SERVER_STATE;
        type PDSROLE_UPGRADE_STATUS_INFO = *mut DSROLE_UPGRADE_STATUS_INFO;
    }
}

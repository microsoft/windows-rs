#[win32]
mod Windows {
    mod Win32 {
        const PIDDI_THUMBNAIL: u32 = 2;
        const PIDDSI_BYTECOUNT: u32 = 4;
        const PIDDSI_CATEGORY: u32 = 2;
        const PIDDSI_COMPANY: u32 = 15;
        const PIDDSI_DOCPARTS: u32 = 13;
        const PIDDSI_HEADINGPAIR: u32 = 12;
        const PIDDSI_HIDDENCOUNT: u32 = 9;
        const PIDDSI_LINECOUNT: u32 = 5;
        const PIDDSI_LINKSDIRTY: u32 = 16;
        const PIDDSI_MANAGER: u32 = 14;
        const PIDDSI_MMCLIPCOUNT: u32 = 10;
        const PIDDSI_NOTECOUNT: u32 = 8;
        const PIDDSI_PARCOUNT: u32 = 6;
        const PIDDSI_PRESFORMAT: u32 = 3;
        const PIDDSI_SCALE: u32 = 11;
        const PIDDSI_SLIDECOUNT: u32 = 7;
        const PIDMSI_COPYRIGHT: u32 = 11;
        const PIDMSI_EDITOR: u32 = 2;
        const PIDMSI_OWNER: u32 = 8;
        const PIDMSI_PRODUCTION: u32 = 10;
        const PIDMSI_PROJECT: u32 = 6;
        const PIDMSI_RATING: u32 = 9;
        const PIDMSI_SEQUENCE_NO: u32 = 5;
        const PIDMSI_SOURCE: u32 = 4;
        const PIDMSI_STATUS: u32 = 7;
        #[repr(i32)]
        enum PIDMSI_STATUS_VALUE {
            PIDMSI_STATUS_NORMAL = 0,
            PIDMSI_STATUS_NEW = 1,
            PIDMSI_STATUS_PRELIM = 2,
            PIDMSI_STATUS_DRAFT = 3,
            PIDMSI_STATUS_INPROGRESS = 4,
            PIDMSI_STATUS_EDIT = 5,
            PIDMSI_STATUS_REVIEW = 6,
            PIDMSI_STATUS_PROOF = 7,
            PIDMSI_STATUS_FINAL = 8,
            PIDMSI_STATUS_OTHER = 32767,
        }
        const PIDMSI_SUPPLIER: u32 = 3;
        const PIDSI_APPNAME: u32 = 18;
        const PIDSI_AUTHOR: u32 = 4;
        const PIDSI_CHARCOUNT: u32 = 16;
        const PIDSI_COMMENTS: u32 = 6;
        const PIDSI_CREATE_DTM: u32 = 12;
        const PIDSI_DOC_SECURITY: u32 = 19;
        const PIDSI_EDITTIME: u32 = 10;
        const PIDSI_KEYWORDS: u32 = 5;
        const PIDSI_LASTAUTHOR: u32 = 8;
        const PIDSI_LASTPRINTED: u32 = 11;
        const PIDSI_LASTSAVE_DTM: u32 = 13;
        const PIDSI_PAGECOUNT: u32 = 14;
        const PIDSI_REVNUMBER: u32 = 9;
        const PIDSI_SUBJECT: u32 = 3;
        const PIDSI_TEMPLATE: u32 = 7;
        const PIDSI_THUMBNAIL: u32 = 17;
        const PIDSI_TITLE: u32 = 2;
        const PIDSI_WORDCOUNT: u32 = 15;
        struct PMemoryAllocator {}
        struct SERIALIZEDPROPERTYVALUE {
            dwType: u32,
            rgb: [u8; 1],
        }
        #[library("ole32.dll")]
        extern fn StgConvertPropertyToVariant(pprop: *const SERIALIZEDPROPERTYVALUE, CodePage: u16, pvar: *mut PROPVARIANT, pma: *const PMemoryAllocator) -> BOOLEAN;
        #[library("ole32.dll")]
        extern fn StgConvertVariantToProperty(pvar: *const PROPVARIANT, CodePage: u16, #[size_param(3)] #[opt] pprop: *mut SERIALIZEDPROPERTYVALUE, #[in] #[out] pcb: *mut u32, pid: PROPID, #[reserved] fReserved: BOOLEAN, #[in] #[out] #[opt] pcIndirect: *mut u32) -> *mut SERIALIZEDPROPERTYVALUE;
    }
}

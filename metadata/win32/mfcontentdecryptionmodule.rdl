            fn GetKeyStatuses(&self, keyStatuses: *mut *mut MFMediaKeyStatus, numKeyStatuses: *mut u32) -> HRESULT;
            fn Load(&self, sessionId: PCWSTR, loaded: *mut BOOL) -> HRESULT;
            fn GenerateRequest(&self, initDataType: PCWSTR, initData: *const u8, initDataSize: u32) -> HRESULT;
            fn Update(&self, response: *const u8, responseSize: u32) -> HRESULT;
            fn Close(&self) -> HRESULT;
            fn Remove(&self) -> HRESULT;
        }
        #[guid(0x3f96ee40_ad81_4096_8470_59a4b770f89a)]
        interface IMFContentDecryptionModuleSessionCallbacks: IUnknown {

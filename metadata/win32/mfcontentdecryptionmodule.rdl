        }
        #[library("MF.dll")]
        extern fn MFCreateEncryptedMediaExtensionsStoreActivate(pmpHost: IMFPMPHostApp, objectStream: IStream, classId: PCWSTR, activate: *mut IMFActivate) -> HRESULT;

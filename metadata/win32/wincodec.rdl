            fn GetFileExtensions(&self, cchFileExtensions: u32, #[in] #[out] wzFileExtensions: *mut u16, pcchActual: *mut u32) -> HRESULT;
            fn DoesSupportAnimation(&self, pfSupportAnimation: *mut BOOL) -> HRESULT;
            fn DoesSupportChromakey(&self, pfSupportChromakey: *mut BOOL) -> HRESULT;
            fn DoesSupportLossless(&self, pfSupportLossless: *mut BOOL) -> HRESULT;
            fn DoesSupportMultiframe(&self, pfSupportMultiframe: *mut BOOL) -> HRESULT;

#[win32]
mod Windows {
    mod Win32 {
        #[library("WINMM.dll")]
        extern fn PlaySoundA(#[opt] pszSound: PCSTR, #[opt] hmod: HMODULE, fdwSound: u32) -> BOOL;
        #[library("WINMM.dll")]
        extern fn PlaySoundW(#[opt] pszSound: PCWSTR, #[opt] hmod: HMODULE, fdwSound: u32) -> BOOL;
        const SND_ALIAS: u32 = 65536;
        const SND_ALIAS_ID: u32 = 1114112;
        const SND_ALIAS_START: u32 = 0;
        const SND_ALIAS_SYSTEMASTERISK: u32 = 10835;
        const SND_ALIAS_SYSTEMDEFAULT: u32 = 17491;
        const SND_ALIAS_SYSTEMEXCLAMATION: u32 = 8531;
        const SND_ALIAS_SYSTEMEXIT: u32 = 17747;
        const SND_ALIAS_SYSTEMHAND: u32 = 18515;
        const SND_ALIAS_SYSTEMQUESTION: u32 = 16211;
        const SND_ALIAS_SYSTEMSTART: u32 = 21331;
        const SND_ALIAS_SYSTEMWELCOME: u32 = 22355;
        const SND_APPLICATION: u32 = 128;
        const SND_ASYNC: u32 = 1;
        const SND_FILENAME: u32 = 131072;
        const SND_LOOP: u32 = 8;
        const SND_MEMORY: u32 = 4;
        const SND_NODEFAULT: u32 = 2;
        const SND_NOSTOP: u32 = 16;
        const SND_NOWAIT: u32 = 8192;
        const SND_PURGE: u32 = 64;
        const SND_RESOURCE: u32 = 262148;
        const SND_RING: u32 = 1048576;
        const SND_SENTRY: u32 = 524288;
        const SND_SYNC: u32 = 0;
        const SND_SYSTEM: u32 = 2097152;
        #[library("WINMM.dll")]
        extern fn sndPlaySoundA(#[opt] pszSound: PCSTR, fuSound: u32) -> BOOL;
        #[library("WINMM.dll")]
        extern fn sndPlaySoundW(#[opt] pszSound: PCWSTR, fuSound: u32) -> BOOL;
    }
}

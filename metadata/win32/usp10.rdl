            #[bitfield("fWordStop", 3, 1)]
            #[bitfield("fInvalid", 4, 1)]
            #[bitfield("fReserved", 5, 3)]
            _bitfield: u8,
        }
        struct SCRIPT_PROPERTIES {
            #[bitfield("langid", 0, 16)]
            #[bitfield("fNumeric", 16, 1)]
            #[bitfield("fComplex", 17, 1)]
            #[bitfield("fNeedsWordBreaking", 18, 1)]
            #[bitfield("fNeedsCaretInfo", 19, 1)]
            #[bitfield("bCharSet", 20, 8)]

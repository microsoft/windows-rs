            #[bitfield("fLegacyBidiClass", 23, 1)]
            #[bitfield("fMergeNeutralItems", 24, 1)]
            #[bitfield("fUseStandardBidi", 25, 1)]
            #[bitfield("fReserved", 26, 6)]

        }
        type OPENTYPE_TAG = u32;
        struct SCRIPT_ANALYSIS {
            #[bitfield("eScript", 0, 10)]
            #[bitfield("fRTL", 10, 1)]
            #[bitfield("fLayoutRTL", 11, 1)]
            #[bitfield("fLinkBefore", 12, 1)]
            #[bitfield("fLinkAfter", 13, 1)]
            #[bitfield("fLogicalOrder", 14, 1)]
            #[bitfield("fNoGlyphIndex", 15, 1)]
            _bitfield: u16,
            s: SCRIPT_STATE,
        }
        type SCRIPT_CACHE = *mut void;
        struct SCRIPT_CHARPROP {
            #[bitfield("fCanGlyphAlone", 0, 1)]

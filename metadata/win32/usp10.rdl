        }
        const SCRIPT_DIGITSUBSTITUTE_CONTEXT: u32 = 0;
        const SCRIPT_DIGITSUBSTITUTE_NATIONAL: u32 = 2;
        const SCRIPT_DIGITSUBSTITUTE_NONE: u32 = 1;
        const SCRIPT_DIGITSUBSTITUTE_TRADITIONAL: u32 = 3;

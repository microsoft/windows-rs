            #[bitfield("fPrivateUseArea", 29, 1)]
            #[bitfield("fNeedsCharacterJustify", 30, 1)]
            #[bitfield("fInvalidGlyph", 31, 1)]
            _bitfield1: u32,
            #[bitfield("fInvalidLogAttr", 0, 1)]
            #[bitfield("fCDM", 1, 1)]
            #[bitfield("fAmbiguousCharSet", 2, 1)]
            #[bitfield("fClusterSizeVaries", 3, 1)]
            #[bitfield("fRejectInvalid", 4, 1)]
            _bitfield2: u32,
        }
        struct SCRIPT_STATE {
            #[bitfield("uBidiLevel", 0, 5)]
            #[bitfield("fOverrideDirection", 5, 1)]
            #[bitfield("fInhibitSymSwap", 6, 1)]
            #[bitfield("fCharShape", 7, 1)]
            #[bitfield("fDigitSubstitute", 8, 1)]

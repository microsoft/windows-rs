        const VK_PAD_RSHOULDER: u32 = 22532;
        const VK_PAD_RTHUMB_DOWN: u32 = 22577;
        const VK_PAD_RTHUMB_DOWNLEFT: u32 = 22583;
        const VK_PAD_RTHUMB_DOWNRIGHT: u32 = 22582;
        const VK_PAD_RTHUMB_LEFT: u32 = 22579;
        const VK_PAD_RTHUMB_PRESS: u32 = 22551;
        const VK_PAD_RTHUMB_RIGHT: u32 = 22578;
        const VK_PAD_RTHUMB_UP: u32 = 22576;
        const VK_PAD_RTHUMB_UPLEFT: u32 = 22580;
        const VK_PAD_RTHUMB_UPRIGHT: u32 = 22581;
        const VK_PAD_RTRIGGER: u32 = 22535;
        const VK_PAD_START: u32 = 22548;
        const VK_PAD_X: u32 = 22530;
        const VK_PAD_Y: u32 = 22531;
        struct XINPUT_BATTERY_INFORMATION {
            BatteryType: u8,
            BatteryLevel: u8,
        }
        struct XINPUT_CAPABILITIES {
            Type: u8,
            SubType: u8,
            Flags: u16,
            Gamepad: XINPUT_GAMEPAD,
            Vibration: XINPUT_VIBRATION,
        }
        const XINPUT_CAPS_FFB_SUPPORTED: u32 = 1;
        const XINPUT_CAPS_NO_NAVIGATION: u32 = 16;
        const XINPUT_CAPS_PMD_SUPPORTED: u32 = 8;
        const XINPUT_CAPS_VOICE_SUPPORTED: u32 = 4;
        const XINPUT_CAPS_WIRELESS: u32 = 2;
        const XINPUT_DEVSUBTYPE_ARCADE_PAD: u32 = 19;
        const XINPUT_DEVSUBTYPE_ARCADE_STICK: u32 = 3;
        const XINPUT_DEVSUBTYPE_DANCE_PAD: u32 = 5;
        const XINPUT_DEVSUBTYPE_DRUM_KIT: u32 = 8;
        const XINPUT_DEVSUBTYPE_FLIGHT_STICK: u32 = 4;
        const XINPUT_DEVSUBTYPE_GAMEPAD: u32 = 1;
        const XINPUT_DEVSUBTYPE_GUITAR: u32 = 6;
        const XINPUT_DEVSUBTYPE_GUITAR_ALTERNATE: u32 = 7;
        const XINPUT_DEVSUBTYPE_GUITAR_BASS: u32 = 11;
        const XINPUT_DEVSUBTYPE_UNKNOWN: u32 = 0;
        const XINPUT_DEVSUBTYPE_WHEEL: u32 = 2;
        const XINPUT_DEVTYPE_GAMEPAD: u32 = 1;
        #[encoding("ansi")]
        const XINPUT_DLL_A: String = "xinput1_4.dll";
        #[encoding("utf-16")]
        const XINPUT_DLL_W: String = "xinput1_4.dll";
        const XINPUT_FLAG_GAMEPAD: u32 = 1;
        struct XINPUT_GAMEPAD {
            wButtons: u16,
            bLeftTrigger: u8,
            bRightTrigger: u8,
            sThumbLX: i16,
            sThumbLY: i16,
            sThumbRX: i16,
            sThumbRY: i16,
        }
        const XINPUT_GAMEPAD_A: u32 = 4096;
        const XINPUT_GAMEPAD_B: u32 = 8192;
        const XINPUT_GAMEPAD_BACK: u32 = 32;
        const XINPUT_GAMEPAD_DPAD_DOWN: u32 = 2;
        const XINPUT_GAMEPAD_DPAD_LEFT: u32 = 4;
        const XINPUT_GAMEPAD_DPAD_RIGHT: u32 = 8;
        const XINPUT_GAMEPAD_DPAD_UP: u32 = 1;
        const XINPUT_GAMEPAD_LEFT_SHOULDER: u32 = 256;
        const XINPUT_GAMEPAD_LEFT_THUMB: u32 = 64;
        const XINPUT_GAMEPAD_LEFT_THUMB_DEADZONE: u32 = 7849;
        const XINPUT_GAMEPAD_RIGHT_SHOULDER: u32 = 512;
        const XINPUT_GAMEPAD_RIGHT_THUMB: u32 = 128;
        const XINPUT_GAMEPAD_RIGHT_THUMB_DEADZONE: u32 = 8689;
        const XINPUT_GAMEPAD_START: u32 = 16;
        const XINPUT_GAMEPAD_TRIGGER_THRESHOLD: u32 = 30;
        const XINPUT_GAMEPAD_X: u32 = 16384;
        const XINPUT_GAMEPAD_Y: u32 = 32768;
        struct XINPUT_KEYSTROKE {
            VirtualKey: u16,
            Unicode: u16,
            Flags: u16,
            UserIndex: u8,
            HidCode: u8,
        }
        const XINPUT_KEYSTROKE_KEYDOWN: u32 = 1;
        const XINPUT_KEYSTROKE_KEYUP: u32 = 2;
        const XINPUT_KEYSTROKE_REPEAT: u32 = 4;
        struct XINPUT_STATE {
            dwPacketNumber: u32,
            Gamepad: XINPUT_GAMEPAD,
        }
        struct XINPUT_VIBRATION {
            wLeftMotorSpeed: u16,
            wRightMotorSpeed: u16,
        }
        #[library("XINPUT1_4.dll")]
        extern fn XInputEnable(enable: BOOL);
        #[library("XINPUT1_4.dll")]
        extern fn XInputGetAudioDeviceIds(dwUserIndex: u32, #[len_param(2)] #[out] #[opt] pRenderDeviceId: PWSTR, #[in] #[out] #[opt] pRenderCount: *mut u32, #[len_param(4)] #[out] #[opt] pCaptureDeviceId: PWSTR, #[in] #[out] #[opt] pCaptureCount: *mut u32) -> u32;
        #[library("XINPUT1_4.dll")]
        extern fn XInputGetBatteryInformation(dwUserIndex: u32, devType: u8, pBatteryInformation: *mut XINPUT_BATTERY_INFORMATION) -> u32;
        #[library("XINPUT1_4.dll")]
        extern fn XInputGetCapabilities(dwUserIndex: u32, dwFlags: u32, pCapabilities: *mut XINPUT_CAPABILITIES) -> u32;
        #[library("XINPUT1_4.dll")]
        extern fn XInputGetKeystroke(dwUserIndex: u32, #[reserved] dwReserved: u32, pKeystroke: *mut XINPUT_KEYSTROKE) -> u32;
        #[library("XINPUT1_4.dll")]
        extern fn XInputGetState(dwUserIndex: u32, pState: *mut XINPUT_STATE) -> u32;
        #[library("XINPUT1_4.dll")]
        extern fn XInputSetState(dwUserIndex: u32, pVibration: *const XINPUT_VIBRATION) -> u32;
        const XUSER_INDEX_ANY: u32 = 255;
        const XUSER_MAX_COUNT: u32 = 4;
    }
}

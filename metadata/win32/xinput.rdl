#[win32]
mod Windows {
    mod Win32 {
        const BATTERY_DEVTYPE_GAMEPAD: u32 = 0;
        const BATTERY_DEVTYPE_HEADSET: u32 = 1;
        const BATTERY_LEVEL_EMPTY: u32 = 0;
        const BATTERY_LEVEL_FULL: u32 = 3;
        const BATTERY_LEVEL_LOW: u32 = 1;
        const BATTERY_LEVEL_MEDIUM: u32 = 2;
        const BATTERY_TYPE_ALKALINE: u32 = 2;
        const BATTERY_TYPE_DISCONNECTED: u32 = 0;
        const BATTERY_TYPE_NIMH: u32 = 3;
        const BATTERY_TYPE_UNKNOWN: u32 = 255;
        const BATTERY_TYPE_WIRED: u32 = 1;
        type PXINPUT_BATTERY_INFORMATION = *mut XINPUT_BATTERY_INFORMATION;
        type PXINPUT_CAPABILITIES = *mut XINPUT_CAPABILITIES;
        type PXINPUT_GAMEPAD = *mut XINPUT_GAMEPAD;
        type PXINPUT_KEYSTROKE = *mut XINPUT_KEYSTROKE;
        type PXINPUT_STATE = *mut XINPUT_STATE;
        type PXINPUT_VIBRATION = *mut XINPUT_VIBRATION;
        const VK_PAD_A: u32 = 22528;

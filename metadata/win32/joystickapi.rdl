        type LPJOYCAPS = LPJOYCAPSA;
        type LPJOYCAPS2 = LPJOYCAPS2A;
        type LPJOYCAPS2A = *mut JOYCAPS2A;
        type LPJOYCAPS2W = *mut JOYCAPS2W;

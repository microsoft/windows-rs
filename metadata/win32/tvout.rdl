#[win32]
mod Windows {
    mod Win32 {
        type LPVIDEOPARAMETERS = *mut VIDEOPARAMETERS;
        type PVIDEOPARAMETERS = *mut VIDEOPARAMETERS;
        struct VIDEOPARAMETERS {
            Guid: GUID,
            dwOffset: u32,
            dwCommand: u32,
            dwFlags: u32,
            dwMode: u32,
            dwTVStandard: u32,
            dwAvailableModes: u32,
            dwAvailableTVStandard: u32,
            dwFlickerFilter: u32,
            dwOverScanX: u32,
            dwOverScanY: u32,
            dwMaxUnscaledX: u32,
            dwMaxUnscaledY: u32,
            dwPositionX: u32,
            dwPositionY: u32,
            dwBrightness: u32,
            dwContrast: u32,
            dwCPType: u32,
            dwCPCommand: u32,
            dwCPStandard: u32,
            dwCPKey: u32,
            bCP_APSTriggerBits: u32,
            bOEMCopyProtection: [u8; 256],
        }
        const VP_COMMAND_GET: u32 = 1;
        const VP_COMMAND_SET: u32 = 2;
        const VP_CP_CMD_ACTIVATE: u32 = 1;
        const VP_CP_CMD_CHANGE: u32 = 4;
        const VP_CP_CMD_DEACTIVATE: u32 = 2;
        const VP_CP_TYPE_APS_TRIGGER: u32 = 1;
        const VP_CP_TYPE_MACROVISION: u32 = 2;
        const VP_FLAGS_BRIGHTNESS: u32 = 64;
        const VP_FLAGS_CONTRAST: u32 = 128;
        const VP_FLAGS_COPYPROTECT: u32 = 256;
        const VP_FLAGS_FLICKER: u32 = 4;
        const VP_FLAGS_MAX_UNSCALED: u32 = 16;
        const VP_FLAGS_OVERSCAN: u32 = 8;
        const VP_FLAGS_POSITION: u32 = 32;
        const VP_FLAGS_TV_MODE: u32 = 1;
        const VP_FLAGS_TV_STANDARD: u32 = 2;
        const VP_MODE_TV_PLAYBACK: u32 = 2;
        const VP_MODE_WIN_GRAPHICS: u32 = 1;
        const VP_TV_STANDARD_NTSC_433: u32 = 65536;
        const VP_TV_STANDARD_NTSC_M: u32 = 1;
        const VP_TV_STANDARD_NTSC_M_J: u32 = 2;
        const VP_TV_STANDARD_PAL_60: u32 = 262144;
        const VP_TV_STANDARD_PAL_B: u32 = 4;
        const VP_TV_STANDARD_PAL_D: u32 = 8;
        const VP_TV_STANDARD_PAL_G: u32 = 131072;
        const VP_TV_STANDARD_PAL_H: u32 = 16;
        const VP_TV_STANDARD_PAL_I: u32 = 32;
        const VP_TV_STANDARD_PAL_M: u32 = 64;
        const VP_TV_STANDARD_PAL_N: u32 = 128;
        const VP_TV_STANDARD_SECAM_B: u32 = 256;
        const VP_TV_STANDARD_SECAM_D: u32 = 512;
        const VP_TV_STANDARD_SECAM_G: u32 = 1024;
        const VP_TV_STANDARD_SECAM_H: u32 = 2048;
        const VP_TV_STANDARD_SECAM_K: u32 = 4096;
        const VP_TV_STANDARD_SECAM_K1: u32 = 8192;
        const VP_TV_STANDARD_SECAM_L: u32 = 16384;
        const VP_TV_STANDARD_SECAM_L1: u32 = 524288;
        const VP_TV_STANDARD_WIN_VGA: u32 = 32768;
    }
}

        }
        struct WIN32_MEMORY_PARTITION_INFORMATION {
            Flags: u32,
            NumaNode: u32,
            Channel: u32,
            NumberOfNumaNodes: u32,
            ResidentAvailablePages: u64,
            CommittedPages: u64,
            CommitLimit: u64,

            VirtualAddress: *mut void,
            NumberOfBytes: usize,
        }
        struct WIN32_MEMORY_REGION_INFORMATION {
            AllocationBase: *mut void,
            AllocationProtect: u32,
            Anonymous: union {
                Flags: u32,
                Anonymous: struct {
                    _bitfield: u32 {
                        Private: 1,
                        MappedDataFile: 1,
                        MappedImage: 1,
                        MappedPageFile: 1,
                        MappedPhysical: 1,
                        DirectMapped: 1,
                        Reserved: 26,

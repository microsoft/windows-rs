#[win32]
mod Windows {
    mod Win32 {
        struct DYNAMIC_TIME_ZONE_INFORMATION {
            Bias: i32,
            StandardName: [u16; 32],
            StandardDate: SYSTEMTIME,
            StandardBias: i32,
            DaylightName: [u16; 32],
            DaylightDate: SYSTEMTIME,
            DaylightBias: i32,
            TimeZoneKeyName: [u16; 128],
            DynamicDaylightTimeDisabled: BOOLEAN,
        }
        #[library("ADVAPI32.dll")]
        extern fn EnumDynamicTimeZoneInformation(dwIndex: u32, lpTimeZoneInformation: *mut DYNAMIC_TIME_ZONE_INFORMATION) -> u32;
        #[library("KERNEL32.dll")]
        extern fn FileTimeToSystemTime(lpFileTime: *const FILETIME, lpSystemTime: *mut SYSTEMTIME) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn GetDynamicTimeZoneInformation(pTimeZoneInformation: *mut DYNAMIC_TIME_ZONE_INFORMATION) -> u32;
        #[library("ADVAPI32.dll")]
        extern fn GetDynamicTimeZoneInformationEffectiveYears(lpTimeZoneInformation: *const DYNAMIC_TIME_ZONE_INFORMATION, FirstYear: *mut u32, LastYear: *mut u32) -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetTimeZoneInformation(lpTimeZoneInformation: *mut TIME_ZONE_INFORMATION) -> u32;
        #[library("KERNEL32.dll")]
        extern fn GetTimeZoneInformationForYear(wYear: u16, #[opt] pdtzi: *const DYNAMIC_TIME_ZONE_INFORMATION, ptzi: *mut TIME_ZONE_INFORMATION) -> BOOL;
        type LPTIME_ZONE_INFORMATION = *mut TIME_ZONE_INFORMATION;
        #[library("KERNEL32.dll")]
        extern fn LocalFileTimeToLocalSystemTime(#[opt] timeZoneInformation: *const TIME_ZONE_INFORMATION, localFileTime: *const FILETIME, localSystemTime: *mut SYSTEMTIME) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn LocalSystemTimeToLocalFileTime(#[opt] timeZoneInformation: *const TIME_ZONE_INFORMATION, localSystemTime: *const SYSTEMTIME, localFileTime: *mut FILETIME) -> BOOL;
        type PDYNAMIC_TIME_ZONE_INFORMATION = *mut DYNAMIC_TIME_ZONE_INFORMATION;
        type PTIME_ZONE_INFORMATION = *mut TIME_ZONE_INFORMATION;
        #[library("KERNEL32.dll")]
        extern fn SetDynamicTimeZoneInformation(lpTimeZoneInformation: *const DYNAMIC_TIME_ZONE_INFORMATION) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SetTimeZoneInformation(lpTimeZoneInformation: *const TIME_ZONE_INFORMATION) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SystemTimeToFileTime(lpSystemTime: *const SYSTEMTIME, lpFileTime: *mut FILETIME) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SystemTimeToTzSpecificLocalTime(#[opt] lpTimeZoneInformation: *const TIME_ZONE_INFORMATION, lpUniversalTime: *const SYSTEMTIME, lpLocalTime: *mut SYSTEMTIME) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn SystemTimeToTzSpecificLocalTimeEx(#[opt] lpTimeZoneInformation: *const DYNAMIC_TIME_ZONE_INFORMATION, lpUniversalTime: *const SYSTEMTIME, lpLocalTime: *mut SYSTEMTIME) -> BOOL;
        const TIME_ZONE_ID_INVALID: u32 = 4294967295;
        struct TIME_ZONE_INFORMATION {
            Bias: i32,
            StandardName: [u16; 32],
            StandardDate: SYSTEMTIME,
            StandardBias: i32,
            DaylightName: [u16; 32],
            DaylightDate: SYSTEMTIME,
            DaylightBias: i32,
        }
        #[library("KERNEL32.dll")]
        extern fn TzSpecificLocalTimeToSystemTime(#[opt] lpTimeZoneInformation: *const TIME_ZONE_INFORMATION, lpLocalTime: *const SYSTEMTIME, lpUniversalTime: *mut SYSTEMTIME) -> BOOL;
        #[library("KERNEL32.dll")]
        extern fn TzSpecificLocalTimeToSystemTimeEx(#[opt] lpTimeZoneInformation: *const DYNAMIC_TIME_ZONE_INFORMATION, lpLocalTime: *const SYSTEMTIME, lpUniversalTime: *mut SYSTEMTIME) -> BOOL;
    }
}

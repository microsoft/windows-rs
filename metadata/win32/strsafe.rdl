#[win32]
mod Windows {
    mod Win32 {
        const STRSAFE_E_END_OF_FILE: HRESULT = -2147024858;
        const STRSAFE_E_INSUFFICIENT_BUFFER: HRESULT = -2147024774;
        const STRSAFE_E_INVALID_PARAMETER: HRESULT = -2147024809;
        const STRSAFE_FILL_BEHIND_NULL: u32 = 512;
        const STRSAFE_FILL_ON_FAILURE: u32 = 1024;
        const STRSAFE_IGNORE_NULLS: u32 = 256;
        type STRSAFE_LPCSTR = *const i8;
        type STRSAFE_LPCUWSTR = *const u16;
        type STRSAFE_LPCWSTR = *const u16;
        type STRSAFE_LPSTR = *mut i8;
        type STRSAFE_LPWSTR = *mut u16;
        const STRSAFE_MAX_CCH: u32 = 2147483647;
        const STRSAFE_MAX_LENGTH: u32 = 2147483646;
        const STRSAFE_NO_TRUNCATION: u32 = 4096;
        const STRSAFE_NULL_ON_FAILURE: u32 = 2048;
        type STRSAFE_PCNZCH = *const i8;
        type STRSAFE_PCNZWCH = *const u16;
        type STRSAFE_PCUNZWCH = *const u16;
        const STRSAFE_USE_SECURE_CRT: u32 = 0;
        const STRSAFE_VALID_FLAGS: u32 = 8191;
    }
}

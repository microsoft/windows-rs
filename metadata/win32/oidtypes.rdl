#[win32]
mod Windows {
    mod Win32 {
        const NDIS_OBJECT_TYPE_OID_REQUEST: u32 = 150;
        type NDIS_OID = u32;
        #[repr(i32)]
        enum NDIS_REQUEST_TYPE {
            NdisRequestQueryInformation = 0,
            NdisRequestSetInformation = 1,
            NdisRequestQueryStatistics = 2,
            NdisRequestOpen = 3,
            NdisRequestClose = 4,
            NdisRequestSend = 5,
            NdisRequestTransferData = 6,
            NdisRequestReset = 7,
            NdisRequestGeneric1 = 8,
            NdisRequestGeneric2 = 9,
            NdisRequestGeneric3 = 10,
            NdisRequestGeneric4 = 11,
        }
        type PNDIS_OID = *mut u32;
        type PNDIS_REQUEST_TYPE = *mut NDIS_REQUEST_TYPE;
    }
}

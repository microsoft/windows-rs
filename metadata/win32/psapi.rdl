#[win32]
mod Windows {
    mod Win32 {
        struct ENUM_PAGE_FILE_INFORMATION {
            cb: u32,
            Reserved: u32,
            TotalSize: usize,
            TotalInUse: usize,
            PeakUsage: usize,
        }
        #[library("KERNEL32.dll")]
        extern "C" fn K32EmptyWorkingSet(hProcess: HANDLE) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumDeviceDrivers(#[size_param(1)] lpImageBase: *mut *mut void, cb: u32, lpcbNeeded: *mut u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumPageFilesA(pCallBackRoutine: PENUM_PAGE_FILE_CALLBACKA, pContext: *mut void) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumPageFilesW(pCallBackRoutine: PENUM_PAGE_FILE_CALLBACKW, pContext: *mut void) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumProcessModules(hProcess: HANDLE, #[size_param(2)] lphModule: *mut HMODULE, cb: u32, lpcbNeeded: *mut u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumProcessModulesEx(hProcess: HANDLE, #[size_param(2)] lphModule: *mut HMODULE, cb: u32, lpcbNeeded: *mut u32, dwFilterFlag: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32EnumProcesses(#[size_param(1)] lpidProcess: *mut u32, cb: u32, lpcbNeeded: *mut u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetDeviceDriverBaseNameA(ImageBase: *const void, #[len_param(2)] #[out] lpFilename: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetDeviceDriverBaseNameW(ImageBase: *const void, #[len_param(2)] #[out] lpBaseName: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetDeviceDriverFileNameA(ImageBase: *const void, #[len_param(2)] #[out] lpFilename: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetDeviceDriverFileNameW(ImageBase: *const void, #[len_param(2)] #[out] lpFilename: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetMappedFileNameA(hProcess: HANDLE, lpv: *const void, #[len_param(3)] #[out] lpFilename: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetMappedFileNameW(hProcess: HANDLE, lpv: *const void, #[len_param(3)] #[out] lpFilename: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetModuleBaseNameA(hProcess: HANDLE, #[opt] hModule: HMODULE, #[len_param(3)] #[out] lpBaseName: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetModuleBaseNameW(hProcess: HANDLE, #[opt] hModule: HMODULE, #[len_param(3)] #[out] lpBaseName: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetModuleFileNameExA(#[opt] hProcess: HANDLE, #[opt] hModule: HMODULE, lpFilename: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetModuleFileNameExW(#[opt] hProcess: HANDLE, #[opt] hModule: HMODULE, lpFilename: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetModuleInformation(hProcess: HANDLE, hModule: HMODULE, lpmodinfo: *mut MODULEINFO, cb: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetPerformanceInfo(pPerformanceInformation: *mut PERFORMANCE_INFORMATION, cb: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetProcessImageFileNameA(hProcess: HANDLE, #[len_param(2)] #[out] lpImageFileName: PSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetProcessImageFileNameW(hProcess: HANDLE, #[len_param(2)] #[out] lpImageFileName: PWSTR, nSize: u32) -> u32;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetProcessMemoryInfo(Process: HANDLE, #[size_param(2)] ppsmemCounters: *mut PROCESS_MEMORY_COUNTERS, cb: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetWsChanges(hProcess: HANDLE, #[size_param(2)] lpWatchInfo: *mut PSAPI_WS_WATCH_INFORMATION, cb: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32GetWsChangesEx(hProcess: HANDLE, #[size_param(2)] lpWatchInfoEx: *mut PSAPI_WS_WATCH_INFORMATION_EX, #[in] #[out] cb: *mut u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32InitializeProcessForWsWatch(hProcess: HANDLE) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32QueryWorkingSet(hProcess: HANDLE, #[size_param(2)] pv: *mut void, cb: u32) -> BOOL;
        #[library("KERNEL32.dll")]
        extern "C" fn K32QueryWorkingSetEx(hProcess: HANDLE, #[size_param(2)] pv: *mut void, cb: u32) -> BOOL;
        const LIST_MODULES_32BIT: u32 = 1;
        const LIST_MODULES_64BIT: u32 = 2;
        const LIST_MODULES_ALL: u32 = 3;
        const LIST_MODULES_DEFAULT: u32 = 0;
        type LPMODULEINFO = *mut MODULEINFO;
        struct MODULEINFO {
            lpBaseOfDll: *mut void,
            SizeOfImage: u32,
            EntryPoint: *mut void,
        }
        extern fn PENUM_PAGE_FILE_CALLBACKA(pContext: *mut void, pPageFileInfo: *mut ENUM_PAGE_FILE_INFORMATION, lpFilename: PCSTR) -> BOOL;
        extern fn PENUM_PAGE_FILE_CALLBACKW(pContext: *mut void, pPageFileInfo: *mut ENUM_PAGE_FILE_INFORMATION, lpFilename: PCWSTR) -> BOOL;
        type PENUM_PAGE_FILE_INFORMATION = *mut ENUM_PAGE_FILE_INFORMATION;
        type PERFORMACE_INFORMATION = PERFORMANCE_INFORMATION;
        struct PERFORMANCE_INFORMATION {
            cb: u32,
            CommitTotal: usize,
            CommitLimit: usize,
            CommitPeak: usize,
            PhysicalTotal: usize,
            PhysicalAvailable: usize,
            SystemCache: usize,
            KernelTotal: usize,
            KernelPaged: usize,
            KernelNonpaged: usize,
            PageSize: usize,
            HandleCount: u32,
            ProcessCount: u32,
            ThreadCount: u32,
        }
        type PPERFORMACE_INFORMATION = *mut PERFORMANCE_INFORMATION;
        type PPERFORMANCE_INFORMATION = *mut PERFORMANCE_INFORMATION;
        type PPROCESS_MEMORY_COUNTERS = *mut PROCESS_MEMORY_COUNTERS;
        type PPROCESS_MEMORY_COUNTERS_EX = *mut PROCESS_MEMORY_COUNTERS_EX;
        type PPROCESS_MEMORY_COUNTERS_EX2 = *mut PROCESS_MEMORY_COUNTERS_EX2;
        type PPSAPI_WORKING_SET_BLOCK = *mut PSAPI_WORKING_SET_BLOCK;
        type PPSAPI_WORKING_SET_EX_BLOCK = *mut PSAPI_WORKING_SET_EX_BLOCK;
        type PPSAPI_WORKING_SET_EX_INFORMATION = *mut PSAPI_WORKING_SET_EX_INFORMATION;
        type PPSAPI_WORKING_SET_INFORMATION = *mut PSAPI_WORKING_SET_INFORMATION;
        type PPSAPI_WS_WATCH_INFORMATION = *mut PSAPI_WS_WATCH_INFORMATION;
        type PPSAPI_WS_WATCH_INFORMATION_EX = *mut PSAPI_WS_WATCH_INFORMATION_EX;
        struct PROCESS_MEMORY_COUNTERS {
            cb: u32,
            PageFaultCount: u32,
            PeakWorkingSetSize: usize,
            WorkingSetSize: usize,
            QuotaPeakPagedPoolUsage: usize,
            QuotaPagedPoolUsage: usize,
            QuotaPeakNonPagedPoolUsage: usize,
            QuotaNonPagedPoolUsage: usize,
            PagefileUsage: usize,
            PeakPagefileUsage: usize,
        }
        struct PROCESS_MEMORY_COUNTERS_EX {
            cb: u32,
            PageFaultCount: u32,
            PeakWorkingSetSize: usize,
            WorkingSetSize: usize,
            QuotaPeakPagedPoolUsage: usize,
            QuotaPagedPoolUsage: usize,
            QuotaPeakNonPagedPoolUsage: usize,
            QuotaNonPagedPoolUsage: usize,
            PagefileUsage: usize,
            PeakPagefileUsage: usize,
            PrivateUsage: usize,
        }
        struct PROCESS_MEMORY_COUNTERS_EX2 {
            cb: u32,
            PageFaultCount: u32,
            PeakWorkingSetSize: usize,
            WorkingSetSize: usize,
            QuotaPeakPagedPoolUsage: usize,
            QuotaPagedPoolUsage: usize,
            QuotaPeakNonPagedPoolUsage: usize,
            QuotaNonPagedPoolUsage: usize,
            PagefileUsage: usize,
            PeakPagefileUsage: usize,
            PrivateUsage: usize,
            PrivateWorkingSetSize: usize,
            SharedCommitUsage: u64,
        }
        const PSAPI_VERSION: u32 = 2;
        union PSAPI_WORKING_SET_BLOCK {
            Flags: usize,
            Anonymous: struct {
                _bitfield: usize,
            },
        }
        union PSAPI_WORKING_SET_EX_BLOCK {
            Flags: usize,
            Anonymous: union {
                Anonymous: struct {
                    _bitfield: usize,
                },
                Invalid: struct {
                    _bitfield: usize,
                },
            },
        }
        struct PSAPI_WORKING_SET_EX_INFORMATION {
            VirtualAddress: *mut void,
            VirtualAttributes: PSAPI_WORKING_SET_EX_BLOCK,
        }
        struct PSAPI_WORKING_SET_INFORMATION {
            NumberOfEntries: usize,
            WorkingSetInfo: [PSAPI_WORKING_SET_BLOCK; 1],
        }
        struct PSAPI_WS_WATCH_INFORMATION {
            FaultingPc: *mut void,
            FaultingVa: *mut void,
        }
        struct PSAPI_WS_WATCH_INFORMATION_EX {
            BasicInfo: PSAPI_WS_WATCH_INFORMATION,
            FaultingThreadId: usize,
            Flags: usize,
        }
    }
}

        const PNPX_INSTALLSTATE_FAILED: u32 = 3;
        const PNPX_INSTALLSTATE_INSTALLED: u32 = 1;
        const PNPX_INSTALLSTATE_INSTALLING: u32 = 2;
        const PNPX_INSTALLSTATE_NOTINSTALLED: u32 = 0;
    }
}

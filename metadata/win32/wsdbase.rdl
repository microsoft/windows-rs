        }
        #[guid(0x74d6124a_a441_4f78_a1eb_97a8d1996893)]
        interface IWSDUdpAddress: IWSDTransportAddress {
            fn SetSockaddr(&self, pSockAddr: *const SOCKADDR_STORAGE) -> HRESULT;

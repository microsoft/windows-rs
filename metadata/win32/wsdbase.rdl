        }
        #[guid(0x03ce20aa_71c4_45e2_b32e_3766c61c790f)]
        interface IWSDSignatureProperty: IUnknown {
            fn IsMessageSigned(&self, pbSigned: *mut BOOL) -> HRESULT;
            fn IsMessageSignatureTrusted(&self, pbSignatureTrusted: *mut BOOL) -> HRESULT;
            fn GetKeyInfo(&self, #[size_param(1)] #[opt] pbKeyInfo: *mut u8, #[in] #[out] pdwKeyInfoSize: *mut u32) -> HRESULT;
            fn GetSignature(&self, #[size_param(1)] #[opt] pbSignature: *mut u8, #[in] #[out] pdwSignatureSize: *mut u32) -> HRESULT;
            fn GetSignedInfoHash(&self, #[size_param(1)] #[opt] pbSignedInfoHash: *mut u8, #[in] #[out] pdwHashSize: *mut u32) -> HRESULT;
        }
        #[guid(0x70d23498_4ee6_4340_a3df_d845d2235467)]
        interface IWSDTransportAddress: IWSDAddress {
            fn GetPort(&self, pwPort: *mut u16) -> HRESULT;

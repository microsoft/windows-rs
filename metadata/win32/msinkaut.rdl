        #[guid(0xf0f060b5_8b1f_4a7c_89ec_880692588a4f)]
        interface IInkCollector: IDispatch {
            #[special]
            fn get_hWnd(&self, #[retval] CurrentWindow: *mut isize) -> HRESULT;
            #[special]
            fn put_hWnd(&self, NewWindow: isize) -> HRESULT;
            #[special]
            fn get_Enabled(&self, #[retval] Collecting: *mut VARIANT_BOOL) -> HRESULT;
            #[special]
            fn put_Enabled(&self, Collecting: VARIANT_BOOL) -> HRESULT;
            #[special]
            fn get_DefaultDrawingAttributes(&self, #[retval] CurrentAttributes: *mut IInkDrawingAttributes) -> HRESULT;
            fn putref_DefaultDrawingAttributes(&self, NewAttributes: IInkDrawingAttributes) -> HRESULT;
            #[special]
            fn get_Renderer(&self, #[retval] CurrentInkRenderer: *mut IInkRenderer) -> HRESULT;
            fn putref_Renderer(&self, NewInkRenderer: IInkRenderer) -> HRESULT;
            #[special]
            fn get_Ink(&self, #[retval] Ink: *mut IInkDisp) -> HRESULT;
            fn putref_Ink(&self, NewInk: IInkDisp) -> HRESULT;
            #[special]
            fn get_AutoRedraw(&self, #[retval] AutoRedraw: *mut VARIANT_BOOL) -> HRESULT;
            #[special]
            fn put_AutoRedraw(&self, AutoRedraw: VARIANT_BOOL) -> HRESULT;
            #[special]
            fn get_CollectingInk(&self, #[retval] Collecting: *mut VARIANT_BOOL) -> HRESULT;
            #[special]
            fn get_CollectionMode(&self, #[retval] Mode: *mut InkCollectionMode) -> HRESULT;
            #[special]
            fn put_CollectionMode(&self, Mode: InkCollectionMode) -> HRESULT;
            #[special]
            fn get_DynamicRendering(&self, #[retval] Enabled: *mut VARIANT_BOOL) -> HRESULT;
            #[special]
            fn put_DynamicRendering(&self, Enabled: VARIANT_BOOL) -> HRESULT;
            #[special]
            fn get_DesiredPacketDescription(&self, #[retval] PacketGuids: *mut VARIANT) -> HRESULT;
            #[special]
            fn put_DesiredPacketDescription(&self, PacketGuids: VARIANT) -> HRESULT;
            #[special]
            fn get_MouseIcon(&self, #[retval] MouseIcon: *mut IPictureDisp) -> HRESULT;
            #[special]
            fn put_MouseIcon(&self, MouseIcon: IPictureDisp) -> HRESULT;
            fn putref_MouseIcon(&self, MouseIcon: IPictureDisp) -> HRESULT;
            #[special]
            fn get_MousePointer(&self, #[retval] MousePointer: *mut InkMousePointer) -> HRESULT;
            #[special]
            fn put_MousePointer(&self, MousePointer: InkMousePointer) -> HRESULT;
            #[special]
            fn get_Cursors(&self, #[retval] Cursors: *mut IInkCursors) -> HRESULT;
            #[special]
            fn get_MarginX(&self, #[retval] MarginX: *mut i32) -> HRESULT;
            #[special]
            fn put_MarginX(&self, MarginX: i32) -> HRESULT;
            #[special]
            fn get_MarginY(&self, #[retval] MarginY: *mut i32) -> HRESULT;
            #[special]
            fn put_MarginY(&self, MarginY: i32) -> HRESULT;
            #[special]
            fn get_Tablet(&self, #[retval] SingleTablet: *mut IInkTablet) -> HRESULT;
            #[special]
            fn get_SupportHighContrastInk(&self, #[retval] Support: *mut VARIANT_BOOL) -> HRESULT;
            #[special]
            fn put_SupportHighContrastInk(&self, Support: VARIANT_BOOL) -> HRESULT;
            fn SetGestureStatus(&self, Gesture: InkApplicationGesture, Listen: VARIANT_BOOL) -> HRESULT;
            fn GetGestureStatus(&self, Gesture: InkApplicationGesture, #[retval] Listening: *mut VARIANT_BOOL) -> HRESULT;
            fn GetWindowInputRectangle(&self, #[in] #[out] WindowInputRectangle: *mut IInkRectangle) -> HRESULT;
            fn SetWindowInputRectangle(&self, WindowInputRectangle: IInkRectangle) -> HRESULT;
            fn SetAllTabletsMode(&self, UseMouseForInput: VARIANT_BOOL) -> HRESULT;
            fn SetSingleTabletIntegratedMode(&self, Tablet: IInkTablet) -> HRESULT;
            fn GetEventInterest(&self, EventId: InkCollectorEventInterest, #[retval] Listen: *mut VARIANT_BOOL) -> HRESULT;
            fn SetEventInterest(&self, EventId: InkCollectorEventInterest, Listen: VARIANT_BOOL) -> HRESULT;

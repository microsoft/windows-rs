#[win32]
mod Windows {
    mod Win32 {
        const FACILITY_HID_ERROR_CODE: u32 = 17;
        struct HIDP_BUTTON_ARRAY_DATA {
            ArrayIndex: u16,
            On: BOOLEAN,
        }
        struct HIDP_BUTTON_CAPS {
            UsagePage: USAGE,
            ReportID: u8,
            IsAlias: BOOLEAN,
            BitField: u16,
            LinkCollection: u16,
            LinkUsage: USAGE,
            LinkUsagePage: USAGE,
            IsRange: BOOLEAN,
            IsStringRange: BOOLEAN,
            IsDesignatorRange: BOOLEAN,
            IsAbsolute: BOOLEAN,
            ReportCount: u16,
            Reserved2: u16,
            Reserved: [u32; 9],
            Anonymous: union {
                Range: struct {
                    UsageMin: USAGE,
                    UsageMax: USAGE,
                    StringMin: u16,
                    StringMax: u16,
                    DesignatorMin: u16,
                    DesignatorMax: u16,
                    DataIndexMin: u16,
                    DataIndexMax: u16,
                },
                NotRange: struct {
                    Usage: USAGE,
                    Reserved1: USAGE,
                    StringIndex: u16,
                    Reserved2: u16,
                    DesignatorIndex: u16,
                    Reserved3: u16,
                    DataIndex: u16,
                    Reserved4: u16,
                },
            },
        }
        struct HIDP_CAPS {
            Usage: USAGE,
            UsagePage: USAGE,
            InputReportByteLength: u16,
            OutputReportByteLength: u16,
            FeatureReportByteLength: u16,
            Reserved: [u16; 17],
            NumberLinkCollectionNodes: u16,
            NumberInputButtonCaps: u16,
            NumberInputValueCaps: u16,
            NumberInputDataIndices: u16,
            NumberOutputButtonCaps: u16,
            NumberOutputValueCaps: u16,
            NumberOutputDataIndices: u16,
            NumberFeatureButtonCaps: u16,
            NumberFeatureValueCaps: u16,
            NumberFeatureDataIndices: u16,
        }
        struct HIDP_DATA {
            DataIndex: u16,
            Reserved: u16,
            Anonymous: union {
                RawValue: u32,
                On: BOOLEAN,
            },
        }
        #[arch(X86)]
        struct HIDP_EXTENDED_ATTRIBUTES {
            NumGlobalUnknowns: u8,
            Reserved: [u8; 3],
            GlobalUnknowns: PHIDP_UNKNOWN_TOKEN,
            Data: [u32; 1],
        }
        #[packed(4)]
        #[arch(X64 | Arm64)]
        struct HIDP_EXTENDED_ATTRIBUTES {
            NumGlobalUnknowns: u8,
            Reserved: [u8; 3],
            GlobalUnknowns: PHIDP_UNKNOWN_TOKEN,
            Data: [u32; 1],
        }
        #[repr(i32)]
        enum HIDP_KEYBOARD_DIRECTION {
            HidP_Keyboard_Break = 0,
            HidP_Keyboard_Make = 1,
        }
        struct HIDP_KEYBOARD_MODIFIER_STATE {
            Anonymous: union {
                Anonymous: struct {
                    _bitfield: u32,
                },
                ul: u32,
            },
        }
        #[arch(X86)]
        struct HIDP_LINK_COLLECTION_NODE {
            LinkUsage: USAGE,
            LinkUsagePage: USAGE,
            Parent: u16,
            NumberOfChildren: u16,
            NextSibling: u16,
            FirstChild: u16,
            _bitfield: u32,
            UserContext: *mut void,
        }
        #[packed(4)]
        #[arch(X64 | Arm64)]
        struct HIDP_LINK_COLLECTION_NODE {
            LinkUsage: USAGE,
            LinkUsagePage: USAGE,
            Parent: u16,
            NumberOfChildren: u16,
            NextSibling: u16,
            FirstChild: u16,
            _bitfield: u32,
            UserContext: *mut void,
        }
        const HIDP_LINK_COLLECTION_ROOT: u16 = 65535;
        const HIDP_LINK_COLLECTION_UNSPECIFIED: u16 = 0;
        #[repr(i32)]
        enum HIDP_REPORT_TYPE {
            HidP_Input = 0,
            HidP_Output = 1,
            HidP_Feature = 2,
        }
        const HIDP_STATUS_BAD_LOG_PHY_VALUES: i32 = -1072627706;
        const HIDP_STATUS_BUFFER_TOO_SMALL: i32 = -1072627705;
        const HIDP_STATUS_BUTTON_NOT_PRESSED: i32 = -1072627697;
        const HIDP_STATUS_DATA_INDEX_NOT_FOUND: i32 = -1072627699;
        const HIDP_STATUS_DATA_INDEX_OUT_OF_RANGE: i32 = -1072627698;
        const HIDP_STATUS_I8042_TRANS_UNKNOWN: i32 = -1072627703;
        const HIDP_STATUS_I8242_TRANS_UNKNOWN: i32 = -1072627703;
        const HIDP_STATUS_INCOMPATIBLE_REPORT_ID: i32 = -1072627702;
        const HIDP_STATUS_INTERNAL_ERROR: i32 = -1072627704;
        const HIDP_STATUS_INVALID_PREPARSED_DATA: i32 = -1072627711;
        const HIDP_STATUS_INVALID_REPORT_LENGTH: i32 = -1072627709;
        const HIDP_STATUS_INVALID_REPORT_TYPE: i32 = -1072627710;
        const HIDP_STATUS_IS_VALUE_ARRAY: i32 = -1072627700;
        const HIDP_STATUS_NOT_BUTTON_ARRAY: i32 = -1072627679;
        const HIDP_STATUS_NOT_IMPLEMENTED: i32 = -1072627680;
        const HIDP_STATUS_NOT_VALUE_ARRAY: i32 = -1072627701;
        const HIDP_STATUS_NULL: i32 = -2146369535;
        const HIDP_STATUS_REPORT_DOES_NOT_EXIST: i32 = -1072627696;
        const HIDP_STATUS_SUCCESS: u32 = 1114112;
        const HIDP_STATUS_USAGE_NOT_FOUND: i32 = -1072627708;
        const HIDP_STATUS_VALUE_OUT_OF_RANGE: i32 = -1072627707;
        struct HIDP_UNKNOWN_TOKEN {
            Token: u8,
            Reserved: [u8; 3],
            BitField: u32,
        }
        struct HIDP_VALUE_CAPS {
            UsagePage: USAGE,
            ReportID: u8,
            IsAlias: BOOLEAN,
            BitField: u16,
            LinkCollection: u16,
            LinkUsage: USAGE,
            LinkUsagePage: USAGE,
            IsRange: BOOLEAN,
            IsStringRange: BOOLEAN,
            IsDesignatorRange: BOOLEAN,
            IsAbsolute: BOOLEAN,
            HasNull: BOOLEAN,
            Reserved: u8,
            BitSize: u16,
            ReportCount: u16,
            Reserved2: [u16; 5],
            UnitsExp: u32,
            Units: u32,
            LogicalMin: i32,
            LogicalMax: i32,
            PhysicalMin: i32,
            PhysicalMax: i32,
            Anonymous: union {
                Range: struct {
                    UsageMin: USAGE,
                    UsageMax: USAGE,
                    StringMin: u16,
                    StringMax: u16,
                    DesignatorMin: u16,
                    DesignatorMax: u16,
                    DataIndexMin: u16,
                    DataIndexMax: u16,
                },
                NotRange: struct {
                    Usage: USAGE,
                    Reserved1: USAGE,
                    StringIndex: u16,
                    Reserved2: u16,
                    DesignatorIndex: u16,
                    Reserved3: u16,
                    DataIndex: u16,
                    Reserved4: u16,
                },
            },
        }
        #[library("HID.DLL")]
        extern fn HidP_GetButtonArray(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, #[len_param(5)] ButtonData: *mut HIDP_BUTTON_ARRAY_DATA, #[in] #[out] ButtonDataLength: *mut u16, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(8)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetButtonCaps(ReportType: HIDP_REPORT_TYPE, #[len_param(2)] ButtonCaps: *mut HIDP_BUTTON_CAPS, #[in] #[out] ButtonCapsLength: *mut u16, PreparsedData: *const _HIDP_PREPARSED_DATA) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetCaps(PreparsedData: *const _HIDP_PREPARSED_DATA, Capabilities: *mut HIDP_CAPS) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetData(ReportType: HIDP_REPORT_TYPE, #[len_param(2)] DataList: *mut HIDP_DATA, #[in] #[out] DataLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(5)] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetExtendedAttributes(ReportType: HIDP_REPORT_TYPE, DataIndex: u16, PreparsedData: *const _HIDP_PREPARSED_DATA, #[len_param(4)] Attributes: *mut HIDP_EXTENDED_ATTRIBUTES, #[in] #[out] LengthAttributes: *mut u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetLinkCollectionNodes(#[len_param(1)] LinkCollectionNodes: *mut HIDP_LINK_COLLECTION_NODE, #[in] #[out] LinkCollectionNodesLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetScaledUsageValue(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, UsageValue: *mut i32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetSpecificButtonCaps(ReportType: HIDP_REPORT_TYPE, #[opt] UsagePage: USAGE, #[opt] LinkCollection: u16, #[opt] Usage: USAGE, #[len_param(5)] ButtonCaps: *mut HIDP_BUTTON_CAPS, #[in] #[out] ButtonCapsLength: *mut u16, PreparsedData: *const _HIDP_PREPARSED_DATA) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetSpecificValueCaps(ReportType: HIDP_REPORT_TYPE, #[opt] UsagePage: USAGE, #[opt] LinkCollection: u16, #[opt] Usage: USAGE, #[len_param(5)] ValueCaps: *mut HIDP_VALUE_CAPS, #[in] #[out] ValueCapsLength: *mut u16, PreparsedData: *const _HIDP_PREPARSED_DATA) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetUsageValue(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, UsageValue: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetUsageValueArray(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, #[size_param(5)] #[in] #[out] UsageValue: *mut i8, UsageValueByteLength: u16, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(8)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetUsages(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, #[len_param(4)] UsageList: *mut u16, #[in] #[out] UsageLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetUsagesEx(ReportType: HIDP_REPORT_TYPE, #[opt] LinkCollection: u16, #[len_param(3)] #[in] #[out] ButtonList: *mut USAGE_AND_PAGE, #[in] #[out] UsageLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(6)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_GetValueCaps(ReportType: HIDP_REPORT_TYPE, #[len_param(2)] ValueCaps: *mut HIDP_VALUE_CAPS, #[in] #[out] ValueCapsLength: *mut u16, PreparsedData: *const _HIDP_PREPARSED_DATA) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_InitializeReportForID(ReportType: HIDP_REPORT_TYPE, ReportID: u8, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(4)] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_MaxDataListLength(ReportType: HIDP_REPORT_TYPE, PreparsedData: *const _HIDP_PREPARSED_DATA) -> u32;
        #[library("HID.DLL")]
        extern fn HidP_MaxUsageListLength(ReportType: HIDP_REPORT_TYPE, #[opt] UsagePage: USAGE, PreparsedData: *const _HIDP_PREPARSED_DATA) -> u32;
        #[library("HID.DLL")]
        extern fn HidP_SetButtonArray(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, #[len_param(5)] ButtonData: *const HIDP_BUTTON_ARRAY_DATA, ButtonDataLength: u16, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(8)] #[in] #[out] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_SetData(ReportType: HIDP_REPORT_TYPE, #[len_param(2)] #[in] #[out] DataList: *mut HIDP_DATA, #[in] #[out] DataLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(5)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_SetScaledUsageValue(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, UsageValue: i32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] #[in] #[out] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_SetUsageValue(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, UsageValue: u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] #[in] #[out] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_SetUsageValueArray(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, Usage: USAGE, #[size_param(5)] UsageValue: *const i8, UsageValueByteLength: u16, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(8)] #[in] #[out] Report: *mut i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_SetUsages(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, #[len_param(4)] #[in] #[out] UsageList: *mut u16, #[in] #[out] UsageLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_TranslateUsagesToI8042ScanCodes(#[len_param(1)] ChangedUsageList: *const u16, UsageListLength: u32, KeyAction: HIDP_KEYBOARD_DIRECTION, #[in] #[out] ModifierState: *mut HIDP_KEYBOARD_MODIFIER_STATE, InsertCodesProcedure: PHIDP_INSERT_SCANCODES, #[opt] InsertCodesContext: *const void) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_UnsetUsages(ReportType: HIDP_REPORT_TYPE, UsagePage: USAGE, #[opt] LinkCollection: u16, #[len_param(4)] #[in] #[out] UsageList: *mut u16, #[in] #[out] UsageLength: *mut u32, PreparsedData: *const _HIDP_PREPARSED_DATA, #[size_param(7)] Report: *const i8, ReportLength: u32) -> NTSTATUS;
        #[library("HID.DLL")]
        extern fn HidP_UsageListDifference(#[len_param(4)] PreviousUsageList: *const u16, #[len_param(4)] CurrentUsageList: *const u16, #[len_param(4)] BreakUsageList: *mut u16, #[len_param(4)] MakeUsageList: *mut u16, UsageListLength: u32) -> NTSTATUS;
        extern fn PFN_HidP_GetVersionInternal(Version: *mut u32) -> NTSTATUS;
        type PHIDP_BUTTON_ARRAY_DATA = *mut HIDP_BUTTON_ARRAY_DATA;
        type PHIDP_BUTTON_CAPS = *mut HIDP_BUTTON_CAPS;
        type PHIDP_CAPS = *mut HIDP_CAPS;
        type PHIDP_DATA = *mut HIDP_DATA;
        type PHIDP_EXTENDED_ATTRIBUTES = *mut HIDP_EXTENDED_ATTRIBUTES;
        extern fn PHIDP_INSERT_SCANCODES(#[opt] Context: *const void, #[size_param(2)] NewScanCodes: *const i8, Length: u32) -> BOOLEAN;
        type PHIDP_KEYBOARD_MODIFIER_STATE = *mut HIDP_KEYBOARD_MODIFIER_STATE;
        type PHIDP_LINK_COLLECTION_NODE = *mut HIDP_LINK_COLLECTION_NODE;
        type PHIDP_PREPARSED_DATA = *mut _HIDP_PREPARSED_DATA;
        type PHIDP_REPORT_DESCRIPTOR = PUCHAR;
        type PHIDP_UNKNOWN_TOKEN = *mut HIDP_UNKNOWN_TOKEN;
        type PHIDP_VALUE_CAPS = *mut HIDP_VALUE_CAPS;
        type PUSAGE_AND_PAGE = *mut USAGE_AND_PAGE;
        struct USAGE_AND_PAGE {
            Usage: USAGE,
            UsagePage: USAGE,
        }
        struct _HIDP_PREPARSED_DATA {}
    }
}

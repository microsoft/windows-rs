        const L2_NOTIFICATION_SOURCE_WLAN_DEVICE_SERVICE: u32 = 2048;
        const L2_NOTIFICATION_SOURCE_WLAN_HNWK: u32 = 128;
        const L2_NOTIFICATION_SOURCE_WLAN_IHV: u32 = 64;
        const L2_NOTIFICATION_SOURCE_WLAN_MSM: u32 = 16;
        const L2_NOTIFICATION_SOURCE_WLAN_SECURITY: u32 = 32;
        const L2_PROFILE_MAX_NAME_LENGTH: u32 = 256;
        const L2_REASON_CODE_DOT11_AC_BASE: u32 = 131072;
        const L2_REASON_CODE_DOT11_MSM_BASE: u32 = 196608;
        const L2_REASON_CODE_DOT11_SECURITY_BASE: u32 = 262144;
        const L2_REASON_CODE_DOT3_AC_BASE: u32 = 393216;
        const L2_REASON_CODE_DOT3_MSM_BASE: u32 = 458752;
        const L2_REASON_CODE_GEN_BASE: u32 = 65536;
        const L2_REASON_CODE_GROUP_SIZE: u32 = 65536;
        const L2_REASON_CODE_IHV_BASE: u32 = 589824;
        const L2_REASON_CODE_ONEX_BASE: u32 = 327680;
        const L2_REASON_CODE_PROFILE_BASE: u32 = 524288;
        const L2_REASON_CODE_PROFILE_MISSING: u32 = 1;
        const L2_REASON_CODE_RESERVED_BASE: u32 = 720896;
        const L2_REASON_CODE_SUCCESS: u32 = 0;

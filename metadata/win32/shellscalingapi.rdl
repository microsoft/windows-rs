#[win32]
mod Windows {
    mod Win32 {
        #[repr(i32)]
        enum DISPLAY_DEVICE_TYPE {
            DEVICE_PRIMARY = 0,
            DEVICE_IMMERSIVE = 1,
        }
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn GetDpiForMonitor(hmonitor: HMONITOR, dpiType: MONITOR_DPI_TYPE, dpiX: *mut u32, dpiY: *mut u32) -> HRESULT;
        #[library("api-ms-win-shcore-scaling-l1-1-2.dll")]
        extern fn GetDpiForShellUIComponent(param0: SHELL_UI_COMPONENT) -> u32;
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn GetProcessDpiAwareness(#[opt] hprocess: HANDLE, value: *mut PROCESS_DPI_AWARENESS) -> HRESULT;
        #[library("api-ms-win-shcore-scaling-l1-1-0.dll")]
        extern fn GetScaleFactorForDevice(deviceType: DISPLAY_DEVICE_TYPE) -> DEVICE_SCALE_FACTOR;
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn GetScaleFactorForMonitor(hMon: HMONITOR, pScale: *mut DEVICE_SCALE_FACTOR) -> HRESULT;
        #[repr(i32)]
        enum MONITOR_DPI_TYPE {
            MDT_EFFECTIVE_DPI = 0,
            MDT_ANGULAR_DPI = 1,
            MDT_RAW_DPI = 2,
            MDT_DEFAULT = 0,
        }
        #[repr(i32)]
        enum PROCESS_DPI_AWARENESS {
            PROCESS_DPI_UNAWARE = 0,
            PROCESS_SYSTEM_DPI_AWARE = 1,
            PROCESS_PER_MONITOR_DPI_AWARE = 2,
        }
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn RegisterScaleChangeEvent(hEvent: HANDLE, pdwCookie: *mut usize) -> HRESULT;
        #[library("api-ms-win-shcore-scaling-l1-1-0.dll")]
        extern fn RegisterScaleChangeNotifications(displayDevice: DISPLAY_DEVICE_TYPE, hwndNotify: HWND, uMsgNotify: u32, pdwCookie: *mut u32) -> HRESULT;
        #[library("api-ms-win-shcore-scaling-l1-1-0.dll")]
        extern fn RevokeScaleChangeNotifications(displayDevice: DISPLAY_DEVICE_TYPE, dwCookie: u32) -> HRESULT;
        #[repr(u32)]
        #[flags]
        enum SCALE_CHANGE_FLAGS {
            SCF_VALUE_NONE = 0,
            SCF_SCALE = 1,
            SCF_PHYSICAL = 2,
        }
        #[repr(i32)]
        enum SHELL_UI_COMPONENT {
            SHELL_UI_COMPONENT_TASKBARS = 0,
            SHELL_UI_COMPONENT_NOTIFICATIONAREA = 1,
            SHELL_UI_COMPONENT_DESKBAND = 2,
        }
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn SetProcessDpiAwareness(value: PROCESS_DPI_AWARENESS) -> HRESULT;
        #[library("api-ms-win-shcore-scaling-l1-1-1.dll")]
        extern fn UnregisterScaleChangeEvent(dwCookie: usize) -> HRESULT;
    }
}

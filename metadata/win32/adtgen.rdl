#[win32]
mod Windows {
    mod Win32 {
        const APF_AuditFailure: u32 = 0;
        const APF_AuditSuccess: u32 = 1;
        const APF_ValidFlags: u32 = 1;
        const AP_AccessMask: u32 = 512;
        const AP_ClientLogonId: u32 = 512;
        const AP_Filespec: u32 = 256;
        const AP_FormatHex: u32 = 256;
        const AP_ParamTypeBits: u32 = 8;
        const AP_ParamTypeMask: u32 = 255;
        const AP_PrimaryLogonId: u32 = 256;
        const AP_SidAsLogonId: u32 = 256;
        type AUDIT_HANDLE = *mut void;
        struct AUDIT_IP_ADDRESS {
            pIpAddress: [u8; 128],
        }
        struct AUDIT_OBJECT_TYPE {
            ObjectType: GUID,
            Flags: u16,
            Level: u16,
            AccessMask: ACCESS_MASK,
        }
        struct AUDIT_OBJECT_TYPES {
            Count: u16,
            Flags: u16,
            pObjectTypes: *mut AUDIT_OBJECT_TYPE,
        }
        struct AUDIT_PARAM {
            Type: AUDIT_PARAM_TYPE,
            Length: u32,
            Flags: u32,
            Anonymous: union {
                Data0: usize,
                String: PWSTR,
                u: usize,
                psid: *mut SID,
                pguid: *mut GUID,
                LogonId_LowPart: u32,
                pObjectTypes: *mut AUDIT_OBJECT_TYPES,
                pIpAddress: *mut AUDIT_IP_ADDRESS,
            },
            Anonymous2: union {
                Data1: usize,
                LogonId_HighPart: i32,
            },
        }
        struct AUDIT_PARAMS {
            Length: u32,
            Flags: u32,
            Count: u16,
            Parameters: *mut AUDIT_PARAM,
        }
        #[repr(i32)]
        enum AUDIT_PARAM_TYPE {
            APT_None = 1,
            APT_String = 2,
            APT_Ulong = 3,
            APT_Pointer = 4,
            APT_Sid = 5,
            APT_LogonId = 6,
            APT_ObjectTypeList = 7,
            APT_Luid = 8,
            APT_Guid = 9,
            APT_Time = 10,
            APT_Int64 = 11,
            APT_IpAddress = 12,
            APT_LogonIdWithSid = 13,
        }
        const AUDIT_TYPE_LEGACY: u32 = 1;
        const AUDIT_TYPE_WMI: u32 = 2;
        const AUTHZP_WPD_EVENT: u32 = 16;
        const AUTHZ_ALLOW_MULTIPLE_SOURCE_INSTANCES: u32 = 1;
        struct AUTHZ_AUDIT_EVENT_TYPE_LEGACY {
            CategoryId: u16,
            AuditId: u16,
            ParameterCount: u16,
        }
        struct AUTHZ_AUDIT_EVENT_TYPE_OLD {
            Version: u32,
            dwFlags: u32,
            RefCount: i32,
            hAudit: usize,
            LinkId: LUID,
            u: AUTHZ_AUDIT_EVENT_TYPE_UNION,
        }
        union AUTHZ_AUDIT_EVENT_TYPE_UNION {
            Legacy: AUTHZ_AUDIT_EVENT_TYPE_LEGACY,
        }
        const AUTHZ_AUDIT_INSTANCE_INFORMATION: u32 = 2;
        const AUTHZ_MIGRATED_LEGACY_PUBLISHER: u32 = 2;
        type PAUDIT_HANDLE = *mut *mut void;
        type PAUDIT_IP_ADDRESS = *mut AUDIT_IP_ADDRESS;
        type PAUDIT_OBJECT_TYPE = *mut AUDIT_OBJECT_TYPE;
        type PAUDIT_OBJECT_TYPES = *mut AUDIT_OBJECT_TYPES;
        type PAUDIT_PARAM = *mut AUDIT_PARAM;
        type PAUDIT_PARAMS = *mut AUDIT_PARAMS;
        type PAUTHZ_AUDIT_EVENT_TYPE_LEGACY = *mut AUTHZ_AUDIT_EVENT_TYPE_LEGACY;
        type PAUTHZ_AUDIT_EVENT_TYPE_OLD = *mut AUTHZ_AUDIT_EVENT_TYPE_OLD;
        type PAUTHZ_AUDIT_EVENT_TYPE_UNION = *mut AUTHZ_AUDIT_EVENT_TYPE_UNION;
    }
}

                enum RM_REBOOT_REASON {
                    RmRebootReasonNone = 0,
                    RmRebootReasonPermissionDenied = 1,
                    RmRebootReasonSessionMismatch = 2,
                    RmRebootReasonCriticalProcess = 4,
                    RmRebootReasonCriticalService = 8,
                    RmRebootReasonDetectedSelf = 16,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ne-restartmanager-rm_shutdown_type")]
                enum RM_SHUTDOWN_TYPE {
                    RmForceShutdown = 1,
                    RmShutdownOnlyRegistered = 16,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ns-restartmanager-rm_unique_process")]
                struct RM_UNIQUE_PROCESS {

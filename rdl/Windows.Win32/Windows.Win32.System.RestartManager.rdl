                    RmStatusStopped = 2,
                    RmStatusStoppedOther = 4,
                    RmStatusRestarted = 8,
                    RmStatusErrorOnStop = 16,
                    RmStatusErrorOnRestart = 32,
                    RmStatusShutdownMasked = 64,
                    RmStatusRestartMasked = 128,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ne-restartmanager-rm_app_type")]
                enum RM_APP_TYPE {
                    RmUnknownApp = 0,
                    RmMainWindow = 1,
                    RmOtherWindow = 2,
                    RmService = 3,
                    RmExplorer = 4,
                    RmConsole = 5,
                    RmCritical = 1000,

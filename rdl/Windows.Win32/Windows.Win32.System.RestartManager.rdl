mod Windows {
    mod Win32 {
        mod System {
            #[win32]
            mod RestartManager {
                const CCH_RM_MAX_APP_NAME: u32 = 255;
                const CCH_RM_MAX_SVC_NAME: u32 = 63;
                const CCH_RM_SESSION_KEY: u32 = 32;
                #[repr(i32)]

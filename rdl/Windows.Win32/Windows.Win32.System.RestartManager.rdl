                #[library("rstrtmgr.dll")]
                extern fn RmEndSession(dwSessionHandle: u32) -> super::super::Foundation::WIN32_ERROR;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.0.6000")]

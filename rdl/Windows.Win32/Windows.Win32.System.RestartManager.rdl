                    RmNoShutdown = 2,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ns-restartmanager-rm_filter_info")]
                struct RM_FILTER_INFO {
                    FilterAction: RM_FILTER_ACTION,
                    FilterTrigger: RM_FILTER_TRIGGER,
                    cbNextOffset: u32,
                    Anonymous: union {
                        strFilename: super::super::Foundation::PWSTR,
                        Process: RM_UNIQUE_PROCESS,
                        strServiceShortName: super::super::Foundation::PWSTR,
                    },
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ne-restartmanager-rm_filter_trigger")]
                enum RM_FILTER_TRIGGER {
                    RmFilterTriggerInvalid = 0,
                    RmFilterTriggerFile = 1,
                    RmFilterTriggerProcess = 2,
                    RmFilterTriggerService = 3,
                }
                const RM_INVALID_PROCESS: i32 = -1;
                const RM_INVALID_TS_SESSION: i32 = -1;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/ns-restartmanager-rm_process_info")]
                struct RM_PROCESS_INFO {

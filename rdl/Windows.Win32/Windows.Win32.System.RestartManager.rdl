                #[library("RstrtMgr.dll")]
                extern fn RmRemoveFilter(dwSessionHandle: u32, strModuleName: super::super::Foundation::PWSTR, pProcess: *mut RM_UNIQUE_PROCESS, strServiceShortName: super::super::Foundation::PWSTR) -> super::super::Foundation::WIN32_ERROR;

                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.0.6000")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/nf-restartmanager-rmgetlist")]
                #[library("rstrtmgr.dll")]
                extern fn RmGetList(dwSessionHandle: u32, pnProcInfoNeeded: *mut u32, pnProcInfo: *mut u32, rgAffectedApps: *mut RM_PROCESS_INFO, lpdwRebootReasons: *mut u32) -> super::super::Foundation::WIN32_ERROR;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.0.6000")]

                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.0.6000")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/restartmanager/nf-restartmanager-rmregisterresources")]
                #[library("rstrtmgr.dll")]
                extern fn RmRegisterResources(dwSessionHandle: u32, nFiles: u32, rgsFileNames: *mut super::super::Foundation::PWSTR, nApplications: u32, rgApplications: *mut RM_UNIQUE_PROCESS, nServices: u32, rgsServiceNames: *mut super::super::Foundation::PWSTR) -> super::super::Foundation::WIN32_ERROR;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.0.6000")]

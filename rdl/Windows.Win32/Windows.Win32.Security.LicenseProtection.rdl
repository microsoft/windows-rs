mod Windows {
    mod Win32 {
        mod Security {
            #[win32]
            mod LicenseProtection {
                #[repr(i32)]
                enum LicenseProtectionStatus {
                    Success = 0,
                    LicenseKeyNotFound = 1,
                    LicenseKeyUnprotected = 2,
                    LicenseKeyCorrupted = 3,
                    LicenseKeyAlreadyExists = 4,
                }
                #[library("licenseprotection.dll")]
                extern fn RegisterLicenseKeyWithExpiration(licenseKey: super::super::Foundation::PWSTR, validityInDays: u32, status: *mut LicenseProtectionStatus) -> super::super::Foundation::HRESULT;
                #[library("licenseprotection.dll")]
                extern fn ValidateLicenseKeyProtection(licenseKey: super::super::Foundation::PWSTR, notValidBefore: *mut super::super::Foundation::FILETIME, notValidAfter: *mut super::super::Foundation::FILETIME, status: *mut LicenseProtectionStatus) -> super::super::Foundation::HRESULT;
            }
        }
    }
}

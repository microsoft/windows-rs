mod Windows {
    mod Win32 {
        mod NetworkManagement {
            #[win32]
            mod Multicast {
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-ipng_address")]
                union IPNG_ADDRESS {
                    IpAddrV4: u32,
                    IpAddrV6: [u8; 16],
                }
                const MCAST_API_CURRENT_VERSION: i32 = 1;
                const MCAST_API_VERSION_0: i32 = 0;
                const MCAST_API_VERSION_1: i32 = 1;
                const MCAST_CLIENT_ID_LEN: u32 = 17;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-mcast_client_uid")]
                struct MCAST_CLIENT_UID {
                    ClientUID: *mut u8,
                    ClientUIDLength: u32,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-mcast_lease_request")]
                struct MCAST_LEASE_REQUEST {
                    LeaseStartTime: i32,
                    MaxLeaseStartTime: i32,
                    LeaseDuration: u32,
                    MinLeaseDuration: u32,
                    ServerAddress: IPNG_ADDRESS,
                    MinAddrCount: u16,
                    AddrCount: u16,
                    pAddrBuf: *mut u8,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-mcast_lease_response")]
                struct MCAST_LEASE_RESPONSE {
                    LeaseStartTime: i32,
                    LeaseEndTime: i32,
                    ServerAddress: IPNG_ADDRESS,
                    AddrCount: u16,
                    pAddrBuf: *mut u8,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-mcast_scope_ctx")]
                struct MCAST_SCOPE_CTX {
                    ScopeID: IPNG_ADDRESS,
                    Interface: IPNG_ADDRESS,
                    ServerID: IPNG_ADDRESS,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/ns-madcapcl-mcast_scope_entry")]
                struct MCAST_SCOPE_ENTRY {
                    ScopeCtx: MCAST_SCOPE_CTX,
                    LastAddr: IPNG_ADDRESS,
                    TTL: u32,
                    ScopeDesc: super::super::Foundation::UNICODE_STRING,
                }
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastapicleanup")]
                #[library("dhcpcsvc.dll")]
                extern fn McastApiCleanup();
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastapistartup")]
                #[library("dhcpcsvc.dll")]
                extern fn McastApiStartup(Version: *mut u32) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastenumeratescopes")]
                #[library("dhcpcsvc.dll")]
                extern fn McastEnumerateScopes(AddrFamily: u16, ReQuery: super::super::Foundation::BOOL, pScopeList: *mut MCAST_SCOPE_ENTRY, pScopeLen: *mut u32, pScopeCount: *mut u32) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastgenuid")]
                #[library("dhcpcsvc.dll")]
                extern fn McastGenUID(pRequestID: *mut MCAST_CLIENT_UID) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastreleaseaddress")]
                #[library("dhcpcsvc.dll")]
                extern fn McastReleaseAddress(AddrFamily: u16, pRequestID: *mut MCAST_CLIENT_UID, pReleaseRequest: *mut MCAST_LEASE_REQUEST) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastrenewaddress")]
                #[library("dhcpcsvc.dll")]
                extern fn McastRenewAddress(AddrFamily: u16, pRequestID: *mut MCAST_CLIENT_UID, pRenewRequest: *mut MCAST_LEASE_REQUEST, pRenewResponse: *mut MCAST_LEASE_RESPONSE) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/madcapcl/nf-madcapcl-mcastrequestaddress")]
                #[library("dhcpcsvc.dll")]
                extern fn McastRequestAddress(AddrFamily: u16, pRequestID: *mut MCAST_CLIENT_UID, pScopeCtx: *mut MCAST_SCOPE_CTX, pAddrRequest: *mut MCAST_LEASE_REQUEST, pAddrResponse: *mut MCAST_LEASE_RESPONSE) -> u32;
            }
        }
    }
}

                        Flags: XINPUT_CAPABILITIES_FLAGS,
                        Gamepad: XINPUT_GAMEPAD,
                        Vibration: XINPUT_VIBRATION,
                    }
                    #[repr(u16)]
                    #[flags]
                    enum XINPUT_CAPABILITIES_FLAGS {
                        XINPUT_CAPS_VOICE_SUPPORTED = 4,
                        XINPUT_CAPS_FFB_SUPPORTED = 1,
                        XINPUT_CAPS_WIRELESS = 2,
                        XINPUT_CAPS_PMD_SUPPORTED = 8,
                        XINPUT_CAPS_NO_NAVIGATION = 16,
                    }
                    #[repr(u8)]
                    enum XINPUT_DEVSUBTYPE {
                        XINPUT_DEVSUBTYPE_GAMEPAD = 1,
                        XINPUT_DEVSUBTYPE_UNKNOWN = 0,
                        XINPUT_DEVSUBTYPE_WHEEL = 2,
                        XINPUT_DEVSUBTYPE_ARCADE_STICK = 3,
                        XINPUT_DEVSUBTYPE_FLIGHT_STICK = 4,
                        XINPUT_DEVSUBTYPE_DANCE_PAD = 5,
                        XINPUT_DEVSUBTYPE_GUITAR = 6,
                        XINPUT_DEVSUBTYPE_GUITAR_ALTERNATE = 7,
                        XINPUT_DEVSUBTYPE_DRUM_KIT = 8,
                        XINPUT_DEVSUBTYPE_GUITAR_BASS = 11,
                        XINPUT_DEVSUBTYPE_ARCADE_PAD = 19,
                    }
                    #[repr(u8)]
                    enum XINPUT_DEVTYPE {
                        XINPUT_DEVTYPE_GAMEPAD = 1,
                    }
                    const XINPUT_DLL: String = "xinput1_4.dll";
                    #[Windows::Win32::Foundation::Metadata::NativeEncoding("ansi")]
                    const XINPUT_DLL_A: String = "xinput1_4.dll";
                    const XINPUT_DLL_W: String = "xinput1_4.dll";
                    #[repr(u32)]
                    #[flags]
                    enum XINPUT_FLAG {
                        XINPUT_FLAG_ALL = 0,
                        XINPUT_FLAG_GAMEPAD = 1,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/xinput/ns-xinput-xinput_gamepad")]
                    struct XINPUT_GAMEPAD {
                        wButtons: XINPUT_GAMEPAD_BUTTON_FLAGS,
                        bLeftTrigger: u8,
                        bRightTrigger: u8,
                        sThumbLX: i16,
                        sThumbLY: i16,
                        sThumbRX: i16,
                        sThumbRY: i16,
                    }
                    #[repr(u16)]
                    #[flags]
                    enum XINPUT_GAMEPAD_BUTTON_FLAGS {
                        XINPUT_GAMEPAD_DPAD_UP = 1,
                        XINPUT_GAMEPAD_DPAD_DOWN = 2,
                        XINPUT_GAMEPAD_DPAD_LEFT = 4,
                        XINPUT_GAMEPAD_DPAD_RIGHT = 8,
                        XINPUT_GAMEPAD_START = 16,
                        XINPUT_GAMEPAD_BACK = 32,
                        XINPUT_GAMEPAD_LEFT_THUMB = 64,
                        XINPUT_GAMEPAD_RIGHT_THUMB = 128,
                        XINPUT_GAMEPAD_LEFT_SHOULDER = 256,
                        XINPUT_GAMEPAD_RIGHT_SHOULDER = 512,
                        XINPUT_GAMEPAD_A = 4096,
                        XINPUT_GAMEPAD_B = 8192,
                        XINPUT_GAMEPAD_X = 16384,
                        XINPUT_GAMEPAD_Y = 32768,
                        XINPUT_GAMEPAD_LEFT_THUMB_DEADZONE = 7849,
                        XINPUT_GAMEPAD_RIGHT_THUMB_DEADZONE = 8689,
                        XINPUT_GAMEPAD_TRIGGER_THRESHOLD = 30,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/xinput/ns-xinput-xinput_keystroke")]
                    struct XINPUT_KEYSTROKE {
                        VirtualKey: XINPUT_VIRTUAL_KEY,
                        Unicode: u16,
                        Flags: XINPUT_KEYSTROKE_FLAGS,
                        UserIndex: u8,
                        HidCode: u8,
                    }
                    #[repr(u16)]
                    #[flags]
                    enum XINPUT_KEYSTROKE_FLAGS {
                        XINPUT_KEYSTROKE_KEYDOWN = 1,
                        XINPUT_KEYSTROKE_KEYUP = 2,
                        XINPUT_KEYSTROKE_REPEAT = 4,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/xinput/ns-xinput-xinput_state")]
                    struct XINPUT_STATE {

mod Windows {
    mod Win32 {
        mod UI {
            mod Input {
                #[win32]
                mod XboxController {
                    #[repr(u8)]
                    enum BATTERY_DEVTYPE {
                        BATTERY_DEVTYPE_GAMEPAD = 0,
                        BATTERY_DEVTYPE_HEADSET = 1,
                    }
                    #[repr(u8)]
                    enum BATTERY_LEVEL {
                        BATTERY_LEVEL_EMPTY = 0,
                        BATTERY_LEVEL_LOW = 1,
                        BATTERY_LEVEL_MEDIUM = 2,
                        BATTERY_LEVEL_FULL = 3,
                    }
                    #[repr(u8)]
                    enum BATTERY_TYPE {
                        BATTERY_TYPE_DISCONNECTED = 0,
                        BATTERY_TYPE_WIRED = 1,
                        BATTERY_TYPE_ALKALINE = 2,
                        BATTERY_TYPE_NIMH = 3,
                        BATTERY_TYPE_UNKNOWN = 255,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/xinput/ns-xinput-xinput_battery_information")]
                    struct XINPUT_BATTERY_INFORMATION {
                        BatteryType: BATTERY_TYPE,
                        BatteryLevel: BATTERY_LEVEL,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/xinput/ns-xinput-xinput_capabilities")]
                    struct XINPUT_CAPABILITIES {
                        Type: XINPUT_DEVTYPE,

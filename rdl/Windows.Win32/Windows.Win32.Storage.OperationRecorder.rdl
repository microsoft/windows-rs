mod Windows {
    mod Win32 {
        mod Storage {
            #[win32]
            mod OperationRecorder {
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/ns-winbase-operation_end_parameters")]
                struct OPERATION_END_PARAMETERS {
                    Version: u32,
                    OperationId: u32,
                    Flags: OPERATION_END_PARAMETERS_FLAGS,
                }
                #[repr(u32)]
                #[flags]
                enum OPERATION_END_PARAMETERS_FLAGS {
                    OPERATION_END_DISCARD = 1,
                }
                #[repr(u32)]
                #[flags]
                enum OPERATION_START_FLAGS {
                    OPERATION_START_TRACE_CURRENT_THREAD = 1,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/ns-winbase-operation_start_parameters")]
                struct OPERATION_START_PARAMETERS {
                    Version: u32,
                    OperationId: u32,
                    Flags: OPERATION_START_FLAGS,
                }
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows8.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-operationend")]
                #[library("ADVAPI32.dll")]
                extern fn OperationEnd(OperationEndParams: *mut OPERATION_END_PARAMETERS) -> super::super::Foundation::BOOL;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows8.0")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-operationstart")]
                #[library("ADVAPI32.dll")]
                extern fn OperationStart(OperationStartParams: *mut OPERATION_START_PARAMETERS) -> super::super::Foundation::BOOL;
            }
        }
    }
}

                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/ndattrib/ns-ndattrib-uiinfo")]
                struct UiInfo {
                    r#type: UI_INFO_TYPE,
                    Anonymous: union {
                        pwzNull: super::super::Foundation::PWSTR,
                        ShellInfo: ShellCommandInfo,
                        pwzHelpUrl: super::super::Foundation::PWSTR,
                        pwzDui: super::super::Foundation::PWSTR,
                    },
                }
            }
        }
    }
}

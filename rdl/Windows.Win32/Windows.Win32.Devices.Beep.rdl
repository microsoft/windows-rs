mod Windows {
    mod Win32 {
        mod Devices {
            #[win32]
            mod Beep {
                const BEEP_FREQUENCY_MAXIMUM: u32 = 32767;
                const BEEP_FREQUENCY_MINIMUM: u32 = 37;
                struct BEEP_SET_PARAMETERS {
                    Frequency: u32,
                    Duration: u32,
                }
                #[Windows::Win32::Foundation::Metadata::NativeEncoding("ansi")]
                const DD_BEEP_DEVICE_NAME: String = "\\Device\\Beep";
                const DD_BEEP_DEVICE_NAME_U: String = "\\Device\\Beep";
                const IOCTL_BEEP_SET: u32 = 65536;
            }
        }
    }
}

                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/UIAnimation/ui-animation-seconds-eventually")]
                const UI_ANIMATION_SECONDS_EVENTUALLY: i32 = -1;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/UIAnimation/ui-animation-seconds-infinite")]
                const UI_ANIMATION_SECONDS_INFINITE: i32 = -1;
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/uianimation/ne-uianimation-ui_animation_slope")]
                enum UI_ANIMATION_SLOPE {
                    UI_ANIMATION_SLOPE_INCREASING = 0,
                    UI_ANIMATION_SLOPE_DECREASING = 1,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/uianimation/ne-uianimation-ui_animation_storyboard_status")]
                enum UI_ANIMATION_STORYBOARD_STATUS {
                    UI_ANIMATION_STORYBOARD_BUILDING = 0,
                    UI_ANIMATION_STORYBOARD_SCHEDULED = 1,
                    UI_ANIMATION_STORYBOARD_CANCELLED = 2,
                    UI_ANIMATION_STORYBOARD_PLAYING = 3,
                    UI_ANIMATION_STORYBOARD_TRUNCATED = 4,
                    UI_ANIMATION_STORYBOARD_FINISHED = 5,
                    UI_ANIMATION_STORYBOARD_READY = 6,
                    UI_ANIMATION_STORYBOARD_INSUFFICIENT_PRIORITY = 7,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/uianimation/ne-uianimation-ui_animation_timer_client_status")]
                enum UI_ANIMATION_TIMER_CLIENT_STATUS {
                    UI_ANIMATION_TIMER_CLIENT_IDLE = 0,
                    UI_ANIMATION_TIMER_CLIENT_BUSY = 1,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/uianimation/ne-uianimation-ui_animation_update_result")]
                enum UI_ANIMATION_UPDATE_RESULT {
                    UI_ANIMATION_UPDATE_NO_CHANGE = 0,
                    UI_ANIMATION_UPDATE_VARIABLES_CHANGED = 1,
                }
            }
        }
    }
}

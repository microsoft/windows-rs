                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/dlgbox/wm-psd-yafullpagerect")]
                    const WM_PSD_YAFULLPAGERECT: u32 = 1030;
                }
            }
        }
    }
}

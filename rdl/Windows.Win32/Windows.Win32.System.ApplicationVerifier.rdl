mod Windows {
    mod Win32 {
        mod System {
            #[win32]
            mod ApplicationVerifier {
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ns-avrfsdk-avrf_backtrace_information")]
                struct AVRF_BACKTRACE_INFORMATION {
                    Depth: u32,
                    Index: u32,
                    ReturnAddresses: [u64; 32],
                }
                extern fn AVRF_HANDLEOPERATION_ENUMERATE_CALLBACK(HandleOperation: *mut AVRF_HANDLE_OPERATION, EnumerationContext: *mut void, EnumerationLevel: *mut u32) -> u32;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ns-avrfsdk-avrf_handle_operation")]
                struct AVRF_HANDLE_OPERATION {
                    Handle: u64,
                    ProcessId: u32,
                    ThreadId: u32,
                    OperationType: u32,
                    Spare0: u32,
                    BackTraceInformation: AVRF_BACKTRACE_INFORMATION,
                }
                extern fn AVRF_HEAPALLOCATION_ENUMERATE_CALLBACK(HeapAllocation: *mut AVRF_HEAP_ALLOCATION, EnumerationContext: *mut void, EnumerationLevel: *mut u32) -> u32;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ns-avrfsdk-avrf_heap_allocation")]
                struct AVRF_HEAP_ALLOCATION {
                    HeapHandle: u64,
                    UserAllocation: u64,
                    UserAllocationSize: u64,
                    Allocation: u64,
                    AllocationSize: u64,
                    UserAllocationState: u32,
                    HeapState: u32,
                    HeapContext: u64,
                    BackTraceInformation: *mut AVRF_BACKTRACE_INFORMATION,
                }
                const AVRF_MAX_TRACES: u32 = 32;
                extern fn AVRF_RESOURCE_ENUMERATE_CALLBACK(ResourceDescription: *mut void, EnumerationContext: *mut void, EnumerationLevel: *mut u32) -> u32;
                #[repr(u32)]
                #[flags]
                enum VERIFIER_ENUM_RESOURCE_FLAGS {
                    AVRF_ENUM_RESOURCES_FLAGS_DONT_RESOLVE_TRACES = 2,
                    AVRF_ENUM_RESOURCES_FLAGS_SUSPEND = 1,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/nf-avrfsdk-verifierenumerateresource")]
                #[library("verifier.dll")]
                extern fn VerifierEnumerateResource(Process: super::super::Foundation::HANDLE, Flags: VERIFIER_ENUM_RESOURCE_FLAGS, ResourceType: u32, ResourceCallback: AVRF_RESOURCE_ENUMERATE_CALLBACK, EnumerationContext: *mut void) -> u32;
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ne-avrfsdk-eavrfresourcetypes")]
                enum eAvrfResourceTypes {
                    AvrfResourceHeapAllocation = 0,
                    AvrfResourceHandleTrace = 1,
                    AvrfResourceMax = 2,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ne-avrfsdk-ehandle_trace_operations")]
                enum eHANDLE_TRACE_OPERATIONS {
                    OperationDbUnused = 0,
                    OperationDbOPEN = 1,
                    OperationDbCLOSE = 2,
                    OperationDbBADREF = 3,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ne-avrfsdk-eheapallocationstate")]
                enum eHeapAllocationState {
                    HeapFullPageHeap = 1073741824,
                    HeapMetadata = -2147483648,
                    HeapStateMask = -65536,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ne-avrfsdk-eheapenumerationlevel")]
                enum eHeapEnumerationLevel {
                    HeapEnumerationEverything = 0,
                    HeapEnumerationStop = -1,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/avrfsdk/ne-avrfsdk-euserallocationstate")]
                enum eUserAllocationState {
                    AllocationStateUnknown = 0,
                    AllocationStateBusy = 1,
                    AllocationStateFree = 2,
                }
            }
        }
    }
}

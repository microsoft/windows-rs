mod Windows {
    mod Win32 {
        mod System {
            mod Performance {
                #[win32]
                mod HardwareCounterProfiling {
                    #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.1")]
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-disablethreadprofiling")]
                    #[library("KERNEL32.dll")]
                    extern fn DisableThreadProfiling(PerformanceDataHandle: super::super::super::Foundation::HANDLE) -> u32;
                    #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.1")]
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-enablethreadprofiling")]
                    #[library("KERNEL32.dll")]
                    extern fn EnableThreadProfiling(ThreadHandle: super::super::super::Foundation::HANDLE, Flags: u32, HardwareCounters: u64, PerformanceDataHandle: *mut super::super::super::Foundation::HANDLE) -> u32;
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winnt/ns-winnt-hardware_counter_data")]
                    struct HARDWARE_COUNTER_DATA {
                        Type: HARDWARE_COUNTER_TYPE,
                        Reserved: u32,
                        Value: u64,
                    }
                    #[repr(i32)]
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winnt/ne-winnt-hardware_counter_type")]
                    enum HARDWARE_COUNTER_TYPE {
                        PMCCounter = 0,
                        MaxHardwareCounterType = 1,
                    }
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winnt/ns-winnt-performance_data")]
                    struct PERFORMANCE_DATA {
                        Size: u16,
                        Version: u8,
                        HwCountersCount: u8,
                        ContextSwitchCount: u32,
                        WaitReasonBitMap: u64,
                        CycleTime: u64,
                        RetryCount: u32,
                        Reserved: u32,
                        HwCounters: [HARDWARE_COUNTER_DATA; 16],
                    }
                    #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.1")]
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-querythreadprofiling")]
                    #[library("KERNEL32.dll")]
                    extern fn QueryThreadProfiling(ThreadHandle: super::super::super::Foundation::HANDLE, Enabled: *mut super::super::super::Foundation::BOOLEAN) -> u32;
                    #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows6.1")]
                    #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/winbase/nf-winbase-readthreadprofilingdata")]
                    #[library("KERNEL32.dll")]
                    extern fn ReadThreadProfilingData(PerformanceDataHandle: super::super::super::Foundation::HANDLE, Flags: u32, PerformanceData: *mut PERFORMANCE_DATA) -> u32;
                }
            }
        }
    }
}

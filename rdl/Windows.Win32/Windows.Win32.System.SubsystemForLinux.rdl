                    WSL_DISTRIBUTION_FLAGS_ENABLE_INTEROP = 1,
                    WSL_DISTRIBUTION_FLAGS_APPEND_NT_PATH = 2,
                    WSL_DISTRIBUTION_FLAGS_ENABLE_DRIVE_MOUNTING = 4,
                }

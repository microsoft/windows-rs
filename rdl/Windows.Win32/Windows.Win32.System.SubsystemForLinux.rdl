                #[library("Api-ms-win-wsl-api-l1-1-0.dll")]
                extern fn WslIsDistributionRegistered(distributionName: super::super::Foundation::PWSTR) -> super::super::Foundation::BOOL;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wslapi/nf-wslapi-wsllaunch")]
                #[library("Api-ms-win-wsl-api-l1-1-0.dll")]
                extern fn WslLaunch(distributionName: super::super::Foundation::PWSTR, command: super::super::Foundation::PWSTR, useCurrentWorkingDirectory: super::super::Foundation::BOOL, stdIn: super::super::Foundation::HANDLE, stdOut: super::super::Foundation::HANDLE, stdErr: super::super::Foundation::HANDLE, process: *mut super::super::Foundation::HANDLE) -> super::super::Foundation::HRESULT;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wslapi/nf-wslapi-wsllaunchinteractive")]

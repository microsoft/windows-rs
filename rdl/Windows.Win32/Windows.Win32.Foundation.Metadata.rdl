mod Windows {
    mod Win32 {
        mod Foundation {
            #[win32]
            mod Metadata {
                #[System::AttributeUsage(1024, AllowMultiple = false, Inherited = true)]
                attribute AgileAttribute {
                    fn();
                }
                attribute AlsoUsableForAttribute {
                    fn(otherType: String);
                }
                attribute AnsiAttribute {
                    fn();
                }
                #[repr(i32)]
                #[flags]
                enum Architecture {
                    None = 0,
                    X86 = 1,
                    X64 = 2,
                    Arm64 = 4,
                    All = 7,
                }
                #[System::AttributeUsage(16, AllowMultiple = true)]
                attribute AssociatedConstantAttribute {
                    fn(Name: String);
                }
                attribute AssociatedEnumAttribute {
                    fn(Name: String);
                }
                attribute CanReturnErrorsAsSuccessAttribute {
                    fn();
                }
                attribute CanReturnMultipleSuccessValuesAttribute {
                    fn();
                }
                #[System::AttributeUsage(2048, AllowMultiple = false, Inherited = true)]
                attribute ComOutPtrAttribute {
                    fn();
                }
                attribute ConstAttribute {
                    fn();
                }
                attribute ConstantAttribute {
                    fn(Value: String);
                }
                #[System::AttributeUsage(10648, AllowMultiple = false, Inherited = false)]
                #[System::Runtime::InteropServices::ComVisible(true)]
                attribute CppAttributeList {
                    fn(AttributeList: String);
                }
                attribute DoNotReleaseAttribute {
                    fn();
                }
                attribute DocumentationAttribute {
                    fn(Uri: String);
                }
                #[System::AttributeUsage(256, AllowMultiple = false, Inherited = false)]
                attribute FlexibleArrayAttribute {
                    fn();
                }
                #[System::AttributeUsage(10648, AllowMultiple = false, Inherited = false)]
                #[System::Runtime::InteropServices::ComVisible(true)]
                attribute FreeWithAttribute {
                    fn(Name: String);
                }
                attribute GuidAttribute {
                    fn(a: u32, b: u16, c: u16, d: u8, e: u8, f: u8, g: u8, h: u8, i: u8, j: u8, k: u8);
                }
                #[System::AttributeUsage(2048, AllowMultiple = true)]
                attribute IgnoreIfReturnAttribute {
                    fn(Value: String);
                }
                #[System::AttributeUsage(8, AllowMultiple = true, Inherited = true)]
                attribute InvalidHandleValueAttribute {
                    fn(Value: i64);
                }
                attribute MemorySizeAttribute {
                    fn();
                    BytesParamIndex: i16,
                }
                #[System::AttributeUsage(8, AllowMultiple = false)]
                attribute MetadataTypedefAttribute {
                    fn();
                }
                attribute NativeArrayInfoAttribute {
                    fn();
                    CountConst: i32,
                    CountParamIndex: i16,
                    CountFieldName: String,
                }
                #[System::AttributeUsage(256, AllowMultiple = true, Inherited = true)]
                attribute NativeBitfieldAttribute {
                    fn(name: String, offset: i64, length: i64);
                }
                #[System::AttributeUsage(128, AllowMultiple = false, Inherited = false)]
                #[System::Runtime::InteropServices::ComVisible(true)]
                attribute NativeEncodingAttribute {
                    fn(Name: String);
                }
                #[System::AttributeUsage(8, AllowMultiple = false, Inherited = true)]
                attribute NativeInheritanceAttribute {
                    fn(BaseName: String);
                }
                #[System::AttributeUsage(10648, AllowMultiple = false, Inherited = false)]
                #[System::Runtime::InteropServices::ComVisible(true)]
                attribute NativeTypeNameAttribute {
                    fn(Name: String);
                }
                #[System::AttributeUsage(8, AllowMultiple = false)]
                attribute NativeTypedefAttribute {
                    fn();
                }
                attribute NotNullTerminatedAttribute {
                    fn();
                }
                attribute NullNullTerminatedAttribute {
                    fn();
                }
                attribute RAIIFreeAttribute {
                    fn(Name: String);
                }
                attribute ReservedAttribute {
                    fn();
                }
                #[System::AttributeUsage(2048, AllowMultiple = false, Inherited = true)]
                attribute RetValAttribute {
                    fn();
                }
                #[System::AttributeUsage(2048, AllowMultiple = false, Inherited = true)]
                attribute RetainedAttribute {
                    fn();
                }
                attribute ScopedEnumAttribute {
                    fn();
                }
                #[System::AttributeUsage(64, Inherited = false)]
                attribute StaticLibraryAttribute {
                    fn(LibName: String);
                }
                attribute StructSizeFieldAttribute {
                    fn(field: String);
                }
                attribute SupportedArchitectureAttribute {
                    fn(arch: Architecture);
                }
                #[System::AttributeUsage(1096, AllowMultiple = false)]
                attribute SupportedOSPlatformAttribute {
                    fn(platform: String);
                }
                attribute UnicodeAttribute {
                    fn();
                }
            }
        }
    }
}

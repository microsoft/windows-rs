                    SRBsIgnored: u32,
                    SRBsMissing: u32,
                    InternalErrors: u32,
                    ExternalErrors: u32,
                    Discontinuities: u32,
                    LineConfidenceAvg: u32,
                    BytesOutput: u32,
                }
                struct VBICODECFILTERING_STATISTICS_NABTS {
                    Common: VBICODECFILTERING_STATISTICS_COMMON,
                    FECBundleBadLines: u32,
                    FECQueueOverflows: u32,
                    FECCorrectedLines: u32,
                    FECUncorrectableLines: u32,
                    BundlesProcessed: u32,
                    BundlesSent2IP: u32,
                    FilteredLines: u32,
                }
                struct VBICODECFILTERING_STATISTICS_NABTS_PIN {
                    Common: VBICODECFILTERING_STATISTICS_COMMON_PIN,
                }
                struct VBICODECFILTERING_STATISTICS_TELETEXT {
                    Common: VBICODECFILTERING_STATISTICS_COMMON,
                }
                struct VBICODECFILTERING_STATISTICS_TELETEXT_PIN {
                    Common: VBICODECFILTERING_STATISTICS_COMMON_PIN,
                }
                struct VRAM_SURFACE_INFO {
                    hSurface: usize,
                    VramPhysicalAddress: i64,
                    cbCaptured: u32,
                    dwWidth: u32,
                    dwHeight: u32,
                    dwLinearSize: u32,
                    lPitch: i32,
                    ullReserved: [u64; 16],
                }
                struct VRAM_SURFACE_INFO_PROPERTY_S {
                    Property: KSIDENTIFIER,
                    pVramSurfaceInfo: *mut VRAM_SURFACE_INFO,
                }
                const WAVE_FORMAT_EXTENSIBLE: u32 = 65534;
                struct WNF_KSCAMERA_STREAMSTATE_INFO {
                    ProcessId: u32,
                    SessionId: u32,
                    StreamState: u32,
                    Reserved: u32,
                }
                struct WST_BUFFER {
                    ScanlinesRequested: VBICODECFILTERING_SCANLINES,
                    WstLines: [WST_BUFFER_LINE; 17],
                }
                struct WST_BUFFER_LINE {
                    Confidence: u8,
                    Bytes: [u8; 42],
                }
                const WST_BYTES_PER_LINE: u32 = 42;
                const WST_TVTUNER_CHANGE_BEGIN_TUNE: i32 = 4096;
                const WST_TVTUNER_CHANGE_END_TUNE: i32 = 8192;
            }
        }
    }
}

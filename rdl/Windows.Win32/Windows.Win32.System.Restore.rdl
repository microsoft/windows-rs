mod Windows {
    mod Win32 {
        mod System {
            #[win32]
            mod Restore {
                const ACCESSIBILITY_SETTING: u32 = 3;
                const APPLICATION_RUN: u32 = 5;
                const BACKUP: u32 = 15;
                const BACKUP_RECOVERY: u32 = 14;
                const BEGIN_NESTED_SYSTEM_CHANGE_NORP: u32 = 104;
                const CHECKPOINT: u32 = 7;
                const CRITICAL_UPDATE: u32 = 18;
                const DESKTOP_SETTING: u32 = 2;
                const FIRSTRUN: u32 = 11;
                const MANUAL_CHECKPOINT: u32 = 16;
                const MAX_DESC: u32 = 64;
                const MAX_DESC_W: u32 = 256;
                const MAX_EVENT: u32 = 104;
                const MAX_RPT: u32 = 18;
                const MIN_EVENT: u32 = 100;
                const MIN_RPT: u32 = 0;
                const OE_SETTING: u32 = 4;
                const RESTORE: u32 = 6;
                #[Windows::Win32::Foundation::Metadata::Ansi]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/ns-srrestoreptapi-restorepointinfoa")]
                struct RESTOREPOINTINFOA {
                    dwEventType: RESTOREPOINTINFO_EVENT_TYPE,
                    dwRestorePtType: RESTOREPOINTINFO_TYPE,
                    llSequenceNumber: i64,
                    szDescription: [super::super::Foundation::CHAR; 64],
                }
                struct RESTOREPOINTINFOEX {
                    ftCreation: super::super::Foundation::FILETIME,
                    dwEventType: u32,
                    dwRestorePtType: u32,
                    dwRPNum: u32,
                    szDescription: [u16; 256],
                }
                #[Windows::Win32::Foundation::Metadata::Unicode]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/ns-srrestoreptapi-restorepointinfow")]
                struct RESTOREPOINTINFOW {
                    dwEventType: RESTOREPOINTINFO_EVENT_TYPE,
                    dwRestorePtType: RESTOREPOINTINFO_TYPE,
                    llSequenceNumber: i64,
                    szDescription: [u16; 256],
                }
                #[repr(u32)]
                enum RESTOREPOINTINFO_EVENT_TYPE {
                    BEGIN_NESTED_SYSTEM_CHANGE = 102,
                    BEGIN_SYSTEM_CHANGE = 100,
                    END_NESTED_SYSTEM_CHANGE = 103,
                    END_SYSTEM_CHANGE = 101,
                }
                #[repr(u32)]
                enum RESTOREPOINTINFO_TYPE {
                    APPLICATION_INSTALL = 0,
                    APPLICATION_UNINSTALL = 1,
                    DEVICE_DRIVER_INSTALL = 10,
                    MODIFY_SETTINGS = 12,
                    CANCELLED_OPERATION = 13,
                }
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.1.2600")]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/nf-srrestoreptapi-srremoverestorepoint")]
                #[library("SrClient.dll")]
                extern fn SRRemoveRestorePoint(dwRPNum: u32) -> u32;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.1.2600")]
                #[Windows::Win32::Foundation::Metadata::Ansi]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/nf-srrestoreptapi-srsetrestorepointa")]
                #[library("sfc.dll")]
                extern fn SRSetRestorePointA(pRestorePtSpec: *mut RESTOREPOINTINFOA, pSMgrStatus: *mut STATEMGRSTATUS) -> super::super::Foundation::BOOL;
                #[Windows::Win32::Foundation::Metadata::SupportedOSPlatform("windows5.1.2600")]
                #[Windows::Win32::Foundation::Metadata::Unicode]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/nf-srrestoreptapi-srsetrestorepointw")]
                #[library("sfc.dll")]
                extern fn SRSetRestorePointW(pRestorePtSpec: *mut RESTOREPOINTINFOW, pSMgrStatus: *mut STATEMGRSTATUS) -> super::super::Foundation::BOOL;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/srrestoreptapi/ns-srrestoreptapi-statemgrstatus")]
                struct STATEMGRSTATUS {
                    nStatus: super::super::Foundation::WIN32_ERROR,
                    llSequenceNumber: i64,
                }
                const WINDOWS_BOOT: u32 = 9;
                const WINDOWS_SHUTDOWN: u32 = 8;
                const WINDOWS_UPDATE: u32 = 17;
            }
        }
    }
}

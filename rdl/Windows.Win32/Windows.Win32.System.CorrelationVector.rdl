mod Windows {
    mod Win32 {
        mod System {
            #[win32]
            mod CorrelationVector {
                struct CORRELATION_VECTOR {
                    Version: super::super::Foundation::CHAR,
                    Vector: [super::super::Foundation::CHAR; 129],
                }
                const RTL_CORRELATION_VECTOR_STRING_LENGTH: u32 = 129;
                const RTL_CORRELATION_VECTOR_V1_LENGTH: u32 = 64;
                const RTL_CORRELATION_VECTOR_V1_PREFIX_LENGTH: u32 = 16;
                const RTL_CORRELATION_VECTOR_V2_LENGTH: u32 = 128;
                const RTL_CORRELATION_VECTOR_V2_PREFIX_LENGTH: u32 = 22;
                #[library("ntdll.dll")]
                extern fn RtlExtendCorrelationVector(CorrelationVector: *mut CORRELATION_VECTOR) -> u32;
                #[library("ntdll.dll")]
                extern fn RtlIncrementCorrelationVector(CorrelationVector: *mut CORRELATION_VECTOR) -> u32;
                #[library("ntdll.dll")]
                extern fn RtlInitializeCorrelationVector(CorrelationVector: *mut CORRELATION_VECTOR, Version: i32, Guid: *mut GUID) -> u32;
                #[library("ntdll.dll")]
                extern fn RtlValidateCorrelationVector(Vector: *mut CORRELATION_VECTOR) -> u32;
            }
        }
    }
}

mod Windows {
    mod Win32 {
        mod System {
            #[win32]
            mod DeveloperLicensing {
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wsdevlicensing/nf-wsdevlicensing-acquiredeveloperlicense")]
                #[library("WSClient.dll")]
                extern fn AcquireDeveloperLicense(hwndParent: super::super::Foundation::HWND, pExpiration: *mut super::super::Foundation::FILETIME) -> super::super::Foundation::HRESULT;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wsdevlicensing/nf-wsdevlicensing-checkdeveloperlicense")]
                #[library("WSClient.dll")]
                extern fn CheckDeveloperLicense(pExpiration: *mut super::super::Foundation::FILETIME) -> super::super::Foundation::HRESULT;
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wsdevlicensing/nf-wsdevlicensing-removedeveloperlicense")]
                #[library("WSClient.dll")]
                extern fn RemoveDeveloperLicense(hwndParent: super::super::Foundation::HWND) -> super::super::Foundation::HRESULT;
            }
        }
    }
}

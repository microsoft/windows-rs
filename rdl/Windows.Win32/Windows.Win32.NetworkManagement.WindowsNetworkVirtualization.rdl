mod Windows {
    mod Win32 {
        mod NetworkManagement {
            #[win32]
            mod WindowsNetworkVirtualization {
                const WNV_API_MAJOR_VERSION_1: u32 = 1;
                const WNV_API_MINOR_VERSION_0: u32 = 0;
                #[repr(i32)]
                enum WNV_CA_NOTIFICATION_TYPE {
                    WnvCustomerAddressAdded = 0,
                    WnvCustomerAddressDeleted = 1,
                    WnvCustomerAddressMoved = 2,
                    WnvCustomerAddressMax = 3,
                }
                struct WNV_CUSTOMER_ADDRESS_CHANGE_PARAM {
                    MACAddress: super::super::Networking::WinSock::DL_EUI48,
                    CAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    CA: WNV_IP_ADDRESS,
                    VirtualSubnetId: u32,
                    PAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    PA: WNV_IP_ADDRESS,
                    NotificationReason: WNV_CA_NOTIFICATION_TYPE,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_ip_address")]
                struct WNV_IP_ADDRESS {
                    IP: union {
                        v4: super::super::Networking::WinSock::IN_ADDR,
                        v6: super::super::Networking::WinSock::IN6_ADDR,
                        Addr: [u8; 16],
                    },
                }

                struct WNV_NOTIFICATION_PARAM {
                    Header: WNV_OBJECT_HEADER,
                    NotificationType: WNV_NOTIFICATION_TYPE,
                    PendingNotifications: u32,
                    Buffer: *mut u8,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ne-wnvapi-wnv_notification_type")]
                enum WNV_NOTIFICATION_TYPE {
                    WnvPolicyMismatchType = 0,
                    WnvRedirectType = 1,
                    WnvObjectChangeType = 2,
                    WnvNotificationTypeMax = 3,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_object_change_param")]
                struct WNV_OBJECT_CHANGE_PARAM {
                    ObjectType: WNV_OBJECT_TYPE,
                    ObjectParam: union {
                        ProviderAddressChange: WNV_PROVIDER_ADDRESS_CHANGE_PARAM,
                        CustomerAddressChange: WNV_CUSTOMER_ADDRESS_CHANGE_PARAM,
                    },
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_object_header")]
                struct WNV_OBJECT_HEADER {
                    MajorVersion: u8,
                    MinorVersion: u8,
                    Size: u32,
                }
                #[repr(i32)]
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ne-wnvapi-wnv_object_type")]
                enum WNV_OBJECT_TYPE {
                    WnvProviderAddressType = 0,
                    WnvCustomerAddressType = 1,
                    WnvObjectTypeMax = 2,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_policy_mismatch_param")]
                struct WNV_POLICY_MISMATCH_PARAM {
                    CAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    PAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    VirtualSubnetId: u32,
                    CA: WNV_IP_ADDRESS,
                    PA: WNV_IP_ADDRESS,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_provider_address_change_param")]
                struct WNV_PROVIDER_ADDRESS_CHANGE_PARAM {
                    PAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    PA: WNV_IP_ADDRESS,
                    AddressState: super::super::Networking::WinSock::NL_DAD_STATE,
                }
                #[Windows::Win32::Foundation::Metadata::Documentation("https://learn.microsoft.com/windows/win32/api/wnvapi/ns-wnvapi-wnv_redirect_param")]
                struct WNV_REDIRECT_PARAM {
                    CAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    PAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    NewPAFamily: super::super::Networking::WinSock::ADDRESS_FAMILY,
                    VirtualSubnetId: u32,
                    CA: WNV_IP_ADDRESS,
                    PA: WNV_IP_ADDRESS,
                    NewPA: WNV_IP_ADDRESS,

                #[library("wnvapi.dll")]
                extern fn WnvRequestNotification(WnvHandle: super::super::Foundation::HANDLE, NotificationParam: *mut WNV_NOTIFICATION_PARAM, Overlapped: *mut super::super::System::IO::OVERLAPPED, BytesTransferred: *mut u32) -> u32;
            }
        }
    }
}

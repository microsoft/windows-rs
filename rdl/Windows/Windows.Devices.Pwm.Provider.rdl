mod Windows {
    mod Devices {
        mod Pwm {
            #[winrt]
            mod Provider {
                #[Windows::Foundation::Metadata::ContractVersion(super::super::DevicesLowLevelContract, 65536)]
                interface IPwmControllerProvider {
                    #[special]
                    fn get_PinCount(&self) -> i32;
                    #[special]
                    fn get_ActualFrequency(&self) -> f64;
                    fn SetDesiredFrequency(&self, frequency: f64) -> f64;
                    #[special]
                    fn get_MaxFrequency(&self) -> f64;
                    #[special]
                    fn get_MinFrequency(&self) -> f64;
                    fn AcquirePin(&self, pin: i32);
                    fn ReleasePin(&self, pin: i32);
                    fn EnablePin(&self, pin: i32);
                    fn DisablePin(&self, pin: i32);
                    fn SetPulseParameters(&self, pin: i32, dutyCycle: f64, invertPolarity: bool);
                }
                #[Windows::Foundation::Metadata::ContractVersion(super::super::DevicesLowLevelContract, 65536)]
                interface IPwmProvider {
                    fn GetControllers(&self) -> super::super::super::Foundation::Collections::IVectorView<IPwmControllerProvider>;

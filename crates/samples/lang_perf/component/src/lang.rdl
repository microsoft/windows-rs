use Windows::Foundation::Metadata::*;

#[winrt]
mod LangPerf {
    #[Activatable(1)]
    #[MarshalingBehavior(Agile)]
    class Class {
        IClass,
    }

    #[ExclusiveTo(Class)]
    interface IClass {
        Int32Property: i32;
        StringProperty: String;
        ObjectProperty: Object;
        fn Next(&self) -> i32;
        fn Lang(&self) -> String;
        event Event: Handler;
        fn Raise(&self);
        fn Items(&self, count: u32) -> Windows::Foundation::Collections::IVector<i32>;
    }

    interface INonDefault {
        fn Value(&self) -> i32;
    }

    delegate fn Handler(sender: Object, args: i32);
}

#[winrt]
mod Test {
    #[repr(i32)]
    enum AsyncStatus {
        Canceled = 2,
        Completed = 1,
        Error = 3,
        Started = 0,
    }
    #[repr(i16)]
    enum I16 {
        A = -1,
        B = 0,
        C = 1,
        D = 2,
    }
}
#[win32]
mod Test {
    #[repr(i32)]
    #[Windows::Win32::Foundation::Metadata::ScopedEnum]
    enum Scoped {
        One = 1,
        Two = 2,
    }
    #[repr(i32)]
    enum Unscoped {
        Unscoped_One = 1,
        Unscoped_Two = 2,
    }
}

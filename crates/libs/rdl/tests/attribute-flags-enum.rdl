#[winrt]
mod Test {
    #[Usage(All)]
    struct ForAll {}
    #[Usage(Class)]
    struct ForClass {}
    #[Usage(Struct | Class)]
    struct ForClassOrStruct {}
    #[Usage(16)]
    struct ForUnknown {}
    #[repr(u32)]
    #[flags]
    enum Targets {
        None = 0,
        Class = 1,
        Struct = 2,
        Interface = 4,
        Method = 8,
        All = 4294967295,
    }
    attribute UsageAttribute {
        fn(value: Targets);
    }
}

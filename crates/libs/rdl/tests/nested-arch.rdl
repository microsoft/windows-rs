mod Windows {
    mod Win32 {
        mod Foundation {
            #[win32]
            mod Metadata {
                #[repr(i32)]
                enum Architecture {
                    X86 = 1,
                    X64 = 2,
                    Arm64 = 4,
                }
                attribute SupportedArchitectureAttribute {
                    fn(value: Architecture);
                }
            }
        }
    }
}
#[win32]
mod Test {
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X86)]
    struct SLIST_HEADER_0 {
        Depth: u16,
        CpuId: u16,
    }
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X86)]
    union SLIST_HEADER {
        Alignment: u64,
        Anonymous: SLIST_HEADER_0,
    }
}

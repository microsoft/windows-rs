#[win32]
mod Test {
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X86)]
    struct SLIST_HEADER_0 {
        Depth: u16,
        CpuId: u16,
    }
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X86)]
    union SLIST_HEADER {
        Alignment: u64,
        Anonymous: SLIST_HEADER_0,
    }
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X64)]
    struct SLIST_HEADER_0 {
        Alignment: u64,
        Region: u64,
    }
    #[Windows::Win32::Foundation::Metadata::SupportedArchitecture(X64)]
    union SLIST_HEADER {
        Alignment: u64,
        Anonymous: SLIST_HEADER_0,
    }
}

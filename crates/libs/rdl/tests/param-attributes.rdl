#[winrt]
mod Test {
    delegate fn Delegate(#[out] result: u32, #[opt] hint: u32, #[input] ptr: *mut u32);
    interface ITest {
        fn Method(&self, #[out] result: u32, #[opt] hint: u32, #[input] ptr: *mut u32);
    }
}
#[win32]
mod Test {
    extern fn Callback(#[out] result: u32, #[opt] hint: u32, #[input] ptr: *mut u32);
    #[library("test.dll")]
    extern fn Function(#[out] result: u32, #[opt] hint: u32, #[input] ptr: *mut u32);
}

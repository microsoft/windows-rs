<?xml version="1.0" encoding="utf-8"?>
<!--
  Pinned WDK + Windows SDK packages the WDK scraper (tool_wdk) generates the
  metadata/wdk corpus against. The WDK version here is the single source of truth and
  must match WDK_VERSION in src/main.rs; the SDK packages are shared with tool_win32
  (their version must match SDK_VERSION there). Restoring these into the NuGet global
  cache makes `cargo run -p tool_wdk` reproduce the corpus byte-for-byte on any machine
  and in CI, independent of whatever WDK is installed on the box.

  The WDK marketing version (10.0.26100.0) tracks the SDK, but its servicing build
  (.6584) lags the SDK's (.8249); both are pinned independently.

  Restore (into the default global cache):
    nuget restore crates/tools/wdk/packages.config -PackagesDirectory %USERPROFILE%\.nuget\packages
-->
<packages>
  <package id="Microsoft.Windows.WDK.x64" version="10.0.26100.6584" />
  <package id="Microsoft.Windows.SDK.CPP" version="10.0.26100.8249" />
  <package id="Microsoft.Windows.SDK.CPP.x64" version="10.0.26100.8249" />
</packages>

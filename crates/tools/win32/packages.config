<?xml version="1.0" encoding="utf-8"?>
<!--
  Pinned Windows SDK packages the win32 scraper (tool_win32) generates the
  metadata/win32 corpus against. The version here is the single source of truth and
  must match SDK_VERSION in src/main.rs. Restoring these into the NuGet global cache
  makes `cargo run -p tool_win32` reproduce the corpus byte-for-byte on any machine
  and in CI, independent of whatever Windows SDK is installed on the box.

  Restore (into the default global cache):
    nuget restore crates/tools/win32/packages.config -PackagesDirectory %USERPROFILE%\.nuget\packages
-->
<packages>
  <package id="Microsoft.Windows.SDK.CPP" version="10.0.26100.8249" />
  <package id="Microsoft.Windows.SDK.CPP.x64" version="10.0.26100.8249" />
  <package id="Microsoft.Windows.SDK.CPP.x86" version="10.0.26100.8249" />
  <package id="Microsoft.Windows.SDK.CPP.arm64" version="10.0.26100.8249" />
</packages>

#[winrt]
mod Test {
    interface ITest {
        fn Return(&self, input: [i32]) -> [i32];
        fn Out(&self, input: [i32], output: &mut [i32]);
        fn ExplicitOut(&self, input: [i32], #[out] output: [i32]);
    }
}
#[win32]
mod Test {
    interface IFixed {
        fn In(&self, input: [i32; 4]);
        fn Out(&self, output: &mut [i32; 5]);
    }
    struct S {
        a: [u8; 1],
        b: [u16; 2],
        c: [u32; 3],
    }
}

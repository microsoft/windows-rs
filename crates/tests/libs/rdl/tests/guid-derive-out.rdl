#[winrt]
mod Sample {
    interface ICompareWithMidl {
        fn Bool(&self, a: bool, b: [bool]) -> bool;
        fn U8(&self, a: u8, b: [u8]) -> u8;
        fn I16(&self, a: i16, b: [i16]) -> i16;
        fn U16(&self, a: u16, b: [u16]) -> u16;
        fn I32(&self, a: i32, b: [i32]) -> i32;
        fn U32(&self, a: u32, b: [u32]) -> u32;
        fn I64(&self, a: i64, b: [i64]) -> i64;
        fn U64(&self, a: u64, b: [u64]) -> u64;
        fn F32(&self, a: f32, b: [f32]) -> f32;
        fn F64(&self, a: f64, b: [f64]) -> f64;
        fn String(&self, a: String, b: [String]) -> String;
        fn Object(&self, a: *mut Object, b: [*mut Object]) -> *mut Object;
    }
}
#[winrt]
mod Test {
    interface IEmpty {}
    #[guid(0x00000001_0002_0003_0405_060708090a0b)]
    delegate fn IExplicitDelegate();
    #[guid(0x00000011_0012_0013_1415_161718191a1b)]
    interface IExplicitInterface {}
    #[guid(0x00000031_0032_0033_3435_363738393a3b)]
    interface IGuidLiteral {}
    #[guid(0x00000041_0042_0043_4445_464748494a4b)]
    delegate fn IGuidLiteralDelegate();
    delegate fn IHandler(arg: i32) -> u32;
    #[no_guid]
    interface INoGuid {}
    #[no_guid]
    delegate fn INoGuidDelegate();
    interface ISimple {
        fn get_Value(&self) -> i32;
    }
    interface ITypeExercise {
        fn get_Bool(&self) -> bool;
        fn get_I8(&self) -> i8;
        fn get_U8(&self) -> u8;
        fn get_I16(&self) -> i16;
        fn get_U16(&self) -> u16;
        fn get_I64(&self) -> i64;
        fn get_U64(&self) -> u64;
        fn get_F32(&self) -> f32;
        fn get_F64(&self) -> f64;
        fn get_ISize(&self) -> isize;
        fn get_USize(&self) -> usize;
        fn get_Obj(&self) -> Object;
        fn read_const(&self, p: *const i32);
        fn read_ref(&self, p: &i32);
        fn write_ptr(&self, p: *mut *mut i32);
    }
    interface IWithParam {
        fn Add(&self, a: i32, b: i32) -> i32;
    }
    interface IWithString {
        fn get_Name(&self) -> String;
    }
}
#[win32]
mod Test {
    interface IWin32 {}
    #[guid(0x00000021_0022_0023_2425_262728292a2b)]

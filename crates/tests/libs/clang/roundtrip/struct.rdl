#[win32]
mod Test {
    struct Empty {}
    struct Named {
        f1: Empty,
        f2: Numbers,
    }
    struct Numbers {
        f1: u8,
        f2: u16,
        f3: u32,
        f4: u64,
        f5: i8,
        f6: i16,
        f7: i32,
        f8: i64,
        f9: f32,
        f10: f64,
        f11: usize,
        f12: isize,
    }
    struct Pointers {
        f1: *mut Named,
        f2: *mut i32,
    }
}

#[win32]
mod Test {
    #[no_guid]
    interface IA {
        fn A(&self, a: IA);
    }
    #[no_guid]
    interface IB {
        fn A(&self, a: IA, b: IB, result: *mut IB);
    }
    #[no_guid]
    interface IC {
        fn Invoke(&self, a: ID, b: *mut ID);
    }
    #[no_guid]
    interface ID {
        fn Invoke(&self, a: IC, b: *mut IC);
    }
}

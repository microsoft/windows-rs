#[win32]
mod Test {
    #[no_guid]
    interface IA {
        fn A(&self, a: IA);
    }
    #[no_guid]
    interface IB {
        fn A(&self, a: IA, b: IB, result: *mut IB);
    }
    #[no_guid]
    interface IC {
        fn Invoke(&self, a: *mut ID, b: *mut *mut ID);
    }
    #[no_guid]
    interface ID {
        fn Invoke(&self, a: *mut IC, b: *mut *mut IC);
    }
}

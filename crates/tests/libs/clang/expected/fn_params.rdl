#[win32]
mod Test {
    type BOOL = i32;
    #[library("kernel32.dll")]
    extern "C" fn CloseFile(file: HANDLE) -> i32;
    type DWORD = u32;
    type HANDLE = *mut void;
    type LPCSTR = *const i8;
    #[library("kernel32.dll")]
    extern "C" fn OpenFile(name: PCSTR, flags: u32) -> HANDLE;
    #[library("kernel32.dll")]
    extern "C" fn ReadFile(file: HANDLE, buffer: *mut void, size: u32, bytesRead: *mut u32) -> i32;
    #[library("kernel32.dll")]
    extern "C" fn WriteFile(file: HANDLE, buffer: *const void, size: u32, bytesWritten: *mut u32) -> i32;
}

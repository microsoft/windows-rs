#[win32]
mod Test {
    #[guid(0x10000000_0000_0000_c000_000000000046)]
    interface IThing: IUnknown {
        fn Do(&self,) -> i32;
    }
    #[no_guid]
    interface IThingExt: IThing {}
    #[guid(0x00000000_0000_0000_c000_000000000046)]
    interface IUnknown {
        fn QueryInterface(&self, riid: *const void, ppvObject: *mut *mut void) -> i32;
        fn AddRef(&self,) -> u32;
        fn Release(&self,) -> u32;
    }
    #[guid(0x30000000_0000_0000_c000_000000000046)]
    interface IUser: IUnknown {
        fn Use(&self, ext: IThingExt) -> i32;
    }
    struct ThingResult {
        Base: IThing,
        context: *mut void,
        status: i32,
    }
}

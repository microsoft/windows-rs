#[win32]
mod Test {
    struct Flags16 {
        _bitfield1: u8,
        _bitfield2: u8,
    }
    struct Flags8 {
        _bitfield: u8,
    }
    struct Mixed {
        _bitfield1: u32,
        tag: u32,
        _bitfield2: u32,
    }
    union Overlap {
        _bitfield: u8,
        whole: u64,
    }
    #[packed(1)]
    struct PackedBits {
        _bitfield: u16,
        tail: u8,
    }
    struct Padding {
        _bitfield: u32,
    }
    struct Signed {
        _bitfield: i32,
    }
    struct Widths {
        _bitfield1: u8,
        _bitfield2: u32,
    }
    struct ZeroWidth {
        _bitfield1: u32,
        _bitfield2: u32,
    }
}

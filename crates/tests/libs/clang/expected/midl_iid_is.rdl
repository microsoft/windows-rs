#[win32]
mod Test {
    struct GUID {
        Data1: u32,
    }
    type HRESULT = i32;
    #[guid(0xc03f6a43_65a4_9818_987e_e0b810d2a6f2)]
    interface IResolver {
        fn Resolve(&self, riid: *const GUID, #[iid_is] #[retval] ppvObject: *mut *mut void) -> i32;
        fn ResolveTyped(&self, riid: *const GUID, #[iid_is] #[retval] objectReference: *mut *mut void) -> i32;
        fn Bind(&self, riid: *const GUID, punk: *const void) -> i32;
    }
    #[no_guid]
    interface IUnknown {
        fn QueryInterface(&self, riid: *const GUID, ppv: *mut *mut void) -> i32;
    }
    type REFIID = *const GUID;
}

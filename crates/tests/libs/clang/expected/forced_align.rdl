#[win32]
mod Test {
    #[align(16)]
    struct M128A {
        Low: u64,
        High: i64,
    }
    struct NaturalAnon {
        uType: u32,
        Anonymous: union {
            ptr: *mut void,
            off: u32,
        },
    }
    #[align(32)]
    struct OverAligned {
        value: i32,
    }
    struct XmmFrame {
        Xmm0: M128A,
        Flags: u32,
    }
}

// Exercises method-level `--filter` support for mixing allow
// (`Ns.Type::Method`) and deny (`!Ns.Type::Method`) entries on the same
// type. The filter set is:
//
//   * `Test.IFoo::Keep` — explicit allow.
//   * `!Test.IFoo::Mute` — explicit deny.
//
// Because there is at least one allow entry, the type is in allow-list
// mode: only methods explicitly allowed are kept; the rest demote.
//
//   * `Keep` — kept (explicit allow).
//   * `Mute` — demoted (explicit deny; in allow-list mode this entry is
//     mostly redundant with the default, but it documents intent and
//     wins on overlap with any allow entry that names the same method).
//   * `Default` — demoted (unlisted; default in allow-list mode is opt-out).

#[winrt]
mod Test {
    interface IFoo {
        fn Keep(&self) -> i32;
        fn Mute(&self) -> i32;
        fn Default(&self) -> i32;
    }
}

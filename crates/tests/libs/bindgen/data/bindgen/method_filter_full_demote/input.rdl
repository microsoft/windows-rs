// Exercises bindgen's `??Ns.Type` filter prefix (skeleton-only emission).
//
// `IDerived` requires `IRequired`. The fixture filters:
//   * `Test.IDerived` (full emit — struct + vtable + `_Impl` + inherent
//     `impl IDerived { Value() }` wrapper)
//   * `??Test.IRequired` (skeleton-only — struct + IID + hierarchy +
//     `Interface` impl, but every vtable slot demoted to `Slot: usize`
//     and no inherent caller-side wrapper block)
//
// This is the right shape for a base interface needed only for class /
// QI hierarchy: callers never invoke its methods through this
// projection, the type is not implementable through the (omitted)
// `_Impl` trait, but `cast::<IRequired>(&derived)?` still works.

#[winrt]
mod Test {
    interface IRequired {
        fn Stub(&self) -> i32;
    }
    interface IDerived: IRequired {
        fn Value(&self) -> i32;
    }
}

// Exercises bindgen's `?Ns.Type` filter prefix (trait-only emission).
//
// `IDerived` requires `IRequired`. The fixture filters:
//   * `Test.IDerived` (full emit — struct + vtable + `_Impl` + inherent
//     `impl IDerived { Value() }` wrapper)
//   * `?Test.IRequired` (trait-only — struct + vtable + `_Impl` +
//     thunks emit, but the inherent `impl IRequired { Stub() }`
//     caller-side wrapper block is suppressed)
//
// This mirrors the `windows-reference` use case: callers never invoke
// the parent interface's methods through the projection; implementers
// stub them (typically with `E_NOTIMPL`) to satisfy the WinRT required-
// interface contract. Suppressing the wrappers is purely a code-size
// optimisation — ABI and `_Impl` shape are preserved.

#[winrt]
mod Test {
    interface IRequired {
        fn Stub(&self) -> i32;
    }
    interface IDerived: IRequired {
        fn Value(&self) -> i32;
    }
}

// Exercises class-level method filter cascade. Runtime classes don't carry
// their own `MethodDef` rows; the methods exposed via `impl Class { … }` are
// forwarders generated from each required interface (instance default,
// static factory, activation/composable factory). Writing
// `!Ns.Class::Method` should resolve `Method` against every required
// interface that exposes it and demote the matching vtable slot, which in
// turn drops the corresponding `impl Class` forwarder for free via the
// existing class-emission path.
//
//   * `!Test.Foo::DropStatic` → demotes `IFooStatics::DropStatic` to a
//     `Slot: usize` and drops `Foo::DropStatic` forwarder.
//   * `!Test.Foo::DropFactory` → same treatment for `IFooFactory::Drop`
//     (sugar `DropFactory` → no expansion, exact match against the factory
//     method name).
//   * Sibling methods on each interface (`KeepStatic`, `KeepFactory`,
//     `Direct`) are unaffected.
//   * `Foo::new()` and the `IFooStatics`/`IFooFactory` factory-cache helpers
//     remain so the surviving forwarders still compile.

#[winrt]
mod Test {
    #[Windows::Foundation::Metadata::Activatable(IFooFactory, 1)]
    #[Windows::Foundation::Metadata::Static(IFooStatics, 1)]
    class Foo {
        IFoo,
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Foo)]
    interface IFoo {
        fn Direct(&self) -> i32;
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Foo)]
    interface IFooStatics {
        fn KeepStatic(&self) -> i32;
        fn DropStatic(&self) -> i32;
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Foo)]
    interface IFooFactory {
        fn KeepFactory(&self) -> Foo;
        fn DropFactory(&self) -> Foo;
    }
}

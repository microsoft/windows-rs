// Validates that bindgen's filter automatically pulls in the entire base-class
// hierarchy when only the most-derived class is explicitly named. With
// `filter = "Test.Leaf"`, the output must still contain `Middle` and `Base`
// (and their associated interfaces), reaching through multiple levels of
// inheritance — not just the immediate base.

#[winrt]
mod Test {
    class Base {
        IBase,
    }
    class Middle: Base {
        IMiddle,
    }
    class Leaf: Middle {
        ILeaf,
    }
    interface IBase {}
    interface IMiddle {}
    interface ILeaf {}
}

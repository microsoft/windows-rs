#[winrt]
mod Windows {
    mod Foundation {
        interface IReference<T> {
            fn Value(&self) -> T;
        }
        // Stubs for bindgen's auto-added `Windows.Foundation.IAsync*` and
        // `Windows.Foundation.Async*` reference filters. Neither is referenced
        // from `Test.IThing`, so they don't appear in `expected.rs`.
        interface IAsyncAction {}
        interface AsyncOperationCompletedHandler {}
    }
}

#[winrt]
mod Test {
    interface IThing {
        fn Count(&self) -> super::Windows::Foundation::IReference<i32>;
        fn SetCount(&self, value: super::Windows::Foundation::IReference<i32>);
        fn Name(&self) -> super::Windows::Foundation::IReference<String>;
        fn SetName(&self, value: super::Windows::Foundation::IReference<String>);
    }
}

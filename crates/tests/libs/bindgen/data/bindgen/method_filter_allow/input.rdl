// Exercises method-level `--filter` allowlist support: `Ns.Type::Method`
// flips the type into allowlist mode — only listed methods are kept; the
// rest are excluded from the user-facing surface. With option 1, excluded
// slots retain their real ABI signature in `_Vtbl` and get a synthesised
// `E_NOTIMPL` stub thunk in `_Vtbl::new`.
//
//   * The first include entry is the type itself (`Test`), required to
//     keep `IFoo` in the type set.
//   * `Test.IFoo::Keep` is the only allowed method; `Drop` and `AlsoDrop`
//     drop from the callable surface and from `IFoo_Impl`, but their
//     vtable slots stay typed and `IFoo_Vtbl::new` installs `E_NOTIMPL`
//     stubs for both.

#[winrt]
mod Test {
    interface IFoo {
        fn Keep(&self) -> i32;
        fn Drop(&self) -> i32;
        fn AlsoDrop(&self) -> i32;
    }
}

// Exercises method-level `--filter` allowlist support: `Ns.Type::Method`
// flips the type into allowlist mode — only listed methods are kept; the
// rest demote to opaque `Slot: usize` entries at their original vtable
// offset.
//
//   * The first include entry is the type itself (`Test`), required to
//     keep `IFoo` in the type set.
//   * `Test.IFoo::Keep` is the only method allowed; `Drop` and `AlsoDrop`
//     demote to `Drop: usize,` / `AlsoDrop: usize,` slots.

#[winrt]
mod Test {
    interface IFoo {
        fn Keep(&self) -> i32;
        fn Drop(&self) -> i32;
        fn AlsoDrop(&self) -> i32;
    }
}

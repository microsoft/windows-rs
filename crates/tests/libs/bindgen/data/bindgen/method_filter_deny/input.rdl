// Exercises method-level `--filter` denylist support: `!Ns.Type::Method`
// excludes a single method from the user-facing surface. With option 1,
// the slot retains its real ABI signature in `_Vtbl` and `_Vtbl::new`
// installs a synthesised `E_NOTIMPL` stub thunk, so the interface remains
// implementable from Rust.
//
//   * `IFoo::Keep` should emit a typed vtable slot, a callable
//     `impl IFoo { pub fn Keep ... }` wrapper, an `IFoo_Impl::Keep`
//     trait method, and a normal upcall thunk in `IFoo_Vtbl::new`.
//   * `IFoo::Drop` should keep its typed (private) vtable slot, but lose
//     its `impl IFoo` wrapper and its `IFoo_Impl` trait method. Its slot
//     in `IFoo_Vtbl::new` is populated by a synthesised stub that returns
//     `windows_core::HRESULT(0x80004001)` (`E_NOTIMPL`).

#[winrt]
mod Test {
    interface IFoo {
        fn Keep(&self) -> i32;
        fn Drop(&self) -> i32;
    }
}

// Coverage for `InterfaceKind::Composable` (both arms) when the composable
// factory method is marked `#[Windows::Foundation::Metadata::NoException]`.
// Sibling of the `noexcept_factory` fixture which covers the Activatable /
// Static arms.
//
// `InterfaceKind::Composable` always emits two methods per factory call:
//   * a non-aggregating `Foo::CreateInstance(...)`, and
//   * an aggregating `Foo::CreateInstance_compose<T: Compose>(..., compose: T)`.
//
// Both go through the `Self::IFooFactory(|this| Ok(unsafe { … })).unwrap()`
// shape under `[NoException]`: the closure must return `Result<R>` to
// satisfy the factory-cache helper, even though the `noexcept` method
// itself returns a non-`Result` value, and the inner vcall only checks the
// HRESULT with `debug_assert!`.

#[winrt]
mod Test {
    #[Windows::Foundation::Metadata::Composable(IFooFactory, Public, 1)]
    class Foo {
        IFoo,
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Foo)]
    interface IFoo {}
    #[Windows::Foundation::Metadata::ExclusiveTo(Foo)]
    interface IFooFactory {
        #[Windows::Foundation::Metadata::NoException]
        fn CreateInstance(&self, name: i32, outer: Object, inner: &mut Object) -> Foo;
    }
}

//! --flat --filter Test.Widget::Act
// Drives the class member-routing branch of filter.rs register_member: a method
// filter on a runtime class locates the required interface that carries the
// method and registers it there.
#[winrt]
mod Windows {
    mod Foundation {
        mod Metadata {
            attribute ActivatableAttribute {
                fn(version: u32);
            }
            attribute ExclusiveToAttribute {
                fn(r#type: Type);
            }
        }
    }
}
#[winrt]
mod Test {
    #[Windows::Foundation::Metadata::Activatable(1)]
    class Widget {
        IWidget,
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Widget)]
    interface IWidget {
        fn Act(&self) -> i32;
        fn Unused(&self) -> i32;
    }
}

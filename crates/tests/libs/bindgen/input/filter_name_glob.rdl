//! --flat --filter Test::Wid*
// Drives the NameGlob branch of filter.rs from_resolved: a `Ns::Prefix*` filter
// expands to every type in the namespace whose name starts with the prefix.
#[winrt]
mod Test {
    struct Widget {
        x: i32,
    }
    struct Widening {
        y: i32,
    }
    struct Other {
        z: i32,
    }
}

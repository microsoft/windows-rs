//! --filter Test::IOuter --sys --flat
// Same referenced-type closure as `type_closure`, exercised in `--sys` style to
// confirm the behaviour is style-independent (sys is not `--minimal`).
#[win32]
mod Test {
    interface IOuter {
        fn GetInner(&self) -> IInner;
    }
    interface IInner {
        fn Value(&self) -> i32;
    }
}

//! --filter Test::IOuter::* --minimal --flat
// The same filter under `--minimal`. `IOuter::GetInner` is callable and `IInner`
// is pulled in, but `IInner`'s own `Value` collapses to a name-only slot because
// minimal demotes methods on types that are only pulled in as dependencies.
// Contrast with `type_closure` (default style), where `IInner::Value` is emitted.
#[win32]
mod Test {
    interface IOuter {
        fn GetInner(&self) -> IInner;
    }
    interface IInner {
        fn Value(&self) -> i32;
    }
}

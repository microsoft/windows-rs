//! --filter Test.Factory::Create --flat --minimal
// Drives the Class branch of minimal_type_map.rs combine_minimal: the requested
// method returns a runtime class, so the closure pulls in only its default
// interface (IWidget) plus the base-class hierarchy walk, without dragging in
// static/composable interfaces.
#[winrt]
mod Windows {
    mod Foundation {
        mod Metadata {
            attribute ActivatableAttribute {
                fn(version: u32);
            }
            attribute ExclusiveToAttribute {
                fn(r#type: Type);
            }
        }
    }
}
#[winrt]
mod Test {
    #[Windows::Foundation::Metadata::Activatable(1)]
    class Widget {
        IWidget,
    }
    #[Windows::Foundation::Metadata::ExclusiveTo(Widget)]
    interface IWidget {
        fn Value(&self) -> i32;
    }
    interface Factory {
        fn Create(&self) -> Widget;
    }
}

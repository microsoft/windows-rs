//! --filter Test --sys --flat
#[win32]
mod Test {
    type DEVPROPGUID = GUID;
    type DEVPROPID = u32;
    struct PROPERTYKEY {
        fmtid: GUID,
        pid: u32,
    }
    struct DEVPROPKEY {
        fmtid: DEVPROPGUID,
        pid: DEVPROPID,
    }
    #[guid(0x540b947e_8b40_45bc_a8a2_6a0b894cbda2)]
    const PKEY_Test_Sample: PROPERTYKEY = 100u32;
    #[guid(0x26e3e2a2_1234_5678_9abc_def012345678)]
    const DEVPKEY_Test_Sample: DEVPROPKEY = 26u32;
}

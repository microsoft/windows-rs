#[win32]
mod Test {
    #[typedef]
    struct HRESULT {
        value: i32,
    }
    #[typedef]
    struct DWORD {
        value: u32,
    }
    #[typedef]
    struct HANDLE {
        value: *mut u8,
    }
    fn Add(a: i32, b: i32) -> i32;
    fn CreateHandle(flags: DWORD, out: *mut HANDLE) -> HRESULT;
    fn CloseHandle(handle: HANDLE);
    fn GetCount(data: *const u8, length: DWORD) -> DWORD;
}

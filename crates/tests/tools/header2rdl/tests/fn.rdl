#[win32]
mod Test {
    #[library("test")]
    extern fn Add(a: i32, b: i32) -> i32;
    #[library("test")]
    extern fn CloseHandle(handle: HANDLE);
    #[library("test")]
    extern fn CreateHandle(flags: DWORD, out: *mut HANDLE) -> HRESULT;
    #[typedef]
    struct DWORD {
        value: u32,
    }
    #[library("test")]
    extern fn GetCount(data: *const u8, length: DWORD) -> DWORD;
    #[typedef]
    struct HANDLE {
        value: *mut u8,
    }
    #[typedef]
    struct HRESULT {
        value: i32,
    }
}

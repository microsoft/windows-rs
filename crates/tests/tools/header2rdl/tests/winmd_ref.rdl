#[win32]
mod Test {
    #[typedef]
    struct BYTE {
        value: u8,
    }
    #[typedef]
    struct CLSID {
        value: GUID,
    }
    #[typedef]
    struct DOUBLE {
        value: f64,
    }
    #[typedef]
    struct DWORD {
        value: u32,
    }
    #[typedef]
    struct FLOAT {
        value: f32,
    }
    struct GUID {
        Data1: u32,
        Data2: u16,
        Data3: u16,
        Data4: [u8; 8],
    }
    #[typedef]
    struct IID {
        value: GUID,
    }
    #[typedef]
    struct INT {
        value: i32,
    }
    #[guid(0x12345678_1234_1234_1234_123456789abc)]
    interface IWidget: Windows::Win32::System::Com::IUnknown {
        fn GetId(&self, id: *mut i32) -> i32;
        fn SetName(&self, name: *const i8) -> i32;
    }
    #[typedef]
    struct LONG {
        value: i32,
    }
    #[typedef]
    struct LPCRECT {
        value: *const Windows::Win32::Foundation::RECT,
    }
    #[typedef]
    struct LPCWSTR {
        value: *const WCHAR,
    }
    #[typedef]
    struct LPRECT {
        value: *mut Windows::Win32::Foundation::RECT,
    }
    #[typedef]
    struct LPVOID {
        value: *mut u8,
    }
    #[typedef]
    struct LPWSTR {
        value: *mut WCHAR,
    }
    #[typedef]
    struct PCWSTR {
        value: *const WCHAR,
    }
    #[typedef]
    struct REFCLSID {
        value: *mut u8,
    }
    #[typedef]
    struct REFIID {
        value: *mut u8,
    }
    #[typedef]
    struct UINT {
        value: u32,
    }
    #[typedef]
    struct UINT32 {
        value: u32,
    }
    #[typedef]
    struct UINT64 {
        value: u64,
    }
    #[typedef]
    struct ULONG {
        value: u32,
    }
    #[typedef]
    struct WCHAR {
        value: u16,
    }
    #[typedef]
    struct WORD {
        value: u16,
    }
    struct tagPOINT {
        x: LONG,
        y: LONG,
    }
    struct tagRECT {
        left: LONG,
        top: LONG,
        right: LONG,
        bottom: LONG,
    }
    struct tagSIZE {
        cx: LONG,
        cy: LONG,
    }
}

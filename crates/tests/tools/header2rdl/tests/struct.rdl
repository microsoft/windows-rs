#[win32]
mod Test {
    struct POINT {
        X: i32,
        Y: i32,
    }
    struct RECT {
        left: i32,
        top: i32,
        right: i32,
        bottom: i32,
    }
    struct LARGE_INTEGER_0 {
        LowPart: u32,
        HighPart: i32,
    }
    union LARGE_INTEGER {
        u: LARGE_INTEGER_0,
        QuadPart: i64,
    }
}

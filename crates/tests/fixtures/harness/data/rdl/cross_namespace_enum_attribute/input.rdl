#[winrt]
mod Test {
    mod Attributes {
        attribute MarshalingBehaviorAttribute {
            fn(value: MarshalingType);
        }
        #[repr(i32)]
        enum MarshalingType {
            None = 1,
            Agile = 2,
            Standard = 3,
        }
    }
    mod Types {
        #[Test::Attributes::MarshalingBehavior(Agile)]
        class MyClass {}
    }
}

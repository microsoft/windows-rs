#[win32]
mod Test {
    #[packed(1)]
    struct Packed1 {
        a: u8,
        b: u32,
        c: u16,
    }
    #[packed(2)]
    struct Packed2 {
        a: u16,
        b: u32,
        c: u64,
    }
    #[packed(4)]
    struct Packed4 {
        a: u32,
        b: u64,
    }
    struct PackedNoOp {
        a: u32,
        b: u32,
    }
    struct Unpacked {
        a: u8,
        b: u32,
    }
}
